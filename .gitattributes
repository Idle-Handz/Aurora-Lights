# Normalize all text files to LF in the repository and working tree.
# This keeps Windows checkouts from rewriting source files to CRLF.
* text=auto eol=lf

# Files that must always be LF (shell interpreters, YAML CI runners).
*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf
*.csx       text eol=lf

# Source / markup.
*.cs        text eol=lf
*.razor     text eol=lf
*.xaml      text eol=lf
*.xml       text eol=lf
*.sql       text eol=lf
*.json      text eol=lf
*.css       text eol=lf
*.svg       text eol=lf
*.js        text eol=lf
*.html      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.ps1       text eol=lf
*.resx      text eol=lf
*.csproj    text eol=lf
*.sln       text eol=lf
*.manifest  text eol=lf
*.appxmanifest text eol=lf
*.plist     text eol=lf
*.gitignore text eol=lf
*.LICENSE   text eol=lf

# Binary: never diff or convert.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.ico       binary
*.otf       binary
*.ttf       binary
*.pdf       binary
*.dll       binary
*.exe       binary
*.pdb       binary
*.sqlite    binary
*.zip       binary
