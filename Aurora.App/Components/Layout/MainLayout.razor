@inherits LayoutComponentBase
@implements IDisposable
@inject CharacterTabService Tabs
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject UserPreferencesService Prefs
@inject AppIdentityService Brand
@inject IJSRuntime JS
@inject Aurora.App.Services.Updates.AppUpdateService AppUpdates
@inject Aurora.App.Services.Updates.ContentUpdateService ContentUpdates
@inject ContentService Content

<MudThemeProvider Theme="_theme" IsDarkMode="@(!Prefs.LightMode)" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Dark">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <div class="app-brand ml-2">
            <img src="brand/aurora-appicon.png" alt="@Brand.AppName" class="app-brand-icon" />
            <div class="app-brand-text">
                <div class="app-brand-title">@Brand.AppName</div>
            </div>
        </div>
        <MudSpacer />
        <MudTextField T="string"
                      Value="_compendiumQuickQuery"
                      ValueChanged="OnCompendiumQueryChanged"
                      Placeholder="Compendium search"
                      Immediate="true"
                      Margin="Margin.Dense"
                      Variant="Variant.Outlined"
                      Class="appbar-compendium-search"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      OnKeyDown="HandleCompendiumSearchKeyDown" />
        <MudIconButton Icon="@Icons.Material.Filled.Search"
                       Color="Color.Inherit"
                       title="Search compendium"
                       OnClick="NavigateToCompendiumSearch" />
        @if (Tabs.ActiveTab?.IsDirty == true)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Save"
                           Color="Color.Primary"
                           title="Save (Ctrl+S)"
                           OnClick="@(() => SaveActive())" />
        }
        @* Update available indicator — single icon button covers both channels. App releases jump
           directly to Settings → Updates; downloaded content jumps to Settings → Content. The badge
           coalesces app + content so we don't crowd the AppBar with two icons. *@
        @if (UpdateAvailableCount > 0)
        {
            <MudTooltip Text="@UpdateTooltip">
                <MudBadge Content="@UpdateAvailableCount"
                          Color="Color.Primary"
                          Overlap="true"
                          Bordered="true">
                    <MudIconButton Icon="@Icons.Material.Filled.SystemUpdateAlt"
                                   Color="Color.Inherit"
                                   OnClick="OpenUpdatesPage" />
                </MudBadge>
            </MudTooltip>
        }
        <MudMenu Icon="@Icons.Material.Filled.HelpOutline"
                 Color="Color.Inherit"
                 AriaLabel="Help and about"
                 Dense="true">
            <MudMenuItem Icon="@Icons.Material.Filled.Keyboard" OnClick="ShowShortcutsDialog">
                Keyboard shortcuts
            </MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Info" OnClick="ShowAboutDialog">
                About @Brand.AppName
            </MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Class="desktop-nav-drawer"
               ClipMode="DrawerClipMode.Always"
               Elevation="2"
               Variant="DrawerVariant.Mini"
               OpenMiniOnHover="true">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="app-main-content">
        @* Character tab bar — only visible when one or more characters are open *@
        @if (Tabs.Tabs.Count > 0)
        {
            <div class="char-tab-bar">
                @foreach (var tab in Tabs.Tabs)
                {
                    <div class="char-tab @(tab == Tabs.ActiveTab ? "char-tab-active" : "")"
                         @onclick="() => ActivateTab(tab)">
                        <span class="char-tab-name">@tab.DisplayName</span>
                        @if (tab.IsDirty)
                        {
                            <span class="char-tab-dirty" title="Unsaved changes">●</span>
                        }
                        <button class="char-tab-close"
                                @onclick:stopPropagation="true"
                                @onclick="() => CloseTabAsync(tab)"
                                title="@(tab.IsDirty ? "Close (will prompt to save unsaved changes)" : "Close")">×</button>
                    </div>
                }
            </div>
        }
        <MudContainer MaxWidth="MaxWidth.False" Class="app-content-container pa-4" Style="@ContentStyle">
            <AppErrorBoundary @ref="_errorBoundary">@Body</AppErrorBoundary>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@if (_mobileMoreOpen && Tabs.ActiveTab != null)
{
    <div class="mobile-more-backdrop" @onclick="CloseMobileMore"></div>
    <nav class="mobile-more-panel" aria-label="More navigation">
        <NavLink href="/character" class="mobile-more-link" @onclick="CloseMobileMore">
            <MudIcon Icon="@Icons.Material.Filled.Person" />
            <span>Overview</span>
        </NavLink>
        <NavLink href="/session" class="mobile-more-link" @onclick="CloseMobileMore">
            <MudIcon Icon="@Icons.Material.Filled.Favorite" />
            <span>Session</span>
        </NavLink>
        <NavLink href="/sheet" class="mobile-more-link" @onclick="CloseMobileMore">
            <MudIcon Icon="@Icons.Material.Filled.Article" />
            <span>Sheet</span>
        </NavLink>
        <NavLink href="/manage" class="mobile-more-link" @onclick="CloseMobileMore">
            <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" />
            <span>Manage</span>
        </NavLink>
        <NavLink href="/compendium" class="mobile-more-link" @onclick="CloseMobileMore">
            <MudIcon Icon="@Icons.Material.Filled.MenuBook" />
            <span>Compendium</span>
        </NavLink>
        <NavLink href="/settings" class="mobile-more-link" @onclick="CloseMobileMore">
            <MudIcon Icon="@Icons.Material.Filled.Settings" />
            <span>Settings</span>
        </NavLink>
        @if (Prefs.DevMode)
        {
            <NavLink href="/console" class="mobile-more-link" @onclick="CloseMobileMore">
                <MudIcon Icon="@Icons.Material.Filled.Terminal" />
                <span>Console</span>
            </NavLink>
        }
    </nav>
}

<nav class="mobile-bottom-nav" aria-label="Primary navigation">
    <NavLink href="/" Match="NavLinkMatch.All" class="mobile-bottom-link">
        <MudIcon Icon="@Icons.Material.Filled.People" />
        <span>Chars</span>
    </NavLink>
    @if (Tabs.ActiveTab != null)
    {
        <NavLink href="/build" class="mobile-bottom-link">
            <MudIcon Icon="@Icons.Material.Filled.Build" />
            <span>Build</span>
        </NavLink>
        <NavLink href="/equipment" class="mobile-bottom-link">
            <MudIcon Icon="@Icons.Material.Filled.Shield" />
            <span>Gear</span>
        </NavLink>
        <NavLink href="/magic" class="mobile-bottom-link">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" />
            <span>Magic</span>
        </NavLink>
        <button type="button"
                class="mobile-bottom-link mobile-bottom-btn @(_mobileMoreOpen ? "active" : string.Empty)"
                @onclick="() => _mobileMoreOpen = !_mobileMoreOpen">
            <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" />
            <span>More</span>
        </button>
    }
    else
    {
        <NavLink href="/compendium" class="mobile-bottom-link">
            <MudIcon Icon="@Icons.Material.Filled.MenuBook" />
            <span>Comp</span>
        </NavLink>
        <NavLink href="/settings" class="mobile-bottom-link">
            <MudIcon Icon="@Icons.Material.Filled.Settings" />
            <span>Settings</span>
        </NavLink>
    }
</nav>

<div class="app-status-bar">
    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-disabled, #6c7086);">@Brand.AppName</MudText>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _mobileMoreOpen;
    private AppErrorBoundary? _errorBoundary;
    private DotNetObjectReference<MainLayout>? _selfRef;
    private string _compendiumQuickQuery = string.Empty;

    private string ContentStyle => Tabs.Tabs.Count > 0
        ? "height: calc(100dvh - 64px - 34px - 28px); overflow-y: auto; overflow-x: hidden;"
        : "height: calc(100dvh - 64px - 28px); overflow-y: auto; overflow-x: hidden;";

    protected override void OnInitialized()
    {
        Tabs.TabsChanged              += OnTabsChanged;
        CharacterContext.CaptureError += OnCaptureError;
        Prefs.ThemeChanged            += OnThemeChanged;
        Prefs.DeveloperModeChanged    += OnDeveloperModeChanged;
        Nav.LocationChanged           += OnLocationChanged;
        AppUpdates.Changed            += OnUpdatesChanged;
        ContentUpdates.Changed        += OnUpdatesChanged;
        Content.ContentDownloaded     += OnContentDownloaded;
        Content.Changed               += OnUpdatesChanged;
    }

    /// <summary>
    /// Background startup refresh finished and at least one index produced new files.
    /// We surface this as a passive snackbar — the AppBar update indicator already
    /// gives a persistent "click here" affordance, so the snackbar just informs.
    /// The notification is dispatched via <c>InvokeAsync</c> because the event can
    /// fire on any thread (the startup refresh is a background <c>Task.Run</c> chain).
    /// </summary>
    private void OnContentDownloaded(string message)
    {
        if (_disposed) return;
        _ = InvokeAsync(() =>
        {
            if (_disposed) return;
            bool hasDirty = Tabs.Tabs.Any(t => t.IsDirty);
            string suffix = hasDirty
                ? " Open Settings → Content to reload when ready (you have unsaved changes)."
                : " Open Settings → Content to reload, or click the update icon.";
            Snackbar.Add(message + suffix, Severity.Info,
                         cfg => cfg.VisibleStateDuration = 12000);
            StateHasChanged();
        });
    }

    /// <summary>
    /// How many distinct attention-worthy signals to badge in the AppBar (0–3):
    ///   • a newer app release (GitHub)
    ///   • a newer content release (GitHub, content- tag)
    ///   • a startup-downloaded content pack pending reload
    /// </summary>
    private int UpdateAvailableCount =>
        (AppUpdates.UpdateAvailable ? 1 : 0) +
        (ContentUpdates.InstalledUpdateAvailable || ContentUpdates.ReleaseNoticeAvailable ? 1 : 0) +
        (Content.ContentReloadPending ? 1 : 0);

    private string UpdateTooltip
    {
        get
        {
            var parts = new List<string>();
            if (AppUpdates.UpdateAvailable)
                parts.Add($"App: {AppUpdates.Latest!.LatestTag}");
            if (ContentUpdates.InstalledUpdateAvailable)
                parts.Add($"Content update: {ContentUpdates.Latest!.LatestTag}");
            else if (ContentUpdates.ReleaseNoticeAvailable)
                parts.Add($"Content release: {ContentUpdates.Latest!.LatestTag}");
            if (Content.ContentReloadPending)
                parts.Add("Reload to apply downloaded content");
            return parts.Count == 0 ? "Updates" : string.Join(" • ", parts);
        }
    }

    private void OnUpdatesChanged()
    {
        if (_disposed) return;
        _ = InvokeAsync(() => { if (!_disposed) StateHasChanged(); });
    }

    private void OpenUpdatesPage() =>
        Nav.NavigateTo(AppUpdates.UpdateAvailable
            ? "/settings?tab=updates"
            : "/settings?tab=content");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            try { await JS.InvokeVoidAsync("AuroraShortcuts.register", _selfRef); } catch { }
            if (Prefs.AutoDownloadContentOnStartup)
                _ = Task.Run(Content.RunStartupContentRefreshAsync);
        }
    }

    [JSInvokable]
    public Task OnCtrlS()
    {
        if (!_disposed) _ = InvokeAsync(SaveActive);
        return Task.CompletedTask;
    }

    private async Task ShowShortcutsDialog()
    {
        await DialogService.ShowMessageBox(
            "Keyboard Shortcuts",
            (MarkupString)"""
            <table style="border-collapse:collapse; width:100%; font-size:13px;">
              <tbody>
                <tr>
                  <td style="padding:6px 16px 6px 0; color:var(--mud-palette-primary); font-family:monospace; white-space:nowrap;">Ctrl + S</td>
                  <td style="padding:6px 0;">Save the active character</td>
                </tr>
              </tbody>
            </table>
            <p style="font-size:12px; color:var(--mud-palette-text-disabled); margin-top:12px;">
              More shortcuts can be added in future updates.
            </p>
            """,
            yesText: "Close");
    }

    private async Task ShowAboutDialog()
    {
        await DialogService.ShowAsync<Aurora.App.Components.Pages.AboutDialog>(
            $"About {Brand.AppName}",
            new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                CloseButton = true
            });
    }

    private void OnThemeChanged()
    {
        if (_disposed) return;
        _ = InvokeAsync(() => { if (!_disposed) StateHasChanged(); });
    }

    private void OnDeveloperModeChanged()
    {
        if (_disposed) return;
        _ = InvokeAsync(() => { if (!_disposed) StateHasChanged(); });
    }

    private bool _disposed;

    private void OnTabsChanged()
    {
        if (_disposed) return;
        _ = InvokeAsync(() => { if (!_disposed) StateHasChanged(); });
    }

    private void OnCaptureError(string message)
    {
        if (_disposed) return;
        _ = InvokeAsync(() =>
        {
            if (!_disposed)
                Snackbar.Add(message, Severity.Error, cfg => cfg.VisibleStateDuration = 8000);
        });
    }

    public void Dispose()
    {
        _disposed = true;
        Tabs.TabsChanged              -= OnTabsChanged;
        CharacterContext.CaptureError -= OnCaptureError;
        Prefs.ThemeChanged            -= OnThemeChanged;
        Prefs.DeveloperModeChanged    -= OnDeveloperModeChanged;
        Nav.LocationChanged           -= OnLocationChanged;
        AppUpdates.Changed            -= OnUpdatesChanged;
        ContentUpdates.Changed        -= OnUpdatesChanged;
        Content.ContentDownloaded     -= OnContentDownloaded;
        Content.Changed               -= OnUpdatesChanged;
        try { _ = JS.InvokeVoidAsync("AuroraShortcuts.unregister"); } catch { }
        _selfRef?.Dispose();
    }

    private void ActivateTab(CharacterTab tab)
    {
        Tabs.ActivateTab(tab);
        Nav.NavigateTo("/character");
    }

    private async Task CloseTabAsync(CharacterTab tab)
    {
        if (tab.IsDirty)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Unsaved Changes",
                $"Save changes to {tab.DisplayName} before closing?",
                yesText: "Save", noText: "Discard", cancelText: "Cancel");

            if (result == null) return; // Cancel

            if (result == true)
            {
                var error = await BuildService.SaveTabAsync(tab);
                if (error != null)
                {
                    Snackbar.Add($"Save failed: {error}", Severity.Error);
                    return;
                }
            }
        }

        var wasActive = tab == Tabs.ActiveTab;
        Tabs.CloseTab(tab);
        await CharacterContext.ReleaseAsync(tab);

        if (wasActive)
        {
            if (Tabs.ActiveTab != null)
                Nav.NavigateTo("/character");
            else
                Nav.NavigateTo("/");
        }
    }

    private async Task SaveActive()
    {
        var tab = Tabs.ActiveTab;
        if (tab == null) return;

        var error = await BuildService.SaveTabAsync(tab);
        if (error == null)
        {
            Tabs.MarkClean(tab);
            Snackbar.Add("Saved.", Severity.Success);
        }
        else
        {
            Snackbar.Add($"Save failed: {error}", Severity.Error);
        }
    }

    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary          = "#89b4fa",
            Secondary        = "#cba6f7",
            Background       = "#1e1e2e",
            BackgroundGray   = "#181825",
            Surface          = "#313244",
            DrawerBackground = "#181825",
            AppbarBackground = "#181825",
            ActionDefault    = "#cdd6f4",
            TextPrimary      = "#cdd6f4",
            TextSecondary    = "#a6adc8",
            TextDisabled     = "#6c7086",
            Divider          = "#313244",
            LinesDefault     = "#313244",
            LinesInputs      = "#45475a",
        },
        PaletteLight = new PaletteLight
        {
            Primary          = "#1e66f5",
            Secondary        = "#8839ef",
            Background       = "#eff1f5",
            BackgroundGray   = "#e6e9ef",
            Surface          = "#ccd0da",
            DrawerBackground = "#dce0e8",
            AppbarBackground = "#e6e9ef",
            ActionDefault    = "#4c4f69",
            TextPrimary      = "#4c4f69",
            TextSecondary    = "#5c5f77",
            TextDisabled     = "#9ca0b0",
            Divider          = "#ccd0da",
            LinesDefault     = "#ccd0da",
            LinesInputs      = "#bcc0cc",
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void CloseMobileMore() => _mobileMoreOpen = false;

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (_disposed) return;
        _ = InvokeAsync(() =>
        {
            if (_disposed) return;
            _mobileMoreOpen = false;
            _errorBoundary?.RecoverPage();
            StateHasChanged();
        });
    }

    private Task OnCompendiumQueryChanged(string value)
    {
        _compendiumQuickQuery = value;
        return Task.CompletedTask;
    }

    private Task HandleCompendiumSearchKeyDown(KeyboardEventArgs args)
    {
        if (string.Equals(args.Key, "Enter", StringComparison.OrdinalIgnoreCase))
            NavigateToCompendiumSearch();

        return Task.CompletedTask;
    }

    private void NavigateToCompendiumSearch()
    {
        string query = _compendiumQuickQuery.Trim();
        Nav.NavigateTo(string.IsNullOrWhiteSpace(query)
            ? "/compendium"
            : $"/compendium?q={Uri.EscapeDataString(query)}");
    }
}
