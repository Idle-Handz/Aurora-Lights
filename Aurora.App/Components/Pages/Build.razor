    // ── Level up ─────────────────────────────────────────────────────────────────

    private async Task LevelUpAsync()
    {
        var tab = Tabs.ActiveTab;
        if (tab == null)
        {
            WarnUnavailable("There is no active character to level up.");
            return;
        }

        // When the character has more than one class, ask which class to level.
        var classes = await BuildService.GetLevelUpClassesAsync(tab);
        LevelUpClassOption? chosen = classes.FirstOrDefault(c => c.IsMain) ?? classes.FirstOrDefault();

        if (classes.Count > 1)
        {
            var options = classes
                .Select(c => new ElementOption(
                    c.Id,
                    c.Name,
                    $"Currently {c.Name} level {c.Level}.",
                    c.IsMain ? "Main class" : "Multiclass"))
                .ToList();

            var entry = new SelectionRuleEntry(
                Rule: null!, Number: 1, Label: "Choose a class to level", CurrentName: null, RequiredLevel: 0);
            var parameters = new DialogParameters
            {
                [nameof(SelectionPickerDialog.Entry)]   = entry,
                [nameof(SelectionPickerDialog.Options)] = (IReadOnlyList<ElementOption>)options,
            };
            var dialogOptions = new DialogOptions
            {
                MaxWidth = MaxWidth.Large, FullWidth = true, CloseOnEscapeKey = true,
            };

            var dialog = await DialogService.ShowAsync<SelectionPickerDialog>(
                "Level Up — Choose a Class", parameters, dialogOptions);
            var result = await dialog.Result;
            if (result is not { Canceled: false, Data: string pickedId })
                return; // cancelled

            chosen = classes.FirstOrDefault(c => c.Id == pickedId);
            if (chosen == null) return;
        }

        bool leveledMulticlass = chosen is { IsMain: false };
        int hpBefore = _snap?.MaxHp ?? 0;

        _saving = true;
        _saveError = null;
        StateHasChanged();

        string? error;
        int hpGained = 0;
        bool isAverage = false;
        if (chosen is null || chosen.IsMain)
            (error, hpGained, isAverage) = await BuildService.LevelUpMainAsync(tab);
        else
            error = await BuildService.AddMulticlassLevelAsync(tab, chosen.Id);

        _saving = false;
        if (error == null)
        {
            tab.IsNew = false;
            Tabs.MarkClean(tab);
            await LoadFromActiveTabAsync();

            int newLevel = _snap?.Level ?? 0;
            // HP gained: from the service for the main class (carries avg/rolled), or the snapshot
            // diff for a multiclass.
            int hp = leveledMulticlass ? (_snap?.MaxHp ?? 0) - hpBefore : hpGained;
            string hpNote = hp <= 0
                ? ""
                : leveledMulticlass ? $" · +{hp} HP" : $" · +{hp} HP ({(isAverage ? "avg" : "rolled")})";

            // For a multiclassing character, name the class that was leveled (main or multiclass);
            // for a single-class character the class name is redundant.
            string message = classes.Count > 1 && chosen != null
                ? $"Leveled {chosen.Name} · character level {newLevel}{hpNote}"
                : $"Level {newLevel}{hpNote}";

            Snackbar.Add(message, Severity.Success, cfg => cfg.VisibleStateDuration = 5000);
            StateHasChanged();
            return;
        }

        _saveError = error;
        await LoadFromActiveTabAsync();
        StateHasChanged();
    }

