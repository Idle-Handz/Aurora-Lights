    // ── Ability scores: method switching ─────────────────────────────────────────

    private void SetAbilityMethod(AbilityGenMethod method)
    {
        _abilityMethod = method;
        if (_abilities == null) return;
        if (method == AbilityGenMethod.PointBuy)
        {
            foreach (var row in _abilityRows)
                row.Item.BaseScore = Math.Clamp(row.Item.BaseScore, 8, 15);
            _abilities.DisablePointsCalculation = false;
            _abilities.CalculateAvailablePoints();
        }
        else
        {
            _abilities.DisablePointsCalculation = true;
        }
    }

    // ── Ability scores: manual ────────────────────────────────────────────────────

    private async Task OnManualBaseChanged(AbilityItem item, int desiredBase)
    {
        item.BaseScore = Math.Clamp(desiredBase, 1, 30);
        await ApplyAbilityChangesAsync();
    }

    // ── Ability scores: point buy ─────────────────────────────────────────────────

    private bool CanIncrement(AbilityItem item)
    {
        if (item.BaseScore >= 15) return false;
        int cost = item.BaseScore >= 13 ? 2 : 1;
        return (_abilities?.AvailablePoints ?? 0) >= cost;
    }

    private bool CanDecrement(AbilityItem item) => item.BaseScore > 8;

    private async Task IncrementScore(AbilityItem item)
    {
        if (!CanIncrement(item)) return;
        item.BaseScore++;
        _abilities?.CalculateAvailablePoints();
        await ApplyAbilityChangesAsync();
    }

    private async Task DecrementScore(AbilityItem item)
    {
        if (!CanDecrement(item)) return;
        item.BaseScore--;
        _abilities?.CalculateAvailablePoints();
        await ApplyAbilityChangesAsync();
    }

    // ── Ability scores: dice rolling ──────────────────────────────────────────────

    private int RollStat()
    {
        if (_abilityMethod == AbilityGenMethod.Roll3d6)
            return _rng.Next(1, 7) + _rng.Next(1, 7) + _rng.Next(1, 7);
        int a = _rng.Next(1, 7), b = _rng.Next(1, 7), c = _rng.Next(1, 7), d = _rng.Next(1, 7);
        return a + b + c + d - Math.Min(Math.Min(a, b), Math.Min(c, d));
    }

    private async Task RollStatAsync(AbilityItem item)
    {
        item.BaseScore = RollStat();
        await ApplyAbilityChangesAsync();
    }

    private async Task RollAllAsync()
    {
        foreach (var row in _abilityRows)
            row.Item.BaseScore = RollStat();
        await ApplyAbilityChangesAsync();
    }

    // ── Ability scores: standard array ────────────────────────────────────────────

    private IEnumerable<int> GetAvailableArrayValues(string abbrev)
    {
        var usedElsewhere = _abilityRows
            .Where(r => r.Abbrev != abbrev && _arrayAssignments.TryGetValue(r.Abbrev, out var v) && v != 0)
            .Select(r => _arrayAssignments[r.Abbrev])
            .ToHashSet();
        return _standardArray.Where(v => !usedElsewhere.Contains(v));
    }

    private async Task AssignArrayValue(AbilityItem item, string abbrev, int value)
    {
        _arrayAssignments[abbrev] = value;
        if (value == 0) return;
        item.BaseScore = value;
        await ApplyAbilityChangesAsync();
    }

    // ── Ability scores: save ──────────────────────────────────────────────────────

    private async Task ApplyAbilityChangesAsync()
    {
        var tab       = Tabs.ActiveTab;
        var character = CharacterManager.Current?.Character;
        if (tab == null || character == null)
        {
            WarnUnavailable("Ability score changes could not be applied because the character is no longer active.");
            return;
        }

        _abilities?.CalculateAvailablePoints();

        if (Prefs.AutoSaveBuildChanges)
        {
            _saving = true;
            StateHasChanged();
            var error = await BuildService.SaveTabAsync(tab);
            _saving = false;
            if (error == null)
            {
                tab.Snapshot = CharacterSnapshot.From(character);
                _snap = tab.Snapshot;
                Tabs.MarkClean(tab);
            }
            else
            {
                _saveError = error;
            }
        }
        else
        {
            tab.Snapshot = CharacterSnapshot.From(character);
            _snap = tab.Snapshot;
            Tabs.MarkDirty(tab);
        }
        StateHasChanged();
    }

    private void WarnUnavailable(string message) =>
        Snackbar.Add(message, Severity.Warning, cfg => cfg.VisibleStateDuration = 2500);
}
