@page "/build"
@implements IDisposable
@inject CharacterTabService Tabs
@inject IDialogService DialogService
@inject CharacterService Characters
@inject ISnackbar Snackbar
@inject UserPreferencesService Prefs
@inject NavigationManager Nav
@using Builder.Presentation
@using Builder.Presentation.Models
@using Builder.Presentation.Models.Collections

@if (Tabs.ActiveTab?.IsLoading == true)
{
    bool _isApplying = Characters.LoadingStatus?.Contains("applying", StringComparison.OrdinalIgnoreCase) == true;
    <div class="char-loading-state">
        <div class="char-loading-name">@(Tabs.ActiveTab.File.DisplayName ?? "Loading…")</div>
        <MudProgressLinear Value="@Characters.LoadingPercent" Color="Color.Primary" Class="char-loading-bar" />
        <div class="char-loading-status">
            @if (_isApplying)
            {
                @CurrentSubStep
            }
            else
            {
                @(string.IsNullOrEmpty(Characters.LoadingStatus) ? "Starting…" : Characters.LoadingStatus)
            }
        </div>
    </div>
    return;
}

@if (_snap is null)
{
    <div style="margin-top: 24px;">
        <MudText Color="Color.Secondary">No character loaded. Open a character from the <MudLink Href="/">Characters</MudLink> page.</MudText>
    </div>
    return;
}

@* ── Save / error bars ── *@
@if (!Prefs.AutoSaveBuildChanges)
{
    <div class="page-save-bar">
        <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Auto-save off</MudText>
        <MudButton StartIcon="@Icons.Material.Filled.Save"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   Size="Size.Small"
                   Disabled="@(_saving || !(Tabs.ActiveTab?.IsDirty == true))"
                   OnClick="ManualSaveAsync">
            Save
        </MudButton>
    </div>
}
@if (_saving)
{
    <div class="build-saving-bar">
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Style="height: 2px;" />
    </div>
}
@if (_saveError != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-3" ShowCloseIcon="true"
              CloseIconClicked="() => _saveError = null">
        <div><b>Failed to save</b></div>
        <div style="font-size:0.8em; word-break:break-all; white-space:pre-wrap;">@_saveError</div>
    </MudAlert>
}
@if (_invalidated.Count > 0)
{
    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3" ShowCloseIcon="true"
              CloseIconClicked="() => _invalidated.Clear()">
        The following selections were removed because they are no longer valid:
        <b>@string.Join(", ", _invalidated)</b>
    </MudAlert>
}

@* ── Guided creation banner ── *@
@if (_nextStep != null)
{
    <div class="build-guide-banner">
        <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="color: var(--mud-palette-warning); font-size: 18px;" />
            <span><b>Next step:</b> @_nextStep.StepLabel</span>
            <MudButton Size="Size.Small" Variant="Variant.Text"
                       Style="color: var(--mud-palette-warning); padding: 0 6px; min-width: 0;"
                       OnClick="NavigateToNextStep">
                → @_nextStep.TargetLabel
            </MudButton>
        </div>
        <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary); margin-top: 2px;">
            @GuidanceDescription(_nextStep)
        </MudText>
    </div>
}
else if (_workflowSuggestion != null)
{
    <div class="build-guide-banner">
        <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
            <MudIcon Icon="@Icons.Material.Filled.Explore" Style="color: var(--mud-palette-primary); font-size: 18px;" />
            <span><b>Recommended next:</b> @_workflowSuggestion.Value.StepLabel</span>
            <MudButton Size="Size.Small" Variant="Variant.Text"
                       Style="color: var(--mud-palette-primary); padding: 0 6px; min-width: 0;"
                       OnClick="NavigateSuggestedStep">
                → @_workflowSuggestion.Value.TargetLabel
            </MudButton>
        </div>
        <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary); margin-top: 2px;">
            @WorkflowSuggestionDescription(_workflowSuggestion.Value)
        </MudText>
    </div>
}

@* ── Level controls (outside tabs) ── *@
<div class="build-level-strip">
    <div class="build-level-actions">
        <MudButton StartIcon="@Icons.Material.Filled.Add"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Small"
                   Disabled="@(!BuildService.CanLevelUp || _saving)"
                   OnClick="LevelUpAsync">
            Level Up
        </MudButton>

        <MudButton StartIcon="@Icons.Material.Filled.Remove"
                   Variant="Variant.Outlined"
                   Color="Color.Default"
                   Size="Size.Small"
                   Disabled="@(!BuildService.CanLevelDown || _saving)"
                   OnClick="LevelDownAsync">
            Level Down
        </MudButton>

        @if (BuildService.HasMainClass && BuildService.CanLevelUp)
        {
            <MudButton StartIcon="@Icons.Material.Filled.MergeType"
                       Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Size="Size.Small"
                       Disabled="@_saving"
                       OnClick="OpenMulticlassDialog">
                Add Multiclass
            </MudButton>
        }

        <div class="build-hp-toggle" title="How HP is assigned on each level-up">
            <span class="build-hp-label">HP:</span>
            <button class="build-hp-btn @(BuildService.IsUsingAverageHp ? "active" : "")"
                    disabled="@_saving"
                    @onclick="() => SetHpMethodAsync(HpMethod.Average)">Avg</button>
            <button class="build-hp-btn @(!BuildService.IsUsingAverageHp ? "active" : "")"
                    disabled="@_saving"
                    @onclick="() => SetHpMethodAsync(HpMethod.Rolled)">Roll</button>
        </div>

        <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-disabled);">
            Level @(_snap.Level)
            @if (!BuildService.CanLevelUp)   { <span> · Max level</span>   }
            @if (!BuildService.CanLevelDown) { <span> · Level 1 min</span> }
        </MudText>

    </div>
</div>

@* ── Build tabs ── *@
<MudTabs @ref="_tabs"
         @bind-ActivePanelIndex="_activePanelIndex"
         Elevation="0"
         Rounded="false"
         ApplyEffectsToContainer="false"
         PanelClass="build-tab-panel"
         Class="build-tabs mt-2">

    @foreach (var tab in _buildTabs)
    {
        <MudTabPanel Text="@GetBuildTabLabel(tab)">
            @if (tab.RuleGroups.Count == 0)
            {
                <div style="margin-top: 16px; padding: 12px; background: var(--mud-palette-background-grey); border-radius: 6px; border: 1px solid var(--mud-palette-lines-default);">
                    <MudText Color="Color.Secondary" Typo="Typo.body2">
                        No selections are available for <b>@tab.Label</b> at your current level.
                    </MudText>
                    <MudText Color="Color.Secondary" Typo="Typo.caption" Style="margin-top: 4px; display: block;">
                        Complete selections on other tabs or level up to unlock choices here.
                    </MudText>
                </div>
            }
            else
            {
                @foreach (var group in tab.RuleGroups)
                {
                    <div class="build-section">
                        @if (!string.IsNullOrEmpty(group.Label))
                        {
                            <div class="section-label">@group.Label</div>
                        }
                        <div class="build-rule-list">
                            @foreach (var entry in group.Rules)
                            {
                                bool _isOptional = IsOptionalEntry(entry);
                                <div class="@GetRuleRowClass(entry)" @ondblclick="() => OpenPickerAsync(entry)">
                                    <div class="build-rule-label">
                                        @entry.Label
                                        @if (_isOptional)
                                        {
                                            <span class="build-rule-optional-badge">optional</span>
                                        }
                                    </div>
                                    <div class="build-rule-value @(entry.CurrentName == null ? "build-rule-empty" : "")">
                                        @(entry.CurrentName ?? (_isOptional ? "Optional..." : "Choose..."))
                                    </div>
                                    <button class="build-rule-btn" @onclick="() => OpenPickerAsync(entry)"
                                            @ondblclick:stopPropagation="true">Change</button>
                                </div>
                            }
                        </div>
                    </div>
                }
            }

            @* Class tab extras: class features *@
            @if (tab.Label == "Class" && _progressions is { Count: > 0 })
            {
                foreach (var cls in _progressions)
                {
                    <div class="build-section">
                        <div class="build-class-header">
                            <div class="build-primary-text">@cls.ClassName</div>
                            <div class="build-badges">
                                <span class="build-badge">Level @cls.Level</span>
                                @if (!string.IsNullOrEmpty(cls.HitDie))
                                {
                                    <span class="build-badge">@cls.HitDie</span>
                                }
                                @if (!cls.IsMainClass)
                                {
                                    <span class="build-badge build-badge-multi">Multiclass</span>
                                }
                            </div>
                        </div>
                        @if (cls.Features.Count > 0)
                        {
                            <div class="section-label" style="margin-top: 14px;">Features</div>
                            <div class="build-feature-list">
                                @foreach (var f in cls.Features)
                                {
                                    @if (!string.IsNullOrWhiteSpace(f.Description))
                                    {
                                        <details class="build-feature-item build-feature-expandable">
                                            <summary>@f.Name</summary>
                                            <div class="build-feature-desc">@f.Description</div>
                                        </details>
                                    }
                                    else
                                    {
                                        <div class="build-feature-item">@f.Name</div>
                                    }
                                }
                            </div>
                        }
                    </div>
                }
            }

            @* Background tab extras: narrative fields *@
            @if (tab.Label == "Background" && _snap != null)
            {
                <div class="build-section">
                    <div class="section-label">Story &amp; Personality</div>
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary); margin-bottom: 10px; display: block;">
                        Personality trait, ideal, bond, and flaw are selected above when your background offers them.
                    </MudText>
                    <NarrativeField Label="Backstory" Value="@_snap.Backstory" Lines="4"
                                    ValueChanged="v => OnNarrativeChanged(v, f => _snap!.Backstory = f)" />
                    <NarrativeField Label="Deity / Faith" Value="@_snap.Deity"
                                    ValueChanged="v => OnNarrativeChanged(v, f => _snap!.Deity = f)" />
                    <NarrativeField Label="Alignment" Value="@_snap.Alignment"
                                    ValueChanged="v => OnNarrativeChanged(v, f => _snap!.Alignment = f)" />
                </div>

                <div class="build-section">
                    <div class="section-label">Appearance</div>
                    <div class="bg-narrative-grid">
                        <NarrativeField Label="Age"    Value="@_snap.Age"    ValueChanged="v => OnNarrativeChanged(v, f => _snap!.Age    = f)" />
                        <NarrativeField Label="Gender" Value="@_snap.Gender" ValueChanged="v => OnNarrativeChanged(v, f => _snap!.Gender = f)" />
                        <NarrativeField Label="Height" Value="@_snap.Height" ValueChanged="v => OnNarrativeChanged(v, f => _snap!.Height = f)" />
                        <NarrativeField Label="Weight" Value="@_snap.Weight" ValueChanged="v => OnNarrativeChanged(v, f => _snap!.Weight = f)" />
                        <NarrativeField Label="Eyes"   Value="@_snap.Eyes"   ValueChanged="v => OnNarrativeChanged(v, f => _snap!.Eyes   = f)" />
                        <NarrativeField Label="Hair"   Value="@_snap.Hair"   ValueChanged="v => OnNarrativeChanged(v, f => _snap!.Hair   = f)" />
                        <NarrativeField Label="Skin"   Value="@_snap.Skin"   ValueChanged="v => OnNarrativeChanged(v, f => _snap!.Skin   = f)" />
                    </div>
                </div>
            }
        </MudTabPanel>
    }

    @* Ability Scores tab — always last *@
    <MudTabPanel Text="@AbilityScoresTabLabel">
        @if (_abilities != null)
        {
            bool _hasAsi = _abilityRows.Any(r => r.Item.AdditionalScore != 0);

            <div class="build-section">
                @* Method selector *@
                <div class="ability-method-tabs">
                    @foreach (var m in _allMethods)
                    {
                        <button class="ability-method-btn @(_abilityMethod == m.Method ? "active" : "")"
                                @onclick="() => SetAbilityMethod(m.Method)">
                            @m.Label
                        </button>
                    }
                </div>

                @if (_abilityMethod == AbilityGenMethod.PointBuy)
                {
                    int remaining = _abilities.AvailablePoints;
                    <div class="ability-points-bar @(remaining < 0 ? "ability-points-over" : "")" style="margin-top: 8px;">
                        <span>Points spent: <b>@(27 - remaining) / 27</b></span>
                        <span style="margin-left: 16px;">Remaining: <b>@remaining</b></span>
                    </div>
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-disabled); margin-top: 4px;">
                        Scores range from 8 (free) to 15 (9 pts). Cost increases at 14 and 15.
                    </MudText>
                }
                else if (_abilityMethod is AbilityGenMethod.Roll3d6 or AbilityGenMethod.Roll4d6)
                {
                    <div style="display: flex; gap: 8px; margin-top: 8px; flex-wrap: wrap; align-items: center;">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Casino"
                                   OnClick="RollAllAsync">Roll All</MudButton>
                        <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-disabled);">
                            Use the 🎲 button on each stat to reroll individually.
                        </MudText>
                    </div>
                }
                else if (_abilityMethod == AbilityGenMethod.StandardArray)
                {
                    <div style="margin-top: 6px; display: flex; gap: 6px; flex-wrap: wrap; align-items: center;">
                        <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Array:</MudText>
                        @foreach (var v in _standardArray)
                        {
                            bool used = _arrayAssignments.Values.Any(a => a == v);
                            <span class="ability-array-chip @(used ? "used" : "")">@v</span>
                        }
                    </div>
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-disabled); margin-top: 2px;">
                        Assign each value to exactly one ability score.
                    </MudText>
                }

                @* ── Ability score table ── *@
                <div class="ability-stats-table-wrapper">
                <div class="ability-stats-table">

                    @* Row 1: abbreviation + name *@
                    <div class="ability-stats-row ability-row-header">
                        @foreach (var row in _abilityRows)
                        {
                            <div class="ability-stats-cell">
                                <div class="ability-abbrev-lbl">@row.Abbrev</div>
                                <div class="ability-name-lbl">@row.Name</div>
                            </div>
                        }
                    </div>

                    @* Row 2: ASI bonuses — only shown when at least one ability has a bonus *@
                    @if (_hasAsi)
                    {
                        <div class="ability-stats-row ability-row-asi">
                            @foreach (var row in _abilityRows)
                            {
                                <div class="ability-stats-cell">
                                    @if (row.Item.AdditionalScore != 0)
                                    {
                                        <div class="ability-asi-badge" title="@row.Item.AdditionalSummery">
                                            <span class="ability-asi-val">@(row.Item.AdditionalScore > 0 ? "+" : "")@row.Item.AdditionalScore</span>
                                            <span class="ability-asi-src">@row.Item.AdditionalSummery</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @* Row 3: interactive controls.
                       Roll/PointBuy show the BASE score (what you're setting); Manual shows
                       the TOTAL (most natural for typing). When a racial/feat ASI applies,
                       a "→ N total" annotation makes the relationship explicit. *@
                    <div class="ability-stats-row ability-row-total">
                        @foreach (var row in _abilityRows)
                        {
                            <div class="ability-stats-cell">
                                @if (_abilityMethod == AbilityGenMethod.Manual)
                                {
                                    <input class="ability-manual-input" type="number" min="1" max="30"
                                           value="@row.Item.BaseScore"
                                           @onchange="async e => await OnManualBaseChanged(row.Item, int.TryParse(e.Value?.ToString(), out var v) ? v : row.Item.BaseScore)" />
                                    @if (row.Item.AdditionalScore != 0)
                                    {
                                        <div class="ability-sublabel">→ @row.Item.FinalScore total</div>
                                    }
                                }
                                else if (_abilityMethod == AbilityGenMethod.PointBuy)
                                {
                                    <div class="ability-score-adj">
                                        <button class="ability-adj-btn-sm" disabled="@(!CanDecrement(row.Item))"
                                                @onclick="() => DecrementScore(row.Item)">−</button>
                                        <span class="ability-score-num">@row.Item.BaseScore</span>
                                        <button class="ability-adj-btn-sm" disabled="@(!CanIncrement(row.Item))"
                                                @onclick="() => IncrementScore(row.Item)">+</button>
                                    </div>
                                    @if (row.Item.AdditionalScore != 0)
                                    {
                                        <div class="ability-sublabel">→ @row.Item.FinalScore total</div>
                                    }
                                }
                                else if (_abilityMethod is AbilityGenMethod.Roll3d6 or AbilityGenMethod.Roll4d6)
                                {
                                    <div class="ability-score-adj">
                                        <span class="ability-score-num">@row.Item.BaseScore</span>
                                        <button class="ability-roll-btn-sm" @onclick="() => RollStatAsync(row.Item)" title="Reroll">🎲</button>
                                    </div>
                                    @if (row.Item.AdditionalScore != 0)
                                    {
                                        <div class="ability-sublabel">→ @row.Item.FinalScore total</div>
                                    }
                                }
                                else if (_abilityMethod == AbilityGenMethod.StandardArray)
                                {
                                    <select class="ability-array-select-sm"
                                            value="@_arrayAssignments.GetValueOrDefault(row.Abbrev, 0)"
                                            @onchange="async e => await AssignArrayValue(row.Item, row.Abbrev, int.TryParse(e.Value?.ToString(), out var sv) ? sv : 0)">
                                        @if (_arrayAssignments.GetValueOrDefault(row.Abbrev, 0) == 0)
                                        {
                                            <option value="0">–</option>
                                        }
                                        @foreach (var av in GetAvailableArrayValues(row.Abbrev))
                                        {
                                            <option value="@av" selected="@(av == _arrayAssignments.GetValueOrDefault(row.Abbrev, 0))">@av</option>
                                        }
                                    </select>
                                    @if (_arrayAssignments.GetValueOrDefault(row.Abbrev, 0) != 0 && row.Item.AdditionalScore != 0)
                                    {
                                        <div class="ability-sublabel">→ @row.Item.FinalScore total</div>
                                    }
                                }
                            </div>
                        }
                    </div>

                    @* Row 4: modifier *@
                    <div class="ability-stats-row ability-row-mod">
                        @foreach (var row in _abilityRows)
                        {
                            <div class="ability-stats-cell">
                                <div class="ability-mod-badge">@row.Item.ModifierString</div>
                                <div class="ability-sublabel">modifier</div>
                            </div>
                        }
                    </div>

                </div>@* end ability-stats-table *@
                </div>@* end ability-stats-table-wrapper *@
            </div>

            @* ASI / Feat selections — below the score table *@
            @if (_asiEntries.Count > 0)
            {
                <div class="build-section">
                    <div class="section-label">Ability Score Improvements</div>
                    <div class="build-rule-list">
                        @foreach (var entry in _asiEntries)
                        {
                            bool _isOptional = entry.Rule?.Attributes?.Optional == true;
                            <div class="@GetRuleRowClass(entry)" @ondblclick="() => OpenPickerAsync(entry)">
                                <div class="build-rule-label">
                                    @entry.Label
                                    @if (_isOptional)
                                    {
                                        <span class="build-rule-optional-badge">optional</span>
                                    }
                                </div>
                                <div class="build-rule-value @(entry.CurrentName == null ? "build-rule-empty" : "")">
                                    @(entry.CurrentName ?? (_isOptional ? "—" : "Choose..."))
                                </div>
                                <button class="build-rule-btn" @onclick="() => OpenPickerAsync(entry)"
                                        @ondblclick:stopPropagation="true">Change</button>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="build-section">
                    <div class="section-label">Ability Score Improvements</div>
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                        Origin ability-score choices appear here after you choose a race or a 2024 background that provides them.
                    </MudText>
                </div>
            }

        }
    </MudTabPanel>

    @* ── Extras tab — custom feats/spells/features added via "Add Custom Feature" ── *@
    <MudTabPanel Text="Extras">
        <div style="padding: 12px 4px;">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; gap:12px;">
                <MudText Typo="Typo.subtitle2" Style="font-weight:600;">Custom additions</MudText>
                <MudButton StartIcon="@Icons.Material.Filled.Extension"
                           Variant="Variant.Outlined" Color="Color.Tertiary" Size="Size.Small"
                           Disabled="@_saving" OnClick="OpenCustomFeatureDialog">
                    Add Custom Feature
                </MudButton>
            </div>

            @if (_customFeatures.Count == 0)
            {
                <MudText Color="Color.Secondary" Style="font-size:13px;">
                    Nothing added yet. Use <b>Add Custom Feature</b> to add feats, spells, or other
                    options that aren't granted by your class, race, or background. Spell choices from
                    added feats appear on the <b>Magic</b> page.
                </MudText>
            }
            else
            {
                <div class="build-rule-group">
                    @foreach (var cf in _customFeatures)
                    {
                        <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; padding:6px 8px; border-bottom:1px solid var(--mud-palette-divider);">
                            <div>
                                <div style="font-size:13px; font-weight:500;">@cf.Name</div>
                                <div style="font-size:10px; color: var(--mud-palette-text-disabled);">@cf.Type</div>
                            </div>
                            <MudButton StartIcon="@Icons.Material.Filled.Delete"
                                       Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                       Disabled="@_saving" OnClick="() => RemoveCustomFeatureAsync(cf.Id)">
                                Remove
                            </MudButton>
                        </div>
                    }
                </div>
            }
        </div>
    </MudTabPanel>
</MudTabs>

@code {
    // ── Loading sub-step cycling ─────────────────────────────────────────────────

    private static readonly string[] _applyingSubSteps =
    [
        "Parsing class features",
        "Applying racial traits",
        "Calculating ability scores",
        "Resolving feat prerequisites",
        "Processing equipment",
        "Loading spellcasting",
        "Computing proficiencies",
        "Building skill list",
        "Applying source restrictions",
        "Finalizing character data",
        "Reading level progressions",
        "Applying background benefits",
        "Resolving language proficiencies",
        "Building attack list",
        "Computing saving throws",
        "Applying armor class calculations",
        "Loading known spells",
        "Resolving multiclass rules",
        "Computing speed and senses",
        "Applying condition immunities",
    ];

    private int _subStepIndex;
    private string[] _shuffledSteps = [];
    private CancellationTokenSource? _subStepCts;

    private string CurrentSubStep => _shuffledSteps.Length > 0
        ? _shuffledSteps[_subStepIndex]
        : _applyingSubSteps[0];

    private void StartSubStepCycling()
    {
        _shuffledSteps = _applyingSubSteps.OrderBy(_ => Random.Shared.Next()).ToArray();
        _subStepIndex = 0;
        _subStepCts = new CancellationTokenSource();
        var token = _subStepCts.Token;
        _ = Task.Run(async () =>
        {
            while (!token.IsCancellationRequested)
            {
                try { await Task.Delay(1500, token); }
                catch (OperationCanceledException) { break; }
                if (token.IsCancellationRequested || _disposed) break;
                _subStepIndex = (_subStepIndex + 1) % _shuffledSteps.Length;
                _ = InvokeAsync(() => { if (!_disposed) StateHasChanged(); });
            }
        }, CancellationToken.None);
    }

    private void StopSubStepCycling()
    {
        _subStepCts?.Cancel();
        _subStepCts?.Dispose();
        _subStepCts = null;
    }

    // ── Shared state ─────────────────────────────────────────────────────────────
    private CharacterSnapshot?                               _snap;
    private IReadOnlyList<ClassProgressionSnapshot>?         _progressions;
    private IReadOnlyList<BuildTabGroup>                     _buildTabs   = [];
    private List<string>                                     _invalidated = [];
    private string?                                          _saveError;
    private bool                                             _saving;
    private BuildGuidanceTarget?                             _nextStep;
    private (string StepLabel, string TargetLabel, string? TabLabel, string? Route)? _workflowSuggestion;
    private string?                                          _highlightedEntryKey;

    // ── Tab navigation ────────────────────────────────────────────────────────────
    private MudTabs?  _tabs;
    private int       _activePanelIndex;

    // ── Ability score state ──────────────────────────────────────────────────────
    private sealed record AbilityRow(string Name, string Abbrev, AbilityItem Item);
    private enum AbilityGenMethod { Manual, Roll4d6, Roll3d6, StandardArray, PointBuy }
    private sealed record MethodOption(AbilityGenMethod Method, string Label);

    private static readonly MethodOption[] _allMethods =
    [
        new(AbilityGenMethod.Manual,        "Manual"),
        new(AbilityGenMethod.Roll4d6,       "Roll 4d6"),
        new(AbilityGenMethod.Roll3d6,       "Roll 3d6"),
        new(AbilityGenMethod.StandardArray, "Standard Array"),
        new(AbilityGenMethod.PointBuy,      "Point Buy"),
    ];

    private static readonly int[]    _standardArray = [15, 14, 13, 12, 10, 8];
    private static readonly Random   _rng           = Random.Shared;

    private AbilitiesCollection?             _abilities;
    private AbilityRow[]                     _abilityRows      = [];
    private AbilityGenMethod                 _abilityMethod    = AbilityGenMethod.Manual;
    private readonly Dictionary<string, int> _arrayAssignments = new();
    private IReadOnlyList<SelectionRuleEntry> _asiEntries      = [];
    private IReadOnlyList<(string Id, string Name, string Type)> _customFeatures = [];

    private bool PreferClassFirst => Tabs.ActiveTab?.IsNew != true;

    // ── Lifecycle ────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _wasLoading = Tabs.ActiveTab?.IsLoading == true;
        Tabs.TabsChanged += OnTabsChanged;
        Characters.LoadingProgressChanged += OnLoadingProgress;
        await LoadFromActiveTabAsync();
    }

    private void OnLoadingProgress()
    {
        if (_disposed) return;
        bool isApplying = Characters.LoadingStatus?.Contains("applying", StringComparison.OrdinalIgnoreCase) == true;
        if (isApplying && _subStepCts == null)
            StartSubStepCycling();
        else if (!isApplying)
            StopSubStepCycling();
        _ = InvokeAsync(() => { if (!_disposed) StateHasChanged(); });
    }

    private async Task LoadFromActiveTabAsync()
    {
        var tab       = Tabs.ActiveTab;
        _snap         = tab?.Snapshot;
        _progressions = tab?.ProgressionSnapshots;

        if (tab != null && _snap != null)
        {
            using (await CharacterContext.EnterAsync(tab))
            {
                (_buildTabs, _asiEntries, _nextStep) = BuildService.GetBuildData(PreferClassFirst);
                _highlightedEntryKey = _nextStep?.EntryKey;
                LoadAbilityRows();
                _workflowSuggestion = ComputeWorkflowSuggestion();
            }
            _customFeatures = BuildService.GetCustomFeatures(tab);
        }
        else
        {
            _buildTabs  = [];
            _asiEntries = [];
            _nextStep   = null;
            _highlightedEntryKey = null;
            _customFeatures = [];
            LoadAbilityRows();
            _workflowSuggestion = null;
        }
    }

    private void LoadAbilityRows()
    {
        var character = CharacterManager.Current?.Character;
        if (character == null) { _abilities = null; _abilityRows = []; return; }

        _abilities = character.Abilities;

        _abilityRows =
        [
            new("Strength",     "STR", _abilities.Strength),
            new("Dexterity",    "DEX", _abilities.Dexterity),
            new("Constitution", "CON", _abilities.Constitution),
            new("Intelligence", "INT", _abilities.Intelligence),
            new("Wisdom",       "WIS", _abilities.Wisdom),
            new("Charisma",     "CHA", _abilities.Charisma),
        ];

        var currentScores = _abilityRows.Select(r => r.Item.BaseScore).OrderBy(x => x).ToList();
        bool isValidArrayAssignment = currentScores.SequenceEqual(_standardArray.OrderBy(x => x));
        foreach (var row in _abilityRows)
        {
            if (!_arrayAssignments.ContainsKey(row.Abbrev))
                _arrayAssignments[row.Abbrev] = isValidArrayAssignment ? row.Item.BaseScore : 0;
        }
    }

    private bool _disposed;
    private bool _wasLoading;

    private void OnTabsChanged()
    {
        if (_disposed) return;
        _ = InvokeAsync(async () =>
        {
            if (_disposed) return;
            bool isLoading = Tabs.ActiveTab?.IsLoading == true;
            if (_wasLoading && !isLoading && Tabs.ActiveTab?.Snapshot != null)
                Nav.NavigateTo("/character");
            _wasLoading = isLoading;
            await LoadFromActiveTabAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        _disposed = true;
        StopSubStepCycling();
        Tabs.TabsChanged -= OnTabsChanged;
        Characters.LoadingProgressChanged -= OnLoadingProgress;
        if (_abilities != null)
            _abilities.DisablePointsCalculation = true;
    }

    // ── Tab navigation ────────────────────────────────────────────────────────────

    private void NavigateToNextStep()
    {
        if (_nextStep == null) return;
        var idx = GetPanelIndexForLabel(_nextStep.TabLabel);
        if (idx >= 0)
            _activePanelIndex = idx;
        _highlightedEntryKey = _nextStep.EntryKey;
    }

    private void NavigateSuggestedStep()
    {
        if (_workflowSuggestion == null) return;

        if (!string.IsNullOrWhiteSpace(_workflowSuggestion.Value.Route))
        {
            Nav.NavigateTo(_workflowSuggestion.Value.Route!);
            return;
        }

        if (!string.IsNullOrWhiteSpace(_workflowSuggestion.Value.TabLabel))
        {
            var idx = GetPanelIndexForLabel(_workflowSuggestion.Value.TabLabel!);
            if (idx >= 0)
                _activePanelIndex = idx;
        }
    }

    private int GetPanelIndexForLabel(string label)
    {
        if (label == "Ability Scores")
            return _buildTabs.Count;

        return _buildTabs.ToList().FindIndex(t => t.Label == label);
    }

    private string GetBuildTabLabel(BuildTabGroup tab) =>
        tab.UnresolvedCount > 0 ? $"{tab.Label} ({tab.UnresolvedCount})" : tab.Label;

    private string AbilityScoresTabLabel
    {
        get
        {
            int unresolved = _asiEntries.Count(entry => entry.CurrentName == null && !entry.IsOptional);
            return unresolved > 0 ? $"Ability Scores ({unresolved})" : "Ability Scores";
        }
    }

    private static bool IsOptionalEntry(SelectionRuleEntry entry) => entry.IsOptional;

    private string GetRuleRowClass(SelectionRuleEntry entry)
    {
        bool unresolved  = entry.CurrentName == null;
        bool optional    = IsOptionalEntry(entry);
        bool highlighted = unresolved && entry.EntryKey == _highlightedEntryKey;
        return highlighted        ? "build-rule-row build-rule-row-highlighted" :
               unresolved && !optional ? "build-rule-row build-rule-row-unresolved" :
               "build-rule-row";
    }

    private static string GuidanceDescription(BuildGuidanceTarget target) =>
        target.ActionKind == BuildGuidanceActionKind.AbilityScores
            ? "Set your starting ability scores before reviewing the rest of the build."
            : "This required choice is still empty. Jump to the highlighted row and choose an option.";

    private static string WorkflowSuggestionDescription((string StepLabel, string TargetLabel, string? TabLabel, string? Route) suggestion) =>
        suggestion.Route == "/equipment"
            ? "Your core build choices look complete. Review starting equipment next."
            : suggestion.StepLabel.Contains("appearance", StringComparison.OrdinalIgnoreCase)
                ? "These details help the character sheet feel complete, but they can wait."
                : "Narrative details can be filled in now or saved for later.";

    private (string StepLabel, string TargetLabel, string? TabLabel, string? Route)? ComputeWorkflowSuggestion()
    {
        if (_snap == null) return null;
        if (Tabs.ActiveTab?.IsNew != true) return null;

        if (NeedsCharacterBackgroundDetails())
            return ("Describe your character", "Background tab", "Background", null);

        if (NeedsCharacterAppearanceDetails())
            return ("Add appearance details", "Background tab", "Background", null);

        return ("Review your equipment", "Equipment page", null, "/equipment");
    }

    private bool NeedsCharacterBackgroundDetails()
    {
        if (_snap == null) return false;

        // Notes2/Allies/Organisation are populated from optional Bond/Ideal/Flaw selections;
        // exclude them so unselected optional flavor choices don't keep nagging the player.
        var fields = new[] { _snap.Backstory, _snap.Notes1, _snap.Alignment, _snap.Deity };
        return fields.Count(v => !string.IsNullOrWhiteSpace(v)) < 2;
    }

    private bool NeedsCharacterAppearanceDetails()
    {
        if (_snap == null) return false;

        var fields = new[]
        {
            _snap.Age, _snap.Height, _snap.Weight, _snap.Eyes, _snap.Hair, _snap.Skin, _snap.Gender
        };

        int filled = fields.Count(v => !string.IsNullOrWhiteSpace(v));
        return filled < 3;
    }

    // ── Manual save ──────────────────────────────────────────────────────────────

    private async Task ManualSaveAsync()
    {
        var tab = Tabs.ActiveTab;
        if (tab == null)
        {
            WarnUnavailable("There is no active character to save right now.");
            return;
        }
        _saving = true;
        StateHasChanged();
        var error = await BuildService.SaveTabAsync(tab);
        _saving = false;
        if (error == null)
        {
            Tabs.MarkClean(tab);
            Snackbar.Add("Saved.", Severity.Success, cfg => { cfg.VisibleStateDuration = 2000; });
        }
        else
        {
            _saveError = error;
        }
        StateHasChanged();
    }

    // ── Selection picker ─────────────────────────────────────────────────────────

    private async Task OpenPickerAsync(SelectionRuleEntry entry)
    {
        var tab  = Tabs.ActiveTab;
        var file = Characters.CurrentCharacterFile;
        if (tab == null || file == null)
        {
            WarnUnavailable("That choice is not available right now. Try again once the character finishes loading.");
            return;
        }

        _saving = true;
        StateHasChanged();
        var options = await Task.Run(() => BuildService.GetOptions(entry.Rule));
        _saving = false;
        StateHasChanged();

        var parameters = new DialogParameters
        {
            [nameof(SelectionPickerDialog.Entry)]   = entry,
            [nameof(SelectionPickerDialog.Options)] = options,
        };
        var dialogOptions = new DialogOptions
        {
            MaxWidth         = MaxWidth.Large,
            FullWidth        = true,
            CloseOnEscapeKey = true,
        };

        var dialog = await DialogService.ShowAsync<SelectionPickerDialog>(entry.Label, parameters, dialogOptions);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string selectedId })
        {
            _saving = true;
            _invalidated.Clear();
            _saveError = null;
            StateHasChanged();

            bool autoSave = Prefs.AutoSaveBuildChanges;
            var removed = await BuildService.ApplySelectionAndSaveAsync(
                entry.Rule, selectedId, entry.Number, tab, file, saveToFile: autoSave);

            _saving = false;
            _saveError = null;

            var errors = removed.Where(s => s.StartsWith("[Error:")).ToList();
            var normal = removed.Where(s => !s.StartsWith("[Error:")).ToList();

            if (errors.Count > 0)
                _saveError = string.Join("; ", errors.Select(e => e.TrimStart('[').TrimEnd(']').Replace("Error: ", "")));

            _invalidated.AddRange(normal);

            if (_saveError == null)
            {
                if (autoSave)
                {
                    Tabs.MarkClean(tab);
                    Snackbar.Add("Changes saved.", Severity.Success, cfg => { cfg.VisibleStateDuration = 2000; });
                }
                else
                {
                    Tabs.MarkDirty(tab);
                    Snackbar.Add("Changes applied. Save when ready.", Severity.Info, cfg => { cfg.VisibleStateDuration = 2500; });
                }
            }

            await LoadFromActiveTabAsync();
            StateHasChanged();
        }
    }

