@page "/"
@implements IDisposable
@inject CharacterService CharSvc
@inject CharacterTabService Tabs
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject UserPreferencesService Prefs
@inject PdfImportService PdfImport
@using Builder.Presentation
@using Aurora.PdfImport

@if (_loading)
{
    <div style="display: flex; align-items: center; gap: 12px; margin-top: 24px;">
        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        <MudText Color="Color.Secondary">Loading characters...</MudText>
    </div>
}

@if (_error is not null)
{
    <MudAlert Severity="@(_warning ? Severity.Warning : Severity.Error)" Class="mt-4">
        <pre style="white-space: pre-wrap; font-size: 11px; max-height: 300px; overflow-y: auto; margin: 0;">@_error</pre>
    </MudAlert>
    @if (_warning)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-2" OnClick="NavigateToCharacter">Open anyway</MudButton>
    }
}
else
{
    <CharacterLibraryShell>
        <BrowserContent>
            <CharacterBrowser Characters="@BrowserEntries"
                              Title="Characters"
                              DirectoryCaption="@DirectoryCaption"
                              EmptyMessage="@EmptyMessage"
                              EmptySubMessage="@EmptySubMessage"
                              BusyMessage="@BusyMessage"
                              ShowCreateButton="true"
                              CreateButtonText="New Character"
                              DisableCreateButton="@_preloading"
                              OnCreate="OnNewCharacter"
                              OnSelected="OnBrowserSelected"
                              OnDelete="OnDeleteCharacter">
                <AdditionalHeaderContent>
                    <button class="character-browser-create"
                            type="button"
                            style="background: transparent; border-color: var(--mud-palette-primary); color: var(--mud-palette-primary);"
                            @onclick="OnImportPdf"
                            disabled="@_preloading">
                        Import Character
                    </button>
                    <button class="character-browser-create"
                            type="button"
                            style="background: transparent; border-color: var(--mud-palette-primary); color: var(--mud-palette-primary);"
                            @onclick="OnImportFile"
                            disabled="@(_preloading || _importingFile)">
                        Open File
                    </button>
                </AdditionalHeaderContent>
            </CharacterBrowser>
        </BrowserContent>
    </CharacterLibraryShell>
}

@code {
    private bool _disposed;
    private List<Builder.Presentation.Models.CharacterFile> _characters = [];
    private List<CharacterBrowserEntry> _browserEntries = [];
    private CancellationTokenSource? _portraitCts;
    private bool _loading = true;
    private bool _preloading;
    private bool _importingFile;
    private string? _error;
    private bool _warning;

    private IReadOnlyList<CharacterBrowserEntry> BrowserEntries => _browserEntries;

    private string DirectoryCaption =>
        _characters.Count == 0
            ? CharSvc.CharactersDirectory
            : $"{_characters.Count} character{(_characters.Count == 1 ? string.Empty : "s")} - {CharSvc.CharactersDirectory}";

    private string EmptyMessage =>
        $"No characters found in {CharSvc.CharactersDirectory}.";

    private string EmptySubMessage =>
        "Tap \"New Character\" to get started, or import an existing .dnd5e file.";

    private string? BusyMessage => _preloading ? "Loading content data..." : null;

    public void Dispose()
    {
        _disposed = true;
        _portraitCts?.Cancel();
        _portraitCts?.Dispose();
    }

    protected override Task OnInitializedAsync()
    {
        try
        {
            _characters = CharSvc.LoadCharacterFiles().ToList();
            RebuildBrowserEntries();
        }
        catch (Exception ex)
        {
            DebugLogService.Instance.LogException(ex, "CharactersPage.OnInitializedAsync");
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }

        _ = RunPreloadAsync();
        return Task.CompletedTask;
    }

    private void RebuildBrowserEntries()
    {
        _portraitCts?.Cancel();
        _portraitCts?.Dispose();
        _portraitCts = new CancellationTokenSource();
        _browserEntries = _characters.Select(ToBrowserEntry).ToList();
        _ = LoadPortraitsAsync(_portraitCts.Token);
    }

    private async Task LoadPortraitsAsync(CancellationToken ct)
    {
        var snapshot = _characters.ToList();
        List<string?> portraits;
        try
        {
            portraits = await Task.Run(() => snapshot.Select(ToPortraitDataUrl).ToList(), ct);
        }
        catch (OperationCanceledException)
        {
            return;
        }
        if (ct.IsCancellationRequested || _disposed) return;

        bool anyUpdated = false;
        for (int i = 0; i < portraits.Count && i < _browserEntries.Count; i++)
        {
            if (portraits[i] != null)
            {
                _browserEntries[i] = _browserEntries[i] with { PortraitDataUrl = portraits[i] };
                anyUpdated = true;
            }
        }
        if (anyUpdated && !_disposed)
            await InvokeAsync(StateHasChanged);
    }

    private async Task RunPreloadAsync()
    {
        if (_disposed) return;
        _preloading = true;
        if (!_disposed) await InvokeAsync(() => { if (!_disposed) StateHasChanged(); });

        try
        {
            await CharSvc.PreloadAsync();

            if (!_disposed)
            {
                string? mruPath = Prefs.MruCharacterPath;
                if (!string.IsNullOrEmpty(mruPath))
                {
                    Builder.Presentation.Models.CharacterFile? mruFile = _characters.FirstOrDefault(file => file.FilePath == mruPath);
                    // Only preload if the character isn't already in memory — re-triggering
                    // a load races against the fast path's CharacterSnapshot.From call:
                    // the background file.Load() rebuilds CharacterManager.Current in-place
                    // and resets SpellcastingSectionContext (prepared spells), producing
                    // corrupted snapshots (wrong level, missing spells) on second open.
                    if (mruFile != null && Tabs.FindTab(mruFile) == null && !CharSvc.IsPreloaded(mruFile))
                    {
                        CharSvc.BeginPreload(mruFile);
                    }
                }
            }
        }
        finally
        {
            _preloading = false;
            if (!_disposed) await InvokeAsync(() => { if (!_disposed) StateHasChanged(); });
        }
    }

    private async Task OnCharacterSelected(Builder.Presentation.Models.CharacterFile characterFile)
    {
        CharacterTab? existing = Tabs.FindTab(characterFile);
        if (existing != null)
        {
            Tabs.ActivateTab(existing);
            Nav.NavigateTo("/character");
            return;
        }

        if (CharSvc.IsPreloaded(characterFile) && !CharSvc.IsCharacterLoading)
        {
            CharacterTab tab = Tabs.OpenTab(characterFile, CharSvc.CurrentCharacter!);
            tab.Snapshot = CharacterSnapshot.From(CharSvc.CurrentCharacter!);
            tab.ProgressionSnapshots = SnapshotProgressionManagers();
            tab.Session = characterFile.LoadSession();
            CharacterContext.ClaimAfterLoad(tab);
            Nav.NavigateTo("/character");
            return;
        }

        _error = null;
        _warning = false;
        CharacterTab loadingTab = Tabs.OpenLoadingTab(characterFile);
        Nav.NavigateTo("/build"); // stay on Build while loading spinner is shown

        try
        {
            (bool success, string message) = await CharSvc.LoadCharacterAsync(characterFile);

            if (success && CharSvc.CurrentCharacter != null)
            {
                loadingTab.Character = CharSvc.CurrentCharacter;
                loadingTab.Snapshot = CharacterSnapshot.From(CharSvc.CurrentCharacter);
                loadingTab.ProgressionSnapshots = SnapshotProgressionManagers();
                loadingTab.Session = characterFile.LoadSession();
                loadingTab.IsLoading = false;
                CharacterContext.ClaimAfterLoad(loadingTab);
                Tabs.NotifyChanged();
                Nav.NavigateTo("/character");
                return;
            }

            if (CharSvc.CurrentCharacter != null)
            {
                loadingTab.Character = CharSvc.CurrentCharacter;
                loadingTab.Snapshot = CharacterSnapshot.From(CharSvc.CurrentCharacter);
                loadingTab.ProgressionSnapshots = SnapshotProgressionManagers();
                loadingTab.Session = characterFile.LoadSession();
                loadingTab.IsLoading = false;
                CharacterContext.ClaimAfterLoad(loadingTab);
                Tabs.NotifyChanged();
                Nav.NavigateTo("/character");
                string warningMessage = string.IsNullOrEmpty(message)
                    ? $"Warning: {characterFile.DisplayName} loaded with missing elements; some features may not display."
                    : message;
                Snackbar.Add(warningMessage, Severity.Warning);
                return;
            }

            Tabs.CloseTab(loadingTab);
            string errorMessage = string.IsNullOrEmpty(message)
                ? $"Could not load {characterFile.DisplayName}."
                : $"Could not load {characterFile.DisplayName}: {message}";
            Snackbar.Add(errorMessage, Severity.Error);
        }
        catch (Exception ex)
        {
            DebugLogService.Instance.LogException(ex, "CharactersPage.OnCharacterSelected");
            Tabs.CloseTab(loadingTab);
            Snackbar.Add($"{characterFile.DisplayName}: {ex.GetType().Name} - {ex.Message}", Severity.Error);
        }
    }

    private void NavigateToCharacter() => Nav.NavigateTo("/character");

    private async Task OnImportPdf()
    {
        var dialog = await DialogService.ShowAsync<PdfImportDialog>("Import Character",
            new DialogOptions { MaxWidth = MaxWidth.Medium, CloseButton = true });
        await dialog.Result;
        _characters = CharSvc.LoadCharacterFiles().ToList();
        RebuildBrowserEntries();
        StateHasChanged();
    }

    private async Task OnImportFile()
    {
        _importingFile = true;
        StateHasChanged();

        Builder.Presentation.Models.CharacterFile? imported = null;
        try
        {
            var (file, error) = await CharSvc.ImportCharacterFromFileAsync();

            if (file == null && error == null)
            {
                // User cancelled the picker — nothing to do.
                return;
            }

            if (error != null)
            {
                Snackbar.Add(error, Severity.Error);
                return;
            }

            imported = file;
            _characters = CharSvc.LoadCharacterFiles().ToList();
            RebuildBrowserEntries();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            DebugLogService.Instance.LogException(ex, "CharactersPage.OnImportFile");
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
            return;
        }
        finally
        {
            _importingFile = false;
            StateHasChanged();
        }

        if (imported != null)
            await OnCharacterSelected(imported);
    }

    private async Task OnNewCharacter()
    {
        IDialogReference dialog = await DialogService.ShowAsync<NewCharacterDialog>("New Character");
        DialogResult? result = await dialog.Result;
        if (result is not { Canceled: false, Data: NewCharacterInfo info })
        {
            return;
        }

        _error = null;
        _warning = false;

        try
        {
            (Builder.Presentation.Models.CharacterFile? file, string? error) =
                await CharSvc.CreateNewCharacterAsync(info.Name, info.PlayerName, Prefs.DefaultHpMethod,
                    Prefs.DefaultFeats, Prefs.DefaultMulticlassing,
                    Prefs.DefaultCustomOrigin, Prefs.DefaultCustomLanguage, Prefs.DefaultCustomProficiency);

            if (file == null || CharSvc.CurrentCharacter == null)
            {
                _error = error ?? "Failed to create character.";
                StateHasChanged();
                return;
            }

            CharacterTab tab = Tabs.OpenTab(file, CharSvc.CurrentCharacter);
            tab.Snapshot = CharacterSnapshot.From(CharSvc.CurrentCharacter);
            tab.ProgressionSnapshots = SnapshotProgressionManagers();
            tab.IsNew = true;
            CharacterContext.ClaimAfterLoad(tab);

            _characters = CharSvc.LoadCharacterFiles().ToList();
            RebuildBrowserEntries();
            Nav.NavigateTo("/build");
        }
        catch (Exception ex)
        {
            DebugLogService.Instance.LogException(ex, "CharactersPage.OnNewCharacter");
            _error = $"{ex.GetType().Name}: {ex.Message}";
            StateHasChanged();
        }
    }

    private void OnBrowserSelected(CharacterBrowserEntry entry)
    {
        Builder.Presentation.Models.CharacterFile? character = _characters.FirstOrDefault(candidate =>
            string.Equals(candidate.FilePath, entry.Id, StringComparison.Ordinal));

        if (character != null)
        {
            _ = OnCharacterSelected(character);
        }
    }

    private async Task OnDeleteCharacter(CharacterBrowserEntry entry)
    {
        Builder.Presentation.Models.CharacterFile? file = _characters.FirstOrDefault(candidate =>
            string.Equals(candidate.FilePath, entry.Id, StringComparison.Ordinal));
        if (file == null) return;

        bool? confirmed = await DialogService.ShowMessageBox(
            "Delete Character?",
            $"Are you sure you want to permanently delete \"{file.DisplayName}\"? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;

        // Close the tab if this character is currently open.
        CharacterTab? tab = Tabs.FindTab(file);
        if (tab != null)
        {
            await CharacterContext.ReleaseAsync(tab);
            Tabs.CloseTab(tab);
        }

        try
        {
            CharSvc.DeleteCharacterFile(file);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not delete {file.DisplayName}: {ex.Message}", Severity.Error);
            return;
        }

        _characters = CharSvc.LoadCharacterFiles().ToList();
        RebuildBrowserEntries();
        StateHasChanged();
    }

    private static IReadOnlyList<ClassProgressionSnapshot> SnapshotProgressionManagers() =>
        BuildService.SnapshotProgressionManagers();

    private static CharacterBrowserEntry ToBrowserEntry(Builder.Presentation.Models.CharacterFile character) =>
        new(
            character.FilePath,
            character.DisplayName,
            $"Level {character.DisplayLevel} - {character.DisplayRace}",
            character.DisplayClass,
            string.IsNullOrWhiteSpace(character.CollectionGroupName) ? null : character.CollectionGroupName,
            character.CollectionGroupName,
            character.IsFavorite,
            PortraitDataUrl: null);  // loaded asynchronously by LoadPortraitsAsync

    private static string? ToPortraitDataUrl(Builder.Presentation.Models.CharacterFile character)
    {
        if (!string.IsNullOrEmpty(character.DisplayPortraitBase64))
        {
            return $"data:image/png;base64,{character.DisplayPortraitBase64}";
        }

        if (!string.IsNullOrEmpty(character.DisplayPortraitFilePath))
        {
            try
            {
                if (File.Exists(character.DisplayPortraitFilePath))
                {
                    byte[] bytes = File.ReadAllBytes(character.DisplayPortraitFilePath);
                    return $"data:image/png;base64,{Convert.ToBase64String(bytes)}";
                }
            }
            catch
            {
                return null;
            }
        }

        return null;
    }
}
