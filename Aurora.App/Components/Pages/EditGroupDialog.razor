@using Microsoft.AspNetCore.Components.Web

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-size: 15px; font-weight: 600;">Edit Group</MudText>
    </TitleContent>
    <DialogContent>
        <div class="new-character-dialog-content">
            <div class="character-creation-field">
                <label for="edit-group-input">Group</label>
                <input id="edit-group-input"
                       class="character-creation-input"
                       list="edit-group-suggestions"
                       placeholder="Select or type a group..."
                       value="@_group"
                       @oninput="e => _group = e.Value?.ToString() ?? string.Empty"
                       @onkeydown="OnKeyDown" />
                <datalist id="edit-group-suggestions">
                    @foreach (var g in ExistingGroups)
                    {
                        <option value="@g" />
                    }
                </datalist>
            </div>
            <p style="margin: 0.25rem 0 0; font-size: 0.82rem; color: var(--mud-palette-text-disabled);">
                Choose an existing group or type a new name. Leave empty to use "Characters".
            </p>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Confirm">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public string CurrentGroup { get; set; } = "";
    [Parameter] public IReadOnlyList<string> ExistingGroups { get; set; } = [];

    private string _group = "";

    protected override void OnParametersSet() => _group = CurrentGroup;

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") Confirm();
        if (e.Key == "Escape") Cancel();
    }

    private void Cancel() => MudDialog.Cancel();
    private void Confirm() => MudDialog.Close(_group.Trim());
}
