<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-size: 15px; font-weight: 600;">Edit Group</MudText>
    </TitleContent>
    <DialogContent>
        <div class="new-character-dialog-content">
            <div class="edit-group-field">
                <label for="@GroupFieldId">Group</label>
                <input id="@GroupFieldId"
                       class="edit-group-input"
                       list="@GroupListId"
                       placeholder="Select or type a group..."
                       @bind="_group"
                       @bind:event="oninput" />
                <datalist id="@GroupListId">
                    @foreach (string group in ExistingGroups)
                    {
                        <option value="@group" />
                    }
                </datalist>
            </div>
            <p style="margin: 0.25rem 0 0; font-size: 0.82rem; color: var(--mud-palette-text-disabled);">
                Choose an existing group or type a new name. Leave empty to use "Characters".
            </p>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Confirm">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public string CurrentGroup { get; set; } = "";
    [Parameter] public IReadOnlyList<string> ExistingGroups { get; set; } = [];

    private string _group = "";
    private string GroupFieldId { get; } = $"character-group-{Guid.NewGuid():N}";
    private string GroupListId { get; } = $"character-group-list-{Guid.NewGuid():N}";

    protected override void OnParametersSet() => _group = CurrentGroup;

    private void Cancel() => MudDialog.Cancel();
    private void Confirm() => MudDialog.Close(_group.Trim());
}
