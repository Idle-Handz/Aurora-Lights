@page "/equipment"
@implements IDisposable
@inject CharacterTabService Tabs
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject DebugLogService DebugLog
@using Aurora.App.Services
@using Builder.Presentation.Models.Equipment
@using Builder.Presentation.ViewModels.Shell.Items
@using Builder.Presentation

@if (_initError is not null)
{
    <div class="page-error-box" style="margin-top: 24px;">
        <div class="page-error-title">Equipment page failed to initialize.</div>
        <pre class="page-error-detail">@_initError</pre>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
            This error has been captured. Enable Dev Mode in
            <MudLink Href="/preferences">Preferences</MudLink> then open the
            <MudLink Href="/console">Console</MudLink> for details.
        </MudText>
    </div>
    return;
}

@if (_snap is null)
{
    <div style="margin-top: 24px;">
        <MudText Color="Color.Secondary">No character loaded. Open a character from the <MudLink Href="/">Characters</MudLink> page.</MudText>
    </div>
    return;
}

@if (CanAssignStartingEquipment)
{
    <div class="se-page-header">
        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.Inventory2"
                   Size="Size.Small"
                   OnClick="OpenStartingEquipmentAsync">
            Starting Equipment
        </MudButton>
    </div>
}

<CharacterEquipmentWorkspace Model="@EquipmentModel"
                             OnAddItem="OpenAddItemDialog"
                             OnOpenGearSlot="OpenGearSlotDialogAsync"
                             OnUnequipGearSlot="UnequipGearAsync"
                             OnRemoveItem="RemoveItemAsync"
                             OnToggleEquipped="ToggleEquippedAsync"
                             OnToggleVersatileWield="ToggleVersatileWieldAsync"
                             OnToggleAttuned="ToggleAttunedAsync"
                             OnChangeAmount="ChangeAmountAsync"
                             OnCoinChanged="ChangeCoinAsync"
                             OnNoteChanged="ChangeNoteAsync"
                             OnEditItem="EditItemAsync"
                             OnExtractItem="ExtractPackAsync" />

@code {
    private CharacterSnapshot? _snap;
    private string? _initError;

    private string? _armorName;
    private string? _mainHandName;
    private string? _offHandName;

    private EquipmentOverviewModel _equipmentModel = new();
    private EquipmentOverviewModel EquipmentModel => _equipmentModel;
    private bool CanAssignStartingEquipment => _snap?.InventoryItems.Any() == false;

    private void BuildEquipmentModel()
    {
        if (_snap is null) { _equipmentModel = new EquipmentOverviewModel(); return; }
        _equipmentModel = new()
        {
            Attacks = _snap.Attacks.Select(atk => new EquipmentAttackModel(atk.Name, atk.Attack, atk.Damage, atk.Range)).ToList(),
            GearSlots =
            [
                new("armor",     "Armor",     _armorName),
                new("main-hand", "Main Hand", _mainHandName),
                new("off-hand",  "Off Hand",  _offHandName)
            ],
            InventoryItems = _snap.InventoryItems
                .Select(item => new EquipmentInventoryItemModel(
                    item.Identifier,
                    item.Name,
                    item.Amount,
                    item.IsStackable,
                    item.IsEquipped,
                    item.EquippedLocation,
                    item.IsAttunable,
                    item.IsAttuned,
                    item.DisplayWeight,
                    item.DisplayPrice,
                    item.IsEquippable,
                    item.HasVersatile,
                    Tabs.ActiveTab?.Character is { } character &&
                        EquipmentService.CanExtractPack(character, item.Identifier)))
                .ToList(),
            Copper   = _snap.CoinCopper,
            Silver   = _snap.CoinSilver,
            Electrum = _snap.CoinElectrum,
            Gold     = _snap.CoinGold,
            Platinum = _snap.CoinPlatinum,
            AttunedCount    = _snap.AttunedCount,
            AttunedMax      = _snap.AttunedMax,
            EquipmentNotes  = _snap.InventoryEquipmentText,
            TreasureNotes   = _snap.InventoryTreasureText,
            QuestNotes      = _snap.InventoryQuestText
        };
    }

    protected override void OnInitialized()
    {
        Tabs.TabsChanged += OnTabsChanged;
        try
        {
            LoadFromActiveTab();
        }
        catch (Exception ex)
        {
            _initError = $"{ex.GetType().Name}: {ex.Message}\n\n{ex.StackTrace}";
            DebugLog.LogException(ex, "Equipment.OnInitialized");
        }
    }

    private void LoadFromActiveTab()
    {
        _snap = Tabs.ActiveTab?.Snapshot;
        RefreshGearNames();
        BuildEquipmentModel();
    }

    private void RefreshGearNames()
    {
        if (_snap is null)
        {
            _armorName = _mainHandName = _offHandName = null;
            return;
        }
        _armorName    = _snap.InventoryItems
            .FirstOrDefault(i => i.IsEquipped && i.EquippedLocation == "Armor")?.Name;
        _mainHandName = _snap.InventoryItems
            .FirstOrDefault(i => i.IsEquipped && i.EquippedLocation is "Primary Hand" or "Two-Handed" or "Two-Handed (Versatile)")?.Name;
        _offHandName  = _snap.InventoryItems
            .FirstOrDefault(i => i.IsEquipped && i.EquippedLocation == "Secondary Hand")?.Name;
    }

    private bool _disposed;

    private void OnTabsChanged()
    {
        if (_disposed) return;
        _ = InvokeAsync(() =>
        {
            if (_disposed) return;
            LoadFromActiveTab();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        _disposed = true;
        Tabs.TabsChanged -= OnTabsChanged;
    }

    private void MarkDirty()
    {
        if (Tabs.ActiveTab is { } tab)
        {
            Tabs.MarkDirty(tab);
        }
    }

    private static GearSlot ParseSlot(string slotId) => slotId switch
    {
        "armor" => GearSlot.Armor,
        "main-hand" => GearSlot.MainHand,
        "off-hand" => GearSlot.OffHand,
        _ => throw new InvalidOperationException("Unknown gear slot.")
    };

    private async Task OpenGearSlotDialogAsync(string slotId)
    {
        await OpenGearSlotDialog(ParseSlot(slotId));
    }

    private async Task UnequipGearAsync(string slotId)
    {
        await UnequipGear(ParseSlot(slotId));
    }

    private async Task OpenGearSlotDialog(GearSlot slot)
    {
        if (Tabs.ActiveTab is not { Character: { } character, File: { } file, Snapshot: { } snap })
        {
            WarnUnavailable("Equipment cannot be changed because there is no active character.");
            return;
        }

        var invOptions = EquipmentService.GetInventoryItemsForSlot(character, slot);

        var parameters = new DialogParameters
        {
            [nameof(GearSlotPickerDialog.Slot)] = slot,
            [nameof(GearSlotPickerDialog.InventoryOptions)] = invOptions,
        };
        var dialog = await DialogService.ShowAsync<GearSlotPickerDialog>("", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: GearPickerResult pick })
        {
            var tab = Tabs.ActiveTab;
            if (tab is null)
            {
                WarnUnavailable("That gear change could not be applied because the character tab is no longer active.");
                return;
            }
            using var scope = await CharacterContext.EnterAsync(tab);

            bool ok = pick.IsNew
                ? EquipmentService.AddAndEquipToSlot(character, slot, pick.ElementId!)
                : EquipmentService.EquipToSlot(character, slot, pick.Identifier!);

            if (!ok)
            {
                Snackbar.Add("Could not equip item.", Severity.Error);
                return;
            }

            RefreshEquipment();
            file.SaveInventoryItems(character);
            MarkDirty();
            StateHasChanged();
        }
    }

    private async Task UnequipGear(GearSlot slot)
    {
        var tab = Tabs.ActiveTab;
        if (tab is not { Character: { } character, File: { } file, Snapshot: { } snap })
        {
            WarnUnavailable("Equipment cannot be changed because there is no active character.");
            return;
        }
        using var scope = await CharacterContext.EnterAsync(tab);

        EquipmentService.UnequipSlot(character, slot);
        RefreshEquipment();
        file.SaveInventoryItems(character);
        MarkDirty();
        StateHasChanged();
    }

    private async Task OpenAddItemDialog()
    {
        var dialog = await DialogService.ShowAsync<ItemPickerDialog>("Add Item");
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: ItemPickerResult pick })
        {
            var tab = Tabs.ActiveTab;
            if (tab is not { Character: { } character, File: { } file, Snapshot: { } snap })
            {
                WarnUnavailable("Items cannot be added because there is no active character.");
                return;
            }
            using var scope = await CharacterContext.EnterAsync(tab);

            var added = EquipmentService.AddItem(character, pick.ElementId, pick.Amount);
            if (!added)
            {
                Snackbar.Add("Could not add item - element not found.", Severity.Error);
                return;
            }

            RefreshEquipment();
            file.SaveInventoryItems(character);
            MarkDirty();
            StateHasChanged();
        }
    }

    private async Task RemoveItemAsync(string identifier)
    {
        var tab = Tabs.ActiveTab;
        if (tab is not { Character: { } character, File: { } file, Snapshot: { } snap })
        {
            WarnUnavailable("Items cannot be removed because there is no active character.");
            return;
        }

        var itemName = snap.InventoryItems
            .FirstOrDefault(i => i.Identifier == identifier)?.Name ?? "this item";

        bool? confirmed = await DialogService.ShowMessageBox(
            "Remove Item",
            $"Remove \"{itemName}\" from inventory? This cannot be undone.",
            yesText: "Remove", cancelText: "Cancel");

        if (confirmed != true) return;

        using var scope = await CharacterContext.EnterAsync(tab);
        EquipmentService.RemoveItem(character, identifier);
        RefreshEquipment();
        file.SaveInventoryItems(character);
        MarkDirty();
        StateHasChanged();
    }

    private async Task ExtractPackAsync(string identifier)
    {
        var tab = Tabs.ActiveTab;
        if (tab is not { Character: { } character, File: { } file })
        {
            WarnUnavailable("Items cannot be extracted because there is no active character.");
            return;
        }

        var components = EquipmentService.GetPackComponents(character, identifier);
        if (components.Count == 0)
        {
            WarnUnavailable("That inventory item cannot be extracted.");
            return;
        }

        var packName = _snap?.InventoryItems
            .FirstOrDefault(i => i.Identifier == identifier)?.Name ?? "this pack";
        var preview = string.Join(", ", components.Select(FormatPackComponent).Take(8));
        if (components.Count > 8)
            preview += $", and {components.Count - 8} more";

        bool? confirmed = await DialogService.ShowMessageBox(
            "Extract Pack",
            $"Extract \"{packName}\" into {preview}? The pack will be removed from inventory.",
            yesText: "Extract", cancelText: "Cancel");

        if (confirmed != true) return;

        using var scope = await CharacterContext.EnterAsync(tab);
        var result = EquipmentService.ExtractPack(character, identifier);

        if (result.Added.Count == 0)
        {
            var message = result.MissingElementIds.Count > 0
                ? $"Could not extract pack: {result.MissingElementIds.Count} component(s) could not be resolved. The pack was left unchanged."
                : "Could not extract pack contents. The pack was left unchanged.";
            Snackbar.Add(message, Severity.Warning, cfg => cfg.VisibleStateDuration = 6000);
            return;
        }

        RefreshEquipment();
        file.SaveInventoryItems(character);
        MarkDirty();

        if (result.Success)
        {
            Snackbar.Add($"Extracted {result.PackName}.", Severity.Success);
        }
        else
        {
            Snackbar.Add(
                $"Extracted {result.Added.Count} item(s), but {result.MissingElementIds.Count} component(s) could not be resolved.",
                Severity.Warning,
                cfg => cfg.VisibleStateDuration = 6000);
        }

        StateHasChanged();
    }

    private async Task ChangeAmountAsync(EquipmentAmountChangeModel change)
    {
        var tab = Tabs.ActiveTab;
        if (tab is not { Character: { } character, File: { } file, Snapshot: { } snap })
        {
            WarnUnavailable("Item quantities cannot be changed because there is no active character.");
            return;
        }
        using var scope = await CharacterContext.EnterAsync(tab);

        EquipmentService.SetAmount(character, change.Identifier, change.Amount);
        RefreshEquipment();
        file.SaveInventoryItems(character);
        MarkDirty();
        // No explicit StateHasChanged here: this — and the sibling Toggle*/ChangeCoin/ChangeNote
        // handlers — runs via the child workspace's EventCallback, which re-renders this
        // component automatically once the handler completes.
    }

    private async Task ToggleEquippedAsync(string identifier)
    {
        var tab = Tabs.ActiveTab;
        if (tab is not { Character: { } character, File: { } file })
        {
            WarnUnavailable("Equipment cannot be changed because there is no active character.");
            return;
        }
        using var scope = await CharacterContext.EnterAsync(tab);

        var item = FindLiveItem(identifier);
        if (item is null)
        {
            WarnUnavailable("That inventory item could not be found anymore.");
            return;
        }

        if (item.IsEquipped)
        {
            var loc = item.EquippedLocation ?? "";
            if (loc == "Armor")
                EquipmentService.UnequipSlot(character, GearSlot.Armor);
            else if (loc is "Primary Hand" or "Two-Handed" or "Two-Handed (Versatile)")
                EquipmentService.UnequipSlot(character, GearSlot.MainHand);
            else if (loc == "Secondary Hand")
                EquipmentService.UnequipSlot(character, GearSlot.OffHand);
            else
                item.Deactivate();
        }
        else
        {
            var naturalSlot = EquipmentService.GetNaturalSlot(item);
            if (naturalSlot.HasValue)
                EquipmentService.EquipToSlot(character, naturalSlot.Value, identifier);
            else
                item.Activate(equip: true, attune: item.IsAttuned);
        }

        RefreshEquipment();
        file.SaveInventoryItems(character);
        MarkDirty();
    }

    private async Task ToggleAttunedAsync(string identifier)
    {
        var tab = Tabs.ActiveTab;
        if (tab is not { Character: { } character, File: { } file })
        {
            WarnUnavailable("Attunement cannot be changed because there is no active character.");
            return;
        }
        using var scope = await CharacterContext.EnterAsync(tab);

        var item = FindLiveItem(identifier);
        if (item is null)
        {
            WarnUnavailable("That inventory item could not be found anymore.");
            return;
        }

        if (item.IsAttuned)
            item.DeactivateAttunement();
        else
            item.Activate(equip: item.IsEquipped, attune: true);

        RefreshEquipment();
        file.SaveInventoryItems(character);
        MarkDirty();
    }

    private async Task ToggleVersatileWieldAsync(string identifier)
    {
        var tab = Tabs.ActiveTab;
        if (tab is not { Character: { } character, File: { } file })
        {
            WarnUnavailable("Equipment cannot be changed because there is no active character.");
            return;
        }
        using var scope = await CharacterContext.EnterAsync(tab);

        var item = FindLiveItem(identifier);
        if (item is null || !item.Item.HasVersatile || !item.IsEquipped)
        {
            WarnUnavailable("That item cannot be wielded with two hands right now.");
            return;
        }

        bool twoHanded = !string.Equals(item.EquippedLocation, "Two-Handed (Versatile)", StringComparison.OrdinalIgnoreCase);
        if (!EquipmentService.SetVersatileWield(character, identifier, twoHanded))
        {
            WarnUnavailable("That item's wield state could not be changed.");
            return;
        }

        RefreshEquipment();
        file.SaveInventoryItems(character);
        MarkDirty();
    }

    private RefactoredEquipmentItem? FindLiveItem(string identifier) =>
        Tabs.ActiveTab?.Character?.Inventory?.Items
            .FirstOrDefault(i => i.Identifier == identifier);

    private void RefreshEquipment(bool reprocess = true)
    {
        if (Tabs.ActiveTab is not { Character: { } character, Snapshot: { } snap }) return;
        if (reprocess) CharacterManager.Current.ReprocessCharacter();
        snap.RefreshEquipmentFromCharacter(character);
        _snap = snap;
        RefreshGearNames();
        BuildEquipmentModel();
    }

    private Task ChangeCoinAsync(EquipmentCoinChangeModel change)
    {
        if (_snap is null)
        {
            return Task.CompletedTask;
        }

        switch (change.CoinId)
        {
            case "cp":
                _snap.CoinCopper = change.Value;
                break;
            case "sp":
                _snap.CoinSilver = change.Value;
                break;
            case "ep":
                _snap.CoinElectrum = change.Value;
                break;
            case "gp":
                _snap.CoinGold = change.Value;
                break;
            case "pp":
                _snap.CoinPlatinum = change.Value;
                break;
        }

        if (Tabs.ActiveTab?.Character?.Inventory?.Coins is { } coins)
        {
            coins.Set(
                _snap.CoinCopper,
                _snap.CoinSilver,
                _snap.CoinElectrum,
                _snap.CoinGold,
                _snap.CoinPlatinum);
        }

        MarkDirty();
        return Task.CompletedTask;
    }

    private Task ChangeNoteAsync(EquipmentNoteChangeModel change)
    {
        if (_snap is null)
        {
            return Task.CompletedTask;
        }

        switch (change.NoteId)
        {
            case "equipment":
                _snap.InventoryEquipmentText = change.Value;
                break;
            case "treasure":
                _snap.InventoryTreasureText = change.Value;
                break;
            case "quest":
                _snap.InventoryQuestText = change.Value;
                break;
        }

        MarkDirty();
        return Task.CompletedTask;
    }

    private async Task OpenStartingEquipmentAsync()
    {
        var agg = await StartingEquipmentService.GetAllAsync();

        var parameters = new DialogParameters
        {
            [nameof(StartingEquipmentDialog.ClassBlock)]      = agg.ClassBlock,
            [nameof(StartingEquipmentDialog.BackgroundBlock)] = agg.BackgroundBlock,
        };
        var dialog = await DialogService.ShowAsync<StartingEquipmentDialog>("Starting Equipment", parameters);
        var result = await dialog.Result;

        if (result is not { Canceled: false, Data: StartingEquipmentResult se })
            return;

        var tab = Tabs.ActiveTab;
        if (tab is not { Character: { } character, File: { } file })
        {
            WarnUnavailable("Starting equipment could not be applied because there is no active character.");
            return;
        }

        using var scope = await CharacterContext.EnterAsync(tab);

        var unresolvedItems = new List<string>();
        foreach (var (id, count, name) in se.Items)
        {
            bool added = EquipmentService.AddItem(character, id, count);
            if (!added)
            {
                unresolvedItems.Add(DescribeStartingEquipmentItem(id, count, name));
                continue;
            }

            if (!string.IsNullOrEmpty(name))
            {
                var liveItem = character.Inventory.Items.LastOrDefault();
                if (liveItem != null)
                    liveItem.AlternativeName = name;
            }
        }

        DepositStartingCoins(character, se);

        RefreshEquipment();

        if (se.TookRolledGold)
        {
            Snackbar.Add(
                "Roll your gold dice and add the result to your coin purse manually.",
                Severity.Info,
                cfg => cfg.VisibleStateDuration = 5000);
        }

        if (unresolvedItems.Count > 0)
            WarnUnresolvedStartingEquipment(unresolvedItems);

        var inventorySaved = file.SaveInventoryItems(character);
        var currencySaved = _snap is null || file.SaveCurrency(_snap);
        if (!inventorySaved || !currencySaved)
        {
            Snackbar.Add("Starting equipment was applied in memory, but some changes could not be written to the character file yet.", Severity.Error);
        }

        MarkDirty();
        StateHasChanged();
    }

    private void WarnUnresolvedStartingEquipment(IReadOnlyList<string> unresolvedItems)
    {
        var sample = string.Join(", ", unresolvedItems.Take(5));
        if (unresolvedItems.Count > 5)
            sample += $", and {unresolvedItems.Count - 5} more";

        DebugLog.Warn(
            "Starting equipment item IDs could not be resolved.",
            string.Join(Environment.NewLine, unresolvedItems));

        Snackbar.Add(
            $"Could not add {unresolvedItems.Count} starting equipment item(s): {sample}. Check that the matching content sources are enabled.",
            Severity.Error,
            cfg => cfg.VisibleStateDuration = 8000);
    }

    private static string DescribeStartingEquipmentItem(string id, int count, string? name)
    {
        var label = !string.IsNullOrWhiteSpace(name)
            ? $"{name} ({id})"
            : id;

        return count > 1 ? $"{count}x {label}" : label;
    }

    private static string FormatPackComponent(EquipmentPackComponent component) =>
        component.Amount > 1 ? $"{component.Name} ({component.Amount})" : component.Name;

    private static void DepositStartingCoins(Builder.Presentation.Models.Character character, StartingEquipmentResult se)
    {
        if (se.Copper > 0)
            character.Inventory.Coins.Deposit(Coinage.CurrencyCoin.Copper, se.Copper);
        if (se.Silver > 0)
            character.Inventory.Coins.Deposit(Coinage.CurrencyCoin.Silver, se.Silver);
        if (se.Electrum > 0)
            character.Inventory.Coins.Deposit(Coinage.CurrencyCoin.Electrum, se.Electrum);
        if (se.Gold > 0)
            character.Inventory.Coins.Deposit(Coinage.CurrencyCoin.Gold, se.Gold);
        if (se.Platinum > 0)
            character.Inventory.Coins.Deposit(Coinage.CurrencyCoin.Platinum, se.Platinum);
    }

    private async Task EditItemAsync(string identifier)
    {
        var liveItem = FindLiveItem(identifier);
        if (liveItem is null)
        {
            WarnUnavailable("That item could not be found.");
            return;
        }

        var originalName = _snap?.InventoryItems.FirstOrDefault(i => i.Identifier == identifier)?.Name
            ?? liveItem.Name ?? identifier;

        var parameters = new DialogParameters
        {
            [nameof(ItemEditDialog.OriginalName)]      = originalName,
            [nameof(ItemEditDialog.AlternativeName)]   = liveItem.AlternativeName,
            [nameof(ItemEditDialog.Notes)]             = liveItem.Notes,
        };
        var dialog = await DialogService.ShowAsync<ItemEditDialog>("Customize Item", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: EquipmentItemEditResult edit })
        {
            var tab = Tabs.ActiveTab;
            if (tab is not { Character: { } character, File: { } file })
            {
                WarnUnavailable("Changes could not be saved because the character tab is no longer active.");
                return;
            }
            using var scope = await CharacterContext.EnterAsync(tab);

            liveItem.AlternativeName = edit.AlternativeName;
            liveItem.Notes           = edit.Notes;

            RefreshEquipment(reprocess: false);
            file.SaveInventoryItems(character);
            MarkDirty();
            StateHasChanged();
        }
    }

    private void WarnUnavailable(string message) =>
        Snackbar.Add(message, Severity.Warning, cfg => cfg.VisibleStateDuration = 2500);
}
