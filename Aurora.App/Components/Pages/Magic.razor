@page "/magic"
@implements IDisposable
@using Builder.Presentation
@inject CharacterTabService Tabs
@inject IDialogService DialogService
@inject CharacterService Characters
@inject ISnackbar Snackbar
@inject UserPreferencesService Prefs

@if (_snap is null)
{
    <div style="margin-top: 24px;">
        <MudText Color="Color.Secondary">No character loaded. Open a character from the <MudLink Href="/">Characters</MudLink> page.</MudText>
    </div>
    return;
}

@if (!_snap.HasSpellcasting)
{
    <div style="margin-top: 24px;">
        <MudText Color="Color.Secondary">This character has no spellcasting.</MudText>
    </div>
    return;
}

@if (!Prefs.AutoSaveBuildChanges)
{
    <div class="page-save-bar">
        <MudText Typo="Typo.caption" Style="color: #a6adc8;">Auto-save off</MudText>
        <MudButton StartIcon="@Icons.Material.Filled.Save"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   Size="Size.Small"
                   Disabled="@(_saving || !(Tabs.ActiveTab?.IsDirty == true))"
                   OnClick="ManualSaveAsync">
            Save
        </MudButton>
    </div>
}
@if (_saving)
{
    <div class="build-saving-bar">
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Style="height: 2px;" />
    </div>
}
@if (_saveError != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-3" ShowCloseIcon="true"
              CloseIconClicked="() => _saveError = null">
        <div><b>Failed to save</b></div>
        <div style="font-size:0.8em; word-break:break-all; white-space:pre-wrap;">@_saveError</div>
    </MudAlert>
}

<CharacterMagicWorkspace Model="@MagicModel"
                         Busy="_saving"
                         SelectedSpellId="_selectedId"
                         SelectedSpell="@SelectedSpellModel"
                         OnSelectSpell="SelectSpellAsync"
                         OnChangeKnownSpell="OpenSpellPickerByKeyAsync"
                         OnPreparedChanged="OnPreparedChangedAsync"
                         OnToggleSlot="PersistSlotToggleAsync" />

@code {
    private CharacterSnapshot? _snap;
    private IReadOnlyList<SelectionRuleGroup> _spellRuleGroups = [];
    private bool _saving;
    private string? _saveError;
    private string? _selectedId;
    private SpellDetail? _spellDetail;
    private MagicOverviewModel _magicModel = new();
    private MagicOverviewModel MagicModel => _magicModel;

    private void BuildMagicModel()
    {
        if (_snap is null) { _magicModel = new MagicOverviewModel(); _selectedSpellModel = null; return; }
        var slotUsage = Tabs.ActiveTab?.Session.SpellSlotsUsed ?? new Dictionary<int, int>();
        _magicModel = new()
        {
            HasSpellcasting = _snap.HasSpellcasting,
            KnownSpellGroups = _spellRuleGroups.Select((group, groupIndex) =>
                new MagicKnownSpellGroupModel(
                    group.Label,
                    group.Rules.Select((entry, entryIndex) => new MagicKnownSpellEntryModel(
                        $"{groupIndex}:{entryIndex}",
                        entry.Label,
                        entry.CurrentName)).ToList()))
                .ToList(),
            Sections = _snap.SpellcastingSections
                .Select(section => new MagicSpellcastingSectionModel
                {
                    Id = section.UniqueIdentifier,
                    Label = section.Name,
                    IsPreparedCaster = section.IsPreparedCaster,
                    SpellcastingAbility = section.AbilityName,
                    SpellcastingDc = section.SpellcastingDc,
                    SpellcastingAttack = section.SpellcastingAttack,
                    PreparedCount = section.PreparedCount,
                    MaxPrepared = section.MaxPrepared,
                    Cantrips = section.Cantrips
                        .Select(spell => new MagicSpellListEntryModel(
                            spell.Id,
                            spell.Name,
                            0,
                            GetSpellSource(spell.Id),
                            true,
                            true,
                            isCantrip: true))
                        .ToList(),
                    SpellLevels = section.SpellLevels
                        .Select(level => new MagicSpellLevelModel(
                            level.Level,
                            level.Spells.Select(spell => new MagicSpellListEntryModel(
                                spell.Id,
                                spell.Name,
                                level.Level,
                                GetSpellSource(spell.Id),
                                spell.IsPrepared,
                                spell.IsAlwaysPrepared)).ToList(),
                            level.TotalSlots,
                            slotUsage.GetValueOrDefault(level.Level, 0)))
                        .ToList()
                })
                .ToList()
        };
    }

    private MagicSpellDetailModel? _selectedSpellModel;
    private MagicSpellDetailModel? SelectedSpellModel => _selectedSpellModel;

    protected override async Task OnInitializedAsync()
    {
        Tabs.TabsChanged += OnTabsChanged;
        await LoadFromActiveTabAsync();
    }

    private async Task LoadFromActiveTabAsync()
    {
        var tab = Tabs.ActiveTab;
        _snap = tab?.Snapshot;
        _selectedId = null;
        _spellDetail = null;

        if (tab != null && _snap != null)
        {
            using (await CharacterContext.EnterAsync(tab))
            {
                _spellRuleGroups = BuildService.GetSpellRuleGroups();
            }

        }
        else
        {
            _spellRuleGroups = [];
        }

        BuildMagicModel();
    }

    private bool _disposed;

    private void OnTabsChanged()
    {
        if (_disposed) return;
        _ = InvokeAsync(async () =>
        {
            if (_disposed) return;
            await LoadFromActiveTabAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        _disposed = true;
        Tabs.TabsChanged -= OnTabsChanged;
    }

    private Task SelectSpellAsync(string id)
    {
        _selectedId = id;
        _spellDetail = BuildService.GetSpellDetail(id);
        _selectedSpellModel = _spellDetail is null
            ? null
            : new MagicSpellDetailModel(
                _spellDetail.Id,
                _spellDetail.Name,
                _spellDetail.Source,
                _spellDetail.Level,
                _spellDetail.Subtitle,
                _spellDetail.CastingTime,
                _spellDetail.Range,
                _spellDetail.Components,
                _spellDetail.Duration,
                _spellDetail.Description);
        return Task.CompletedTask;
    }

    private static string GetSpellSource(string id)
        => BuildService.GetSpellDetail(id)?.Source ?? string.Empty;

    private async Task ManualSaveAsync()
    {
        var tab = Tabs.ActiveTab;
        if (tab == null) return;
        _saving = true;
        StateHasChanged();
        var error = await BuildService.SaveTabAsync(tab);
        _saving = false;
        if (error == null)
        {
            Tabs.MarkClean(tab);
            Snackbar.Add("Saved.", Severity.Success, cfg => cfg.VisibleStateDuration = 2000);
        }
        else
        {
            _saveError = error;
        }

        StateHasChanged();
    }

    private async Task OpenSpellPickerByKeyAsync(string key)
    {
        string[] parts = key.Split(':', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length != 2
            || !int.TryParse(parts[0], out int groupIndex)
            || !int.TryParse(parts[1], out int entryIndex)
            || groupIndex < 0
            || groupIndex >= _spellRuleGroups.Count
            || entryIndex < 0
            || entryIndex >= _spellRuleGroups[groupIndex].Rules.Count)
        {
            return;
        }

        await OpenSpellPickerAsync(_spellRuleGroups[groupIndex].Rules[entryIndex]);
    }

    private async Task OpenSpellPickerAsync(SelectionRuleEntry entry)
    {
        var tab = Tabs.ActiveTab;
        var file = Characters.CurrentCharacterFile;
        if (tab == null || file == null) return;

        var options = await Task.Run(() => BuildService.GetOptions(entry.Rule));

        var parameters = new DialogParameters
        {
            [nameof(SelectionPickerDialog.Entry)] = entry,
            [nameof(SelectionPickerDialog.Options)] = options,
        };
        var dialogOptions = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseOnEscapeKey = true,
        };

        var dialog = await DialogService.ShowAsync<SelectionPickerDialog>(entry.Label, parameters, dialogOptions);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string selectedId })
        {
            _saving = true;
            _saveError = null;
            StateHasChanged();

            bool autoSave = Prefs.AutoSaveBuildChanges;
            var removed = await BuildService.ApplySelectionAndSaveAsync(
                entry.Rule, selectedId, entry.Number, tab, file, saveToFile: autoSave);

            _saving = false;

            var errors = removed.Where(s => s.StartsWith("[Error:")).ToList();

            if (errors.Count > 0)
                _saveError = string.Join("; ", errors.Select(e => e.TrimStart('[').TrimEnd(']').Replace("Error: ", "")));
            else if (autoSave)
            {
                Tabs.MarkClean(tab);
                Snackbar.Add("Changes saved.", Severity.Success, cfg => cfg.VisibleStateDuration = 2000);
            }
            else
            {
                Tabs.MarkDirty(tab);
                Snackbar.Add($"{entry.Label} updated. Save when ready.", Severity.Info, cfg => cfg.VisibleStateDuration = 2500);
            }

            await LoadFromActiveTabAsync();
            StateHasChanged();
        }
    }

    private async Task OnPreparedChangedAsync(MagicPreparedChangeModel change)
    {
        if (_snap is null || Tabs.ActiveTab is not { } tab) return;

        var section = _snap.SpellcastingSections
            .FirstOrDefault(candidate => string.Equals(candidate.UniqueIdentifier, change.SpellcastingSectionId, StringComparison.Ordinal));
        if (section is null) return;

        SpellEntry? spell = section.SpellLevels
            .SelectMany(level => level.Spells)
            .FirstOrDefault(candidate => string.Equals(candidate.Id, change.SpellId, StringComparison.Ordinal));
        if (spell is null) return;

        // Update the snapshot (UI) and the handler (serialisation source) atomically under the lock.
        using (await CharacterContext.EnterAsync(tab))
        {
            spell.IsPrepared = change.Value;

            var handler = SpellcastingSectionContext.Current;
            if (handler is not null)
            {
                if (change.Value)
                {
                    var info = CharacterManager.Current
                        .GetSpellcastingInformations()
                        .FirstOrDefault(i => string.Equals(i.UniqueIdentifier, change.SpellcastingSectionId, StringComparison.Ordinal));
                    if (info is not null)
                        handler.SetPrepareSpell(info, change.SpellId);
                }
                else
                {
                    handler.UnsetPrepareSpell(change.SpellcastingClass, change.SpellId);
                }
            }
        }

        BuildMagicModel();
        Tabs.MarkDirty(tab);

        if (Prefs.AutoSaveBuildChanges)
        {
            _saving = true;
            _saveError = null;
            StateHasChanged();

            string? error = await BuildService.SaveTabAsync(tab);

            _saving = false;
            if (error is null)
            {
                Tabs.MarkClean(tab);
                Snackbar.Add(change.Value ? $"{spell.Name} prepared." : $"{spell.Name} unprepared.",
                    Severity.Success, cfg => cfg.VisibleStateDuration = 1800);
            }
            else
                _saveError = error;

            StateHasChanged();
        }
        else
        {
            Snackbar.Add(change.Value ? $"{spell.Name} prepared. Save when ready." : $"{spell.Name} unprepared. Save when ready.",
                Severity.Info, cfg => cfg.VisibleStateDuration = 2200);
        }
    }

    private void ToggleSlotAsync(MagicSlotToggleModel change)
    {
        var tab = Tabs.ActiveTab;
        if (_snap is null || tab is null) return;

        // Same toggle logic as Session.razor: clicking a filled pip clears it,
        // clicking an empty pip fills up to that index.
        var used = tab.Session.SpellSlotsUsed.GetValueOrDefault(change.Level, 0);
        int newUsed = used == change.SlotIndex ? change.SlotIndex - 1 : change.SlotIndex;
        tab.Session.SpellSlotsUsed[change.Level] = newUsed;

        foreach (var section in _snap.SpellcastingSections)
        {
            var level = section.SpellLevels.FirstOrDefault(l => l.Level == change.Level);
            if (level is not null)
                level.UsedSlots = newUsed;
        }

        BuildMagicModel();

        try { tab.File.SaveSession(tab.Session); }
        catch { /* non-critical — state remains correct in memory */ }
    }

    private Task PersistSlotToggleAsync(MagicSlotToggleModel change)
    {
        var tab = Tabs.ActiveTab;
        if (_snap is null || tab is null) return Task.CompletedTask;

        var used = tab.Session.SpellSlotsUsed.GetValueOrDefault(change.Level, 0);
        int newUsed = used == change.SlotIndex ? change.SlotIndex - 1 : change.SlotIndex;
        tab.Session.SpellSlotsUsed[change.Level] = newUsed;

        foreach (var section in _snap.SpellcastingSections)
        {
            var level = section.SpellLevels.FirstOrDefault(l => l.Level == change.Level);
            if (level is not null)
                level.UsedSlots = newUsed;
        }

        BuildMagicModel();

        if (tab.File.SaveSession(tab.Session))
        {
            _saveError = null;
        }
        else
        {
            _saveError = "Spell slot changes could not be saved yet. The current slot state is still in memory.";
        }

        return InvokeAsync(StateHasChanged);
    }
}
