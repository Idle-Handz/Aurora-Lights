@page "/manage"
@implements IDisposable
@inject CharacterTabService Tabs
@inject ISnackbar Snackbar
@inject UserPreferencesService Prefs
@inject DebugLogService DebugLog
@using Builder.Presentation
@using Builder.Presentation.Models.Sources

@if (_snap is null)
{
    <div style="margin-top: 24px;">
        <MudText Color="Color.Secondary">No character loaded. Open a character from the <MudLink Href="/">Characters</MudLink> page.</MudText>
    </div>
    return;
}

<MudTabs Elevation="0" ApplyEffectsToContainer="true" PanelClass="pa-0 pt-4">

    <MudTabPanel Text="Info">
        <CharacterManageWorkspace InfoModel="_infoModel"
                                  OnInfoChanged="MarkDirty" />
    </MudTabPanel>

    <MudTabPanel Text="Sources">
        <CharacterManageWorkspace EmptyMessage="No source restrictions are available."
                                  InfoModel="@null"
                                  SourceGroups="@SourceGroups"
                                  ShowDefaultActions="true"
                                  OnToggleGroup="ToggleGroupAsync"
                                  OnToggleItem="ToggleSourceAsync"
                                  OnLoadDefaults="LoadDefaultAsync"
                                  OnSaveDefaults="SaveAsDefault" />
    </MudTabPanel>

    <MudTabPanel Text="Options">
        <div class="pref-section">
            <div class="section-label">Optional Rules</div>

            <div class="pref-row">
                <div class="pref-row-text">
                    <div class="pref-row-title">Allow feats</div>
                    <div class="pref-row-desc">
                        When enabled, this character can forgo an Ability Score Improvement to take a feat instead.
                    </div>
                </div>
                <MudSwitch Value="BuildService.IsUsingFeats"
                           ValueChanged="@((bool v) => SetOptionAsync(v, "feats"))"
                           Disabled="@_optionSaving"
                           Color="Color.Primary" />
            </div>

            <div class="pref-row" style="margin-top: 16px;">
                <div class="pref-row-text">
                    <div class="pref-row-title">Allow multiclassing</div>
                    <div class="pref-row-desc">
                        When enabled, this character can gain levels in more than one class.
                    </div>
                </div>
                <MudSwitch Value="BuildService.IsUsingMulticlassing"
                           ValueChanged="@((bool v) => SetOptionAsync(v, "multiclassing"))"
                           Disabled="@_optionSaving"
                           Color="Color.Primary" />
            </div>

            <div class="pref-row" style="margin-top: 16px;">
                <div class="pref-row-text">
                    <div class="pref-row-title">Customized ability score increases</div>
                    <div class="pref-row-desc">
                        Move racial ability score increases to any ability scores of your choice,
                        keeping the same split (+2 to one ability, +1 to a different one).
                    </div>
                </div>
                <MudSwitch Value="BuildService.IsUsingCustomOrigin"
                           ValueChanged="@((bool v) => SetOptionAsync(v, "origin"))"
                           Disabled="@_optionSaving"
                           Color="Color.Primary" />
            </div>

            <div class="pref-row" style="margin-top: 16px;">
                <div class="pref-row-text">
                    <div class="pref-row-title">Customized language</div>
                    <div class="pref-row-desc">
                        Replace the fixed language granted by your race with any other standard language
                        of your choice.
                    </div>
                </div>
                <MudSwitch Value="BuildService.IsUsingCustomLanguage"
                           ValueChanged="@((bool v) => SetOptionAsync(v, "language"))"
                           Disabled="@_optionSaving"
                           Color="Color.Primary" />
            </div>

            <div class="pref-row" style="margin-top: 16px;">
                <div class="pref-row-text">
                    <div class="pref-row-title">Customized proficiencies</div>
                    <div class="pref-row-desc">
                        Replace any fixed skill proficiency granted by your race with any other skill
                        proficiency of your choice.
                    </div>
                </div>
                <MudSwitch Value="BuildService.IsUsingCustomProficiency"
                           ValueChanged="@((bool v) => SetOptionAsync(v, "proficiency"))"
                           Disabled="@_optionSaving"
                           Color="Color.Primary" />
            </div>
        </div>
    </MudTabPanel>

</MudTabs>

@code {
    private CharacterSnapshot? _snap;
    private CharacterTab? _tab;
    private EditableCharacterInfoModel? _infoModel;
    private bool _optionSaving;
    private IReadOnlyList<SourceRestrictionGroupModel> SourceGroups =>
        CharacterManager.Current.SourcesManager.SourceGroups.Select(ToGroupModel).ToList();

    protected override void OnInitialized()
    {
        Tabs.TabsChanged += OnTabsChanged;
        LoadFromActiveTab();
    }

    private void LoadFromActiveTab()
    {
        _tab = Tabs.ActiveTab;
        _snap = _tab?.Snapshot;
        _infoModel = _snap is null ? null : ToInfoModel(_snap);
    }

    private bool _disposed;

    private void OnTabsChanged()
    {
        if (_disposed) return;
        _ = InvokeAsync(() =>
        {
            if (_disposed) return;
            LoadFromActiveTab();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        _disposed = true;
        Tabs.TabsChanged -= OnTabsChanged;
    }

    private async Task SetOptionAsync(bool enabled, string which)
    {
        if (_tab is not { } tab) return;
        _optionSaving = true;
        StateHasChanged();
        var error = which switch
        {
            "feats"        => await BuildService.SetFeatsOptionAsync(tab, enabled),
            "multiclassing"=> await BuildService.SetMulticlassingOptionAsync(tab, enabled),
            "origin"       => await BuildService.SetCustomOriginOptionAsync(tab, enabled),
            "language"     => await BuildService.SetCustomLanguageOptionAsync(tab, enabled),
            "proficiency"  => await BuildService.SetCustomProficiencyOptionAsync(tab, enabled),
            _              => "Unknown option."
        };
        _optionSaving = false;
        if (error != null)
            Snackbar.Add($"Failed to update option: {error}", Severity.Error);
        StateHasChanged();
    }

    private Task MarkDirty()
    {
        if (_tab is { } tab && _snap is not null && _infoModel is not null)
        {
            ApplyInfoModel(_infoModel, _snap);
            Tabs.MarkDirty(tab);
        }

        return Task.CompletedTask;
    }

    private async Task ToggleGroupInternal(SourcesGroup group)
    {
        if (!group.AllowUnchecking)
        {
            Snackbar.Add("That source group is required and can't be disabled.", Severity.Info, cfg => cfg.VisibleStateDuration = 2500);
            return;
        }
        group.SetIsChecked(group.IsChecked == true ? false : (bool?)true, updateChildren: true);
        await ApplyAndPersistRestrictions();
    }

    private async Task ToggleSourceInternal(SourceItem item)
    {
        if (!item.AllowUnchecking)
        {
            Snackbar.Add("That source is required and can't be disabled.", Severity.Info, cfg => cfg.VisibleStateDuration = 2500);
            return;
        }
        item.SetIsChecked(item.IsChecked != true, updateChildren: true, updateParent: true);
        await ApplyAndPersistRestrictions();
    }

    private async Task ApplyAndPersistRestrictions()
    {
        if (_tab is not { } tab)
        {
            Snackbar.Add("Source restrictions cannot be changed because there is no active character.", Severity.Warning, cfg => cfg.VisibleStateDuration = 2500);
            return;
        }
        using var scope = await CharacterContext.EnterAsync(tab);

        CharacterManager.Current.SourcesManager.ApplyRestrictions(reprocess: true);
        if (!await PersistSourceRestrictionsAsync(tab)) return;
        _ = MarkDirty();

        StateHasChanged();
    }


    private async Task ToggleGroupAsync(string groupId)
    {
        SourcesGroup? group = CharacterManager.Current.SourcesManager.SourceGroups
            .FirstOrDefault(candidate => string.Equals(candidate.Name, groupId, StringComparison.Ordinal));
        if (group is not null)
        {
            await ToggleGroupInternal(group);
        }
        else
        {
            Snackbar.Add("That source group could not be found.", Severity.Warning, cfg => cfg.VisibleStateDuration = 2500);
        }
    }

    private async Task ToggleSourceAsync(string sourceId)
    {
        SourceItem? item = CharacterManager.Current.SourcesManager.SourceGroups
            .SelectMany(group => group.Sources)
            .FirstOrDefault(candidate => string.Equals(candidate.Source.Id, sourceId, StringComparison.Ordinal));
        if (item is not null)
        {
            await ToggleSourceInternal(item);
        }
        else
        {
            Snackbar.Add("That source could not be found.", Severity.Warning, cfg => cfg.VisibleStateDuration = 2500);
        }
    }

    private async Task LoadDefaultAsync()
    {
        if (_tab is not { } tab)
        {
            Snackbar.Add("Default sources cannot be loaded because there is no active character.", Severity.Warning, cfg => cfg.VisibleStateDuration = 2500);
            return;
        }
        using var scope = await CharacterContext.EnterAsync(tab);

        CharacterManager.Current.SourcesManager.LoadDefaults();
        if (!await PersistSourceRestrictionsAsync(tab)) return;
        _ = MarkDirty();

        StateHasChanged();
    }

    private void SaveAsDefault()
    {
        CharacterManager.Current.SourcesManager.StoreDefaults();
        Snackbar.Add("Saved current source selections as the default set.", Severity.Success, cfg => cfg.VisibleStateDuration = 2200);
    }

    private static EditableCharacterInfoModel ToInfoModel(CharacterSnapshot snap) =>
        new()
        {
            Name = snap.Name,
            PlayerName = snap.PlayerName,
            Experience = snap.Experience,
            Deity = snap.Deity,
            Alignment = snap.Alignment,
            Age = snap.Age,
            Gender = snap.Gender,
            Height = snap.Height,
            Weight = snap.Weight,
            Eyes = snap.Eyes,
            Hair = snap.Hair,
            Skin = snap.Skin,
            Backstory = snap.Backstory,
            Organisation = snap.Organisation,
            Allies = snap.Allies,
            Trinket = snap.Trinket,
            Notes1 = snap.Notes1,
            Notes2 = snap.Notes2
        };

    private static void ApplyInfoModel(EditableCharacterInfoModel model, CharacterSnapshot snap)
    {
        snap.Name = model.Name;
        snap.PlayerName = model.PlayerName;
        snap.Experience = model.Experience;
        snap.Deity = model.Deity;
        snap.Alignment = model.Alignment;
        snap.Age = model.Age;
        snap.Gender = model.Gender;
        snap.Height = model.Height;
        snap.Weight = model.Weight;
        snap.Eyes = model.Eyes;
        snap.Hair = model.Hair;
        snap.Skin = model.Skin;
        snap.Backstory = model.Backstory;
        snap.Organisation = model.Organisation;
        snap.Allies = model.Allies;
        snap.Trinket = model.Trinket;
        snap.Notes1 = model.Notes1;
        snap.Notes2 = model.Notes2;
    }

    private static SourceRestrictionGroupModel ToGroupModel(SourcesGroup group) =>
        new(
            group.Name,
            group.Name,
            group.Underline,
            group.AllowUnchecking,
            group.IsChecked,
            group.Sources.Select(item => new SourceRestrictionItemModel(
                item.Source.Id,
                item.Source.Name ?? string.Empty,
                item.IsChecked,
                item.AllowUnchecking,
                !item.AllowUnchecking)).ToList());

    private async Task<bool> PersistSourceRestrictionsAsync(CharacterTab tab)
    {
        var result = await CharacterFileWriteCoordinator.WriteAsync(
            tab.FileSaveSemaphore,
            tab.File,
            "Source restrictions",
            () => tab.File.SaveSourceRestrictions());

        if (result.Succeeded)
            return true;

        if (result.IsExternalChange)
        {
            Snackbar.Add(
                "The character file changed on disk. Reloaded the character instead of overwriting those source changes.",
                Severity.Warning,
                cfg => cfg.VisibleStateDuration = 7000);
            await ReloadAfterExternalChangeAsync(tab);
            return false;
        }

        if (result.Exception is not null)
            DebugLog.LogException(result.Exception, "Manage.PersistSourceRestrictionsAsync");

        Snackbar.Add(
            $"Source restrictions changed in memory, but could not be written to the character file yet. {result.Message}",
            Severity.Warning,
            cfg => cfg.VisibleStateDuration = 7000);
        return true;
    }

    private async Task ReloadAfterExternalChangeAsync(CharacterTab tab)
    {
        try
        {
            await CharacterContext.ReloadFromDiskAsync(tab);
            BuildService.ResnapTab(tab);
            LoadFromActiveTab();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            DebugLog.LogException(ex, "Manage.ReloadAfterExternalChangeAsync");
            Snackbar.Add(
                "The character file changed on disk, but Reflections could not reload it automatically. Close and reopen the character before changing sources.",
                Severity.Error,
                cfg => cfg.VisibleStateDuration = 9000);
        }
    }
}
