<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-size: 15px; font-weight: 600;">New Character</MudText>
    </TitleContent>
    <DialogContent>
        <div class="new-character-dialog-content">
            <CharacterCreationFields Model="_model"
                                     NamePlaceholder="Character Name"
                                     PlayerNamePlaceholder="Player Name"
                                     OnKeyDown="OnKeyDown" />
            @if (_nameError != null)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_nameError</MudAlert>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Confirm"
                   Disabled="@string.IsNullOrWhiteSpace(_model.Name)">
            Create
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    private readonly CharacterCreationModel _model = new();
    private string? _nameError;

    private static readonly HashSet<char> _invalidChars = new(Path.GetInvalidFileNameChars());

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_model.Name))
            Confirm();
    }

    private void Cancel() => MudDialog.Cancel();

    private void Confirm()
    {
        var name = _model.Name.Trim();
        var bad  = name.Where(c => _invalidChars.Contains(c)).Distinct().ToArray();
        if (bad.Length > 0)
        {
            _nameError = $"Name cannot contain: {string.Join("  ", bad)}";
            return;
        }
        _nameError = null;
        MudDialog.Close(new NewCharacterInfo(name, _model.PlayerName.Trim()));
    }
}
