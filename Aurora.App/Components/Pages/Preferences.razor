@page "/preferences"
@inject NavigationManager Nav

<MudText Typo="Typo.h6" Class="mb-2">Redirecting to Settings...</MudText>
<MudText Color="Color.Secondary">Preferences are now part of the unified Settings page.</MudText>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        Nav.NavigateTo("/settings", replace: true);
    }
}
