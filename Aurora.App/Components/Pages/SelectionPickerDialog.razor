<MudDialog Style="max-height: 90vh; width: min(700px, 95vw);">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-size: 15px; font-weight: 600;">@Entry.Label</MudText>
    </TitleContent>
    <DialogContent>
        <div class="picker-layout">
            @* ── Left: search + list ── *@
            <div class="picker-left @(IsSpellRule ? "picker-has-filters" : "")">
                <MudTextField @bind-Value="_search"
                              Placeholder="Search…"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Clearable="true"
                              Immediate="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="mb-n2" />

                @if (IsSpellRule)
                {
                    <button type="button"
                            class="picker-filter-toggle @(HasActiveFilters ? "picker-filter-toggle-active" : string.Empty)"
                            @onclick="() => _filtersExpanded = !_filtersExpanded">
                        <span>Filters@(HasActiveFilters ? " ●" : string.Empty)</span>
                        <span class="picker-filter-chevron @(_filtersExpanded ? "open" : string.Empty)">▾</span>
                    </button>
                    @if (_filtersExpanded)
                    {
                        <div class="picker-filters">
                            <select class="picker-filter-select"
                                    value="@_levelFilter"
                                    @onchange="e => { _levelFilter = e.Value?.ToString() ?? string.Empty; RebuildFilter(); }">
                                <option value="">All levels</option>
                                <option value="0">Cantrip</option>
                                @for (int i = 1; i <= 9; i++)
                                {
                                    <option value="@i">@SpellLevelLabel(i)</option>
                                }
                            </select>
                            <select class="picker-filter-select"
                                    value="@_schoolFilter"
                                    @onchange="e => { _schoolFilter = e.Value?.ToString() ?? string.Empty; RebuildFilter(); }">
                                <option value="">All schools</option>
                                @foreach (string school in AvailableSchools)
                                {
                                    <option value="@school">@school</option>
                                }
                            </select>
                            <div class="picker-filter-checks">
                                <label class="picker-filter-check">
                                    <input type="checkbox" @bind="_ritualFilter" @bind:after="RebuildFilter" />
                                    <span>Ritual</span>
                                </label>
                                <label class="picker-filter-check">
                                    <input type="checkbox" @bind="_concentrationFilter" @bind:after="RebuildFilter" />
                                    <span>Conc.</span>
                                </label>
                            </div>
                        </div>
                    }
                }

                @if (_filtered.Count == 0)
                {
                    <MudText Color="Color.Secondary" Style="padding: 12px 0; font-size: 13px;">
                        No options found.
                    </MudText>
                }
                else
                {
                    <div class="picker-list">
                        @foreach (var opt in _filtered)
                        {
                            var isSelected = opt.Id == _selectedId;
                            <div class="picker-item @(isSelected ? "picker-item-selected" : "")"
                                 @onclick="() => SelectItem(opt)"
                                 @ondblclick="() => ConfirmItem(opt)">
                                <div class="picker-item-name">@opt.Name</div>
                            </div>
                        }
                    </div>
                }
            </div>

            @* ── Right: detail panel ── *@
            <div class="picker-detail">
                @if (_selectedOpt != null)
                {
                    <div class="picker-detail-name">@_selectedOpt.Name</div>
                    @if (!string.IsNullOrEmpty(_selectedOpt.Source))
                    {
                        <div class="picker-detail-source">@_selectedOpt.Source</div>
                    }
                    @if (!string.IsNullOrEmpty(_selectedOpt.Requirements))
                    {
                        <div class="picker-detail-req">Requires: @_selectedOpt.Requirements</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_selectedOpt.Description))
                    {
                        <div class="picker-detail-desc">@_selectedOpt.Description</div>
                    }
                    else
                    {
                        <div class="picker-detail-empty">No description available.</div>
                    }
                }
                else
                {
                    <div class="picker-detail-empty">Select an option to see details.</div>
                }
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Confirm"
                   Disabled="@(_selectedId == null)">
            Select
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public SelectionRuleEntry Entry    { get; set; } = null!;
    [Parameter] public IReadOnlyList<ElementOption> Options { get; set; } = [];

    private string _search
    {
        get => _searchValue;
        set { _searchValue = value; RebuildFilter(); }
    }
    private string _searchValue = "";
    private string _levelFilter = "";
    private string _schoolFilter = "";
    private bool _ritualFilter;
    private bool _concentrationFilter;
    private bool _filtersExpanded;
    private string?        _selectedId;
    private ElementOption? _selectedOpt;
    private List<ElementOption> _filtered = [];

    private bool IsSpellRule =>
        Entry?.Rule?.Attributes?.Type?.Equals("Spell", StringComparison.OrdinalIgnoreCase) == true;

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(_levelFilter) ||
        !string.IsNullOrWhiteSpace(_schoolFilter) ||
        _ritualFilter ||
        _concentrationFilter;

    private IReadOnlyList<string> _availableSchools = [];
    private IReadOnlyList<string> AvailableSchools => _availableSchools;

    private void RebuildFilter()
    {
        _filtered = Options.Where(o =>
        {
            if (!string.IsNullOrWhiteSpace(_searchValue) &&
                !o.Name.Contains(_searchValue, StringComparison.OrdinalIgnoreCase) &&
                !o.Description.Contains(_searchValue, StringComparison.OrdinalIgnoreCase))
                return false;

            if (IsSpellRule)
            {
                if (!string.IsNullOrWhiteSpace(_levelFilter) &&
                    int.TryParse(_levelFilter, out int lvl) && o.SpellLevel != lvl)
                    return false;
                if (!string.IsNullOrWhiteSpace(_schoolFilter) &&
                    !string.Equals(o.School, _schoolFilter, StringComparison.OrdinalIgnoreCase))
                    return false;
                if (_ritualFilter && !o.IsRitual)
                    return false;
                if (_concentrationFilter && !o.IsConcentration)
                    return false;
            }

            return true;
        }).ToList();
    }

    private static string SpellLevelLabel(int level) => level switch
    {
        1 => "1st level",
        2 => "2nd level",
        3 => "3rd level",
        _ => $"{level}th level",
    };

    protected override void OnParametersSet()
    {
        _availableSchools = Options
            .Where(o => !string.IsNullOrWhiteSpace(o.School))
            .Select(o => o.School)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(s => s)
            .ToList();
        RebuildFilter();
        if (Entry.CurrentName != null)
        {
            var current = Options.FirstOrDefault(o =>
                string.Equals(o.Name, Entry.CurrentName, StringComparison.OrdinalIgnoreCase));
            if (current != null)
                SelectItem(current);
        }
    }

    private void SelectItem(ElementOption opt)
    {
        _selectedId  = opt.Id;
        _selectedOpt = opt;
    }

    private void Cancel()      => MudDialog.Cancel();
    private void Confirm()     { if (_selectedId != null) MudDialog.Close(_selectedId); }
    private void ConfirmItem(ElementOption opt) { SelectItem(opt); Confirm(); }
}
