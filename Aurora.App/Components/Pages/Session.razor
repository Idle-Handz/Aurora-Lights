    // ── Currency ─────────────────────────────────────────────────────────────

    private void OnCoinChanged(string coinId, ChangeEventArgs e)
    {
        if (_snap is null) return;
        if (!long.TryParse(e.Value?.ToString(), out long val)) return;
        val = Math.Max(0, val);
        switch (coinId)
        {
            case "cp": _snap.CoinCopper   = val; break;
            case "sp": _snap.CoinSilver   = val; break;
            case "ep": _snap.CoinElectrum = val; break;
            case "gp": _snap.CoinGold     = val; break;
            case "pp": _snap.CoinPlatinum = val; break;
        }
        // Write through to the model (like OnNotesInput): ResnapTab rebuilds the snapshot
        // from the Character, so snapshot-only edits would be reverted by a level-up or
        // any other full save.
        if (_tab?.Character is { } ch)
            ch.Inventory.Coins.Set(_snap.CoinCopper, _snap.CoinSilver, _snap.CoinElectrum, _snap.CoinGold, _snap.CoinPlatinum);
        PersistSessionChanges();
    }

    // ── Persistence ───────────────────────────────────────────────────────────

    private void AutoSave()
    {
        PersistSessionChanges();
    }

    private void SaveSession()
    {
        if (PersistSessionChanges())
        {
            Snackbar.Add("Session saved.", Severity.Success);
        }
    }

    private void OnNotesInput(int field, string value)
    {
        if (_snap is null) return;
        if (field == 1) _snap.Notes1 = value;
        else            _snap.Notes2 = value;
        if (_tab?.Character is { } ch)
        {
            if (field == 1) ch.Notes1 = value;
            else            ch.Notes2 = value;
        }
    }

    private void SaveNotesInput(int field, string value)
    {
        OnNotesInput(field, value);
        AutoSave();
    }

    private bool PersistSessionChanges()
    {
        if (_tab is null || _snap is null) return false;

        // The sidecar is a separate file — no write gate needed; saves immediately.
        var sessionSaved = SessionStore.Save(_tab.File.FilePath, _s);

        // XML patch saves (currency, notes) must not interleave with a background full save's
        // SaveTextEdits. Fire them on a background task so we can await the shared write
        // coordinator without blocking the UI thread.
        var tab  = _tab;
        var snap = _snap;
        _ = Task.Run(async () =>
        {
            var result = await CharacterFileWriteCoordinator.WriteAsync(
                tab.FileSaveSemaphore,
                tab.File,
                "Session currency and notes",
                () => tab.File.SaveCurrency(snap) && tab.File.SaveNotes(snap));

            if (!result.Succeeded && !_disposed)
                await InvokeAsync(() => HandleSessionPatchFailureAsync(tab, result));
        });

        if (sessionSaved)
        {
            _saveError = null;
            return true;
        }

        _saveError = "Some session changes could not be saved yet. Your current values are still in memory, but please try saving again after resolving any file access issues.";
        Snackbar.Add(_saveError, Severity.Error);
        _ = InvokeAsync(StateHasChanged);
        return false;
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private async Task HandleSessionPatchFailureAsync(CharacterTab tab, CharacterFileWriteResult result)
    {
        if (_disposed) return;

        if (result.IsExternalChange)
        {
            Snackbar.Add(
                "Session saved, but the character file changed on disk. Reloaded the character instead of overwriting notes or currency.",
                Severity.Warning,
                cfg => cfg.VisibleStateDuration = 7000);

            if (_tab == tab)
                await ReloadAfterExternalChangeAsync(tab);
            return;
        }

        if (result.Exception is not null)
            DebugLogService.Instance.LogException(result.Exception, "Session.PersistSessionChanges");

        Snackbar.Add(
            $"Session saved, but currency and notes could not be written to the character file. {result.Message}",
            Severity.Warning,
            cfg => cfg.VisibleStateDuration = 7000);
    }

    private async Task ReloadAfterExternalChangeAsync(CharacterTab tab)
    {
        try
        {
            using var scope = await CharacterContext.EnterAsync(tab);
            await CharacterContext.ReloadFromDiskAsync(tab);
            BuildService.ResnapTab(tab);
            Refresh();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            DebugLogService.Instance.LogException(ex, "Session.ReloadAfterExternalChangeAsync");
            Snackbar.Add(
                "The character file changed on disk, but Reflections could not reload it automatically. Close and reopen the character before making more session changes.",
                Severity.Error,
                cfg => cfg.VisibleStateDuration = 9000);
        }
    }

    private static string ExhaustionTooltip(int level) => level switch
    {
        1 => "Level 1: Disadvantage on ability checks",
        2 => "Level 2: Speed halved",
        3 => "Level 3: Disadvantage on attack rolls and saving throws",
        4 => "Level 4: Hit point maximum halved",
        5 => "Level 5: Speed reduced to 0",
        6 => "Level 6: Death",
        _ => $"Exhaustion level {level}"
    };

    private static string OrdinalLevel(int level) => level switch
    {
        1 => "1st",
        2 => "2nd",
        3 => "3rd",
        _ => $"{level}th"
    };

    private static string ResetLabel(ResetOn r) => r switch
    {
        ResetOn.LongRest  => "LR",
        ResetOn.ShortRest => "SR",
        _                 => "Manual"
    };
