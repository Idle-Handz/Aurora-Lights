@page "/session"
@implements IDisposable
@inject CharacterTabService Tabs
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using Builder.Presentation.Models

@if (_tab is null || _snap is null)
{
    <div style="margin-top: 24px;">
        <MudText Color="Color.Secondary">No character loaded. Open a character from the <MudLink Href="/">Characters</MudLink> page.</MudText>
    </div>
    return;
}

<div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 16px;">
    <div class="page-header-row">
        <MudText Typo="Typo.h6" Style="margin: 0;">@_snap.Name</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="margin: 0;">
            Level @_snap.Level @_snap.Race @_snap.Class
        </MudText>
    </div>
    <MudTooltip Text="Save session">
        <MudIconButton Icon="@Icons.Material.Filled.Save"
                       Size="Size.Small"
                       Color="Color.Primary"
                       OnClick="SaveSession"
                       Style="margin-top: 2px;" />
    </MudTooltip>
</div>

<div class="combat-strip session-combat-strip">
    <div class="combat-stat">
        <div class="combat-stat-value">@_snap.ArmorClass</div>
        <div class="combat-stat-label">AC</div>
    </div>
    <div class="combat-sep"></div>
    <div class="combat-stat">
        <div class="combat-stat-value">@FormatBonus(_snap.Initiative)</div>
        <div class="combat-stat-label">Initiative</div>
    </div>
    <div class="combat-sep"></div>
    <div class="combat-stat">
        <div class="combat-stat-value">@FormatBonus(_snap.Proficiency)</div>
        <div class="combat-stat-label">Proficiency</div>
    </div>
    <div class="combat-sep"></div>
    <div class="combat-stat">
        <div class="combat-stat-value">@_snap.Speed ft.</div>
        <div class="combat-stat-label">Speed</div>
    </div>
</div>

<div class="session-card">
    <div class="session-card-title-row">
        <div class="session-card-title">Attack Reminders</div>
        <MudMenu Icon="@Icons.Material.Filled.AddCircleOutline"
                 Size="Size.Small"
                 Dense="true"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight">
            @if (_availableAttackReminders.Count == 0)
            {
                <MudMenuItem Disabled="true">No inventory weapon reminders</MudMenuItem>
            }
            else
            {
                @foreach (var reminder in _availableAttackReminders)
                {
                    var row = reminder;
                    <MudMenuItem OnClick="() => AddAttackReminder(row)">
                        @row.Name
                    </MudMenuItem>
                }
            }
            <MudDivider />
            <MudMenuItem OnClick="OpenAddCustomAttackReminderDialog">Custom reminder...</MudMenuItem>
        </MudMenu>
    </div>

    @if (_attackReminders.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-size: 12px;">
            No attack reminders shown. Add a weapon from inventory, or add unarmed/racial attacks on the Equipment page.
        </MudText>
    }
    else
    {
        <div class="session-attack-table">
            <div class="session-attack-row session-attack-header">
                <span>Name</span>
                <span>Attack</span>
                <span>Damage</span>
                <span>Range</span>
                <span></span>
            </div>
            @foreach (var reminder in _attackReminders)
            {
                var row = reminder;
                <div class="session-attack-row">
                    <span>@row.Name</span>
                    <span>@row.Attack</span>
                    <span>@row.Damage</span>
                    <span>@row.Range</span>
                    <span class="session-attack-actions">
                        @if (row.IsCustom)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           Color="Color.Secondary"
                                           title="Edit reminder"
                                           OnClick="() => OpenEditCustomAttackReminderDialog(row)" />
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                       Size="Size.Small"
                                       Color="Color.Secondary"
                                       title="Remove reminder"
                                       OnClick="() => RemoveAttackReminder(row)" />
                    </span>
                </div>
            }
        </div>
    }
</div>

<div class="detail-advancement-strip">
    <div class="detail-advancement-meta">
        <div class="section-label" style="margin-bottom: 6px;">Advancement</div>
        <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-disabled);">
            Level @_snap.Level
            @if (!BuildService.CanLevelUp)   { <span> · Max level</span>   }
            @if (!BuildService.CanLevelDown) { <span> · Level 1 min</span> }
        </MudText>
    </div>
    <div class="detail-advancement-actions">
        <MudButton StartIcon="@Icons.Material.Filled.Add"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Small"
                   Disabled="@(!BuildService.CanLevelUp || _advancementBusy)"
                   OnClick="LevelUpAsync">
            Level Up
        </MudButton>

        <MudButton StartIcon="@Icons.Material.Filled.Remove"
                   Variant="Variant.Outlined"
                   Color="Color.Default"
                   Size="Size.Small"
                   Disabled="@(!BuildService.CanLevelDown || _advancementBusy)"
                   OnClick="LevelDownAsync">
            Level Down
        </MudButton>

        @if (BuildService.HasMainClass && BuildService.CanLevelUp)
        {
            <MudButton StartIcon="@Icons.Material.Filled.MergeType"
                       Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Size="Size.Small"
                       Disabled="@_advancementBusy"
                       OnClick="OpenMulticlassDialog">
                Add Multiclass
            </MudButton>
        }
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_saveError))
{
    <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Outlined" Style="margin-bottom: 16px;">
        @_saveError
    </MudAlert>
}

@* ── HP + Status side by side ── *@
<div class="session-pair-row">

@* HP Row *@
<div class="session-card">
    <div class="session-card-title">Hit Points</div>
    <div class="session-hp-row">
        @* Current HP *@
        <div class="session-hp-block">
            <div class="session-hp-label">Current</div>
            <div class="session-hp-controls">
                <button class="session-hp-btn" @onclick="() => AdjustHp(-1)">−</button>
                <input class="session-hp-input" type="number"
                       value="@_s.CurrentHp"
                       min="0" max="@(_snap.MaxHp + _s.TempHp)"
                       @onchange="OnCurrentHpChanged" />
                <button class="session-hp-btn" @onclick="() => AdjustHp(+1)">+</button>
            </div>
            <div class="session-hp-max">/ @_snap.MaxHp</div>
        </div>

        <div class="session-hp-sep"></div>

        @* Temp HP *@
        <div class="session-hp-block">
            <div class="session-hp-label">Temp</div>
            <div class="session-hp-controls">
                <button class="session-hp-btn" @onclick="() => AdjustTempHp(-1)">−</button>
                <input class="session-hp-input" type="number"
                       value="@_s.TempHp"
                       min="0" max="999"
                       @onchange="OnTempHpChanged" />
                <button class="session-hp-btn" @onclick="() => AdjustTempHp(+1)">+</button>
            </div>
        </div>
    </div>

</div>

@* Status *@
<div class="session-card">
    <div class="session-card-title">Status</div>
    <div class="session-status-row">

        @* Inspiration *@
        <button class="session-inspiration-btn @(_s.Inspiration ? "inspiration-on" : "")"
                @onclick="ToggleInspiration">
            <span class="inspiration-star">★</span>
            Inspiration
        </button>

        @* Exhaustion *@
        <div class="session-exhaustion-block">
            <div class="session-status-label">Exhaustion</div>
            <div class="session-pips">
                @for (int i = 1; i <= 6; i++)
                {
                    var lvl = i;
                    <button class="session-pip @(lvl <= _s.Exhaustion ? "pip-exhaustion" : "pip-empty")"
                            title="@ExhaustionTooltip(lvl)"
                            @onclick="() => SetExhaustion(lvl)"></button>
                }
            </div>
            @if (_s.Exhaustion > 0)
            {
                <div class="session-exhaustion-label">Level @_s.Exhaustion</div>
            }
        </div>

        @* Death saves *@
        <div class="session-death-row">
            <div class="session-death-block">
                <div class="session-death-label" style="color: var(--mud-palette-success);">Saves</div>
                <div class="session-pips">
                    @for (int i = 1; i <= 3; i++)
                    {
                        var idx = i;
                        <button class="session-pip @(idx <= _s.DeathSaveSuccesses ? "pip-success" : "pip-empty")"
                                title="Death save success @idx of 3 (3 successes = stabilize)"
                                @onclick="() => ToggleDeathSuccess(idx)"></button>
                    }
                </div>
            </div>
            <div class="session-death-block">
                <div class="session-death-label" style="color: var(--mud-palette-error);">Fails</div>
                <div class="session-pips">
                    @for (int i = 1; i <= 3; i++)
                    {
                        var idx = i;
                        <button class="session-pip @(idx <= _s.DeathSaveFailures ? "pip-failure" : "pip-empty")"
                                title="Death save failure @idx of 3 (3 failures = death)"
                                @onclick="() => ToggleDeathFailure(idx)"></button>
                    }
                </div>
            </div>
        </div>
    </div>

    @* Conditions *@
    <div class="session-conditions-row" style="margin-top: 10px;">
        <div class="session-status-label" style="margin-bottom: 6px;">Conditions</div>
        <div class="session-conditions-list">
            @foreach (var cond in _s.Conditions.ToList())
            {
                var c = cond;
                <div class="session-condition-chip">
                    @c
                    <button class="session-condition-remove" @onclick="() => RemoveCondition(c)">×</button>
                </div>
            }
            <MudMenu Icon="@Icons.Material.Filled.Add"
                     Size="Size.Small"
                     Dense="true"
                     AnchorOrigin="Origin.BottomLeft"
                     TransformOrigin="Origin.TopLeft">
                @foreach (var cond in _allConditions)
                {
                    var c = cond;
                    <MudMenuItem Disabled="@_s.Conditions.Contains(c)"
                                 OnClick="() => AddCondition(c)">@c</MudMenuItem>
                }
            </MudMenu>
        </div>
    </div>
</div>

</div>@* end session-pair-row *@

@* ── Currency ── *@
<div class="session-card">
    <div class="session-card-title">Currency</div>
    <div class="session-currency-strip">
        <label class="session-coin-cell">
            <input class="session-coin-input" type="number" min="0"
                   value="@_snap.CoinCopper"
                   @onchange='e => OnCoinChanged("cp", e)' />
            <span class="session-coin-label">CP</span>
        </label>
        <label class="session-coin-cell">
            <input class="session-coin-input" type="number" min="0"
                   value="@_snap.CoinSilver"
                   @onchange='e => OnCoinChanged("sp", e)' />
            <span class="session-coin-label">SP</span>
        </label>
        <label class="session-coin-cell">
            <input class="session-coin-input" type="number" min="0"
                   value="@_snap.CoinElectrum"
                   @onchange='e => OnCoinChanged("ep", e)' />
            <span class="session-coin-label">EP</span>
        </label>
        <label class="session-coin-cell">
            <input class="session-coin-input" type="number" min="0"
                   value="@_snap.CoinGold"
                   @onchange='e => OnCoinChanged("gp", e)' />
            <span class="session-coin-label">GP</span>
        </label>
        <label class="session-coin-cell">
            <input class="session-coin-input" type="number" min="0"
                   value="@_snap.CoinPlatinum"
                   @onchange='e => OnCoinChanged("pp", e)' />
            <span class="session-coin-label">PP</span>
        </label>
    </div>
</div>

@* ── Spell Slots ── *@
@if (_spellLevels.Count > 0)
{
    <div class="session-card">
        <div class="session-card-title">Spell Slots</div>
        @if (!string.IsNullOrWhiteSpace(_spellcastingSummary))
        {
            <div class="session-status-label" style="margin-bottom: 8px;">@_spellcastingSummary</div>
        }
        <div class="session-slots-grid">
            @foreach (var entry in _spellLevels)
            {
                var level = entry.Level;
                var total = entry.TotalSlots;
                var used = ClampSlotUsage(level, total);
                <div class="session-slot-row">
                    <div class="session-slot-label">@OrdinalLevel(level)</div>
                    <div class="session-pips">
                        @for (int i = 1; i <= total; i++)
                        {
                            var idx = i;
                            <button class="session-pip @(idx <= used ? "pip-slot-used" : "pip-slot-free")"
                                    @onclick="() => ToggleSlot(level, idx)"></button>
                        }
                    </div>
                    <div class="session-slot-count">@(total - used)/@total</div>
                </div>
            }
        </div>
    </div>
}

@* ── Custom Resources ── *@
<div class="session-card">
    <div class="session-card-title-row">
        <div class="session-card-title">Resources</div>
        <MudIconButton Icon="@Icons.Material.Filled.AddCircleOutline"
                       Size="Size.Small"
                       OnClick="OpenAddResourceDialog"
                       Style="color: var(--mud-palette-primary); padding: 2px;" />
    </div>

    @if (_s.CustomResources.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-size: 12px;">
            No resources tracked. Use + to add Bardic Inspiration, Ki Points, etc.
        </MudText>
    }
    else
    {
        <div class="session-resources-list">
            @foreach (var res in _s.CustomResources.ToList())
            {
                var r = res;
                <div class="session-resource-row">
                    <div class="session-resource-name">
                        @r.Name
                        <span class="session-resource-reset">(@ResetLabel(r.ResetOn))</span>
                    </div>
                    @if (r.UseNumeric)
                    {
                        <div class="session-resource-numeric">
                            <button class="session-hp-btn" @onclick="() => AdjustResource(r, -1)">−</button>
                            <span class="session-resource-val">@r.Remaining/@r.Max</span>
                            <button class="session-hp-btn" @onclick="() => AdjustResource(r, +1)">+</button>
                        </div>
                    }
                    else
                    {
                        <div class="session-pips">
                            @for (int i = 1; i <= r.Max; i++)
                            {
                                var idx = i;
                                <button class="session-pip @(idx <= r.Used ? "pip-resource-used" : "pip-slot-free")"
                                        @onclick="() => ToggleResource(r, idx)"></button>
                            }
                        </div>
                    }
                    <div class="session-resource-actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       OnClick="() => OpenEditResourceDialog(r)"
                                       Style="color: var(--mud-palette-text-disabled); padding: 2px;" />
                        <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                       Size="Size.Small"
                                       OnClick="() => RemoveResource(r)"
                                       Style="color: var(--mud-palette-text-disabled); padding: 2px;" />
                    </div>
                </div>
            }
        </div>
    }
</div>

@* ── Notes ── *@
<div class="session-card">
    <div class="session-card-title">Notes</div>
    <div class="session-notes-row">
        <textarea class="session-notes-area"
                  rows="4"
                  placeholder="Notes…"
                  value="@_snap.Notes1"
                  @oninput="args => OnNotesInput(1, args.Value?.ToString() ?? string.Empty)"
                  @onchange="args => SaveNotesInput(1, args.Value?.ToString() ?? string.Empty)"></textarea>
        <textarea class="session-notes-area"
                  rows="4"
                  placeholder="More notes…"
                  value="@_snap.Notes2"
                  @oninput="args => OnNotesInput(2, args.Value?.ToString() ?? string.Empty)"
                  @onchange="args => SaveNotesInput(2, args.Value?.ToString() ?? string.Empty)"></textarea>
    </div>
</div>

@* ── Rest Buttons ── *@
<div class="session-rest-row">
    <MudButton Variant="Variant.Outlined"
               Color="Color.Default"
               StartIcon="@Icons.Material.Filled.Bedtime"
               OnClick="DoShortRest">
        Short Rest
    </MudButton>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.NightShelter"
               OnClick="DoLongRest"
               Style="margin-left: 10px;">
        Long Rest
    </MudButton>
</div>

@code {
    private static string FormatBonus(int value) => value >= 0 ? $"+{value}" : value.ToString();

    private CharacterTab? _tab;
    private CharacterSnapshot? _snap;
    private SessionState _s = new();
    private List<SpellLevelEntry> _spellLevels = [];
    private IReadOnlyList<SessionAttackReminder> _attackReminders = [];
    private IReadOnlyList<SessionAttackReminder> _availableAttackReminders = [];
    private string _spellcastingSummary = string.Empty;
    private string? _saveError;
    private bool _advancementBusy;

    private static readonly string[] _allConditions =
    [
        "Blinded", "Charmed", "Deafened", "Frightened",
        "Grappled", "Incapacitated", "Invisible", "Paralyzed", "Petrified",
        "Poisoned", "Prone", "Restrained", "Stunned", "Unconscious"
    ];

    protected override void OnInitialized()
    {
        Tabs.TabsChanged += OnTabsChanged;
        Refresh();
    }

    private bool _disposed;

    private void OnTabsChanged()
    {
        if (_disposed) return;
        _ = InvokeAsync(() =>
        {
            if (_disposed) return;
            Refresh();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        _disposed = true;
        Tabs.TabsChanged -= OnTabsChanged;
    }

    private void Refresh()
    {
        _tab  = Tabs.ActiveTab;
        _snap = _tab?.Snapshot;
        if (_tab != null)
        {
            _s = _tab.Session;
            // Only initialise once the snapshot exists — during eager navigation the tab
            // can be present while still loading, and InitializeIfNew(0) would permanently
            // stamp CurrentHp = 0 instead of max HP.
            if (_snap != null)
                _s.InitializeIfNew(_snap.MaxHp);
        }
        _spellLevels = BuildAggregatedSpellLevels(_snap);
        var attackReminderSet = BuildAttackReminderSet();
        _attackReminders = attackReminderSet.Visible;
        _availableAttackReminders = attackReminderSet.AvailableWeapons;
        _spellcastingSummary = _snap?.SpellcastingSections.Count > 1
            ? string.Join(", ", _snap.SpellcastingSections.Select(section => section.Name).Distinct(StringComparer.OrdinalIgnoreCase))
            : string.Empty;
    }

    // ── Advancement ──────────────────────────────────────────────────────────────

    private async Task LevelUpAsync()
    {
        var tab = Tabs.ActiveTab;
        if (tab == null)
        {
            Snackbar.Add("There is no active character to level up.", Severity.Warning);
            return;
        }

        _advancementBusy = true;
        StateHasChanged();
        var (error, hpGained, isAverage) = await BuildService.LevelUpMainAsync(tab);
        _advancementBusy = false;
        if (error == null)
        {
            tab.IsNew = false;
            Tabs.MarkClean(tab);
            string hpNote = hpGained > 0
                ? $" · +{hpGained} HP ({(isAverage ? "avg" : "rolled")})"
                : "";
            Snackbar.Add($"Level {_snap?.Level + 1 ?? 0}{hpNote}", Severity.Success,
                cfg => cfg.VisibleStateDuration = 5000);
        }
        else
        {
            _saveError = error;
        }

        Refresh();
        StateHasChanged();
    }

    private async Task LevelDownAsync()
    {
        var tab = Tabs.ActiveTab;
        if (tab == null)
        {
            Snackbar.Add("There is no active character to level down.", Severity.Warning);
            return;
        }

        _advancementBusy = true;
        StateHasChanged();
        var error = await BuildService.LevelDownAsync(tab);
        _advancementBusy = false;
        if (error == null)
        {
            Tabs.MarkClean(tab);
            Snackbar.Add("Level removed.", Severity.Info, cfg => cfg.VisibleStateDuration = 2000);
        }
        else
        {
            _saveError = error;
        }

        Refresh();
        StateHasChanged();
    }

    private async Task OpenMulticlassDialog()
    {
        var tab = Tabs.ActiveTab;
        if (tab == null)
        {
            Snackbar.Add("There is no active character to multiclass.", Severity.Warning);
            return;
        }

        _advancementBusy = true;
        StateHasChanged();
        var options = await BuildService.GetAvailableMulticlassOptionsAsync(tab);
        _advancementBusy = false;
        StateHasChanged();
        if (options.Count == 0)
        {
            Snackbar.Add("No multiclass options are currently available for this character.", Severity.Warning);
            return;
        }

        var fakeEntry = new SelectionRuleEntry(
            Rule: null!,
            Number: 1,
            Label: "Add Multiclass",
            CurrentName: null,
            RequiredLevel: 0);

        var parameters = new DialogParameters
        {
            [nameof(SelectionPickerDialog.Entry)]   = fakeEntry,
            [nameof(SelectionPickerDialog.Options)] = options,
        };
        var dialogOptions = new DialogOptions
        {
            MaxWidth         = MaxWidth.Large,
            FullWidth        = true,
            CloseOnEscapeKey = true,
        };

        var dialog = await DialogService.ShowAsync<SelectionPickerDialog>("Add Multiclass", parameters, dialogOptions);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string selectedId })
        {
            _advancementBusy = true;
            _saveError = null;
            StateHasChanged();
            var error = await BuildService.AddMulticlassLevelAsync(tab, selectedId);
            _advancementBusy = false;
            if (error == null)
            {
                Tabs.MarkClean(tab);
                Snackbar.Add("Multiclass added.", Severity.Success, cfg => cfg.VisibleStateDuration = 2000);
            }
            else
            {
                _saveError = error;
            }

            Refresh();
            StateHasChanged();
        }
    }

    // ── HP ────────────────────────────────────────────────────────────────────

    private void AdjustHp(int delta)
    {
        _s.CurrentHp = Math.Clamp(_s.CurrentHp + delta, 0, CurrentHpMaximum);
        AutoSave();
    }

    private void AdjustTempHp(int delta)
    {
        _s.TempHp = Math.Max(0, _s.TempHp + delta);
        ClampCurrentHp();
        AutoSave();
    }

    private void OnCurrentHpChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
        {
            _s.CurrentHp = Math.Clamp(v, 0, CurrentHpMaximum);
            AutoSave();
        }
    }

    private void OnTempHpChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
        {
            _s.TempHp = Math.Max(0, v);
            ClampCurrentHp();
            AutoSave();
        }
    }

    private int CurrentHpMaximum => Math.Max(0, (_snap?.MaxHp ?? 0) + _s.TempHp);

    private void ClampCurrentHp()
    {
        _s.CurrentHp = Math.Clamp(_s.CurrentHp, 0, CurrentHpMaximum);
    }

    // ── Death saves ───────────────────────────────────────────────────────────

    private void ToggleDeathSuccess(int idx)
    {
        _s.DeathSaveSuccesses = _s.DeathSaveSuccesses == idx ? idx - 1 : idx;
        AutoSave();
    }

    private void ToggleDeathFailure(int idx)
    {
        _s.DeathSaveFailures = _s.DeathSaveFailures == idx ? idx - 1 : idx;
        AutoSave();
    }

    // ── Status ────────────────────────────────────────────────────────────────

    private void ToggleInspiration()
    {
        _s.Inspiration = !_s.Inspiration;
        AutoSave();
    }

    private void SetExhaustion(int lvl)
    {
        _s.Exhaustion = _s.Exhaustion == lvl ? lvl - 1 : lvl;
        AutoSave();
    }

    private void AddCondition(string cond)
    {
        if (!_s.Conditions.Contains(cond)) { _s.Conditions.Add(cond); AutoSave(); }
    }

    private void RemoveCondition(string cond)
    {
        _s.Conditions.Remove(cond);
        AutoSave();
    }

    // ── Spell slots ───────────────────────────────────────────────────────────

    private void ToggleSlot(int level, int idx)
    {
        var total = _spellLevels.FirstOrDefault(entry => entry.Level == level)?.TotalSlots ?? idx;
        var used = ClampSlotUsage(level, total);
        _s.SpellSlotsUsed[level] = used == idx ? idx - 1 : idx;
        AutoSave();
    }

    private int ClampSlotUsage(int level, int total)
    {
        return Math.Clamp(_s.SpellSlotsUsed.GetValueOrDefault(level, 0), 0, Math.Max(0, total));
    }

    private void AddAttackReminder(SessionAttackReminder reminder)
    {
        if (!reminder.IsWeapon || string.IsNullOrWhiteSpace(reminder.Key))
            return;

        if (!_s.AttackReminderWeaponIds.Contains(reminder.Key, StringComparer.OrdinalIgnoreCase))
            _s.AttackReminderWeaponIds.Add(reminder.Key);

        AutoSave();
        RefreshAttackReminders();
    }

    private async Task OpenAddCustomAttackReminderDialog()
    {
        var dialog = await DialogService.ShowAsync<CustomAttackReminderDialog>("Add Attack Reminder");
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: CustomAttackReminder customReminder })
        {
            _s.CustomAttackReminders.Add(customReminder);
            AutoSave();
            RefreshAttackReminders();
        }
    }

    private async Task OpenEditCustomAttackReminderDialog(SessionAttackReminder reminder)
    {
        if (reminder.CustomIdentifier is not { } customIdentifier)
            return;

        var existing = _s.CustomAttackReminders.FirstOrDefault(custom =>
            string.Equals(custom.Id, customIdentifier, StringComparison.OrdinalIgnoreCase));
        if (existing is null)
            return;

        var parameters = new DialogParameters
        {
            [nameof(CustomAttackReminderDialog.Existing)] = existing,
            [nameof(CustomAttackReminderDialog.IsEdit)] = true,
        };
        var dialog = await DialogService.ShowAsync<CustomAttackReminderDialog>("Edit Attack Reminder", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: CustomAttackReminder updated })
        {
            var index = _s.CustomAttackReminders.IndexOf(existing);
            if (index >= 0)
                _s.CustomAttackReminders[index] = updated;
            else
                _s.CustomAttackReminders.Add(updated);

            AutoSave();
            RefreshAttackReminders();
        }
    }

    private void RemoveAttackReminder(SessionAttackReminder reminder)
    {
        if (reminder.CustomIdentifier is { } customIdentifier)
        {
            _s.CustomAttackReminders.RemoveAll(custom =>
                string.Equals(custom.Id, customIdentifier, StringComparison.OrdinalIgnoreCase));
        }
        else if (reminder.IsWeapon)
        {
            bool removedLegacyWeaponSelection = false;
            if (reminder.EquipmentIdentifier is { } identifier)
            {
                removedLegacyWeaponSelection = _s.AttackReminderWeaponIds.RemoveAll(id =>
                    string.Equals(id, identifier, StringComparison.OrdinalIgnoreCase)) > 0;
            }

            _s.AttackReminderWeaponIds.RemoveAll(id =>
                string.Equals(id, reminder.Key, StringComparison.OrdinalIgnoreCase));

            if (removedLegacyWeaponSelection && reminder.EquipmentIdentifier is { } legacyIdentifier)
            {
                foreach (var remaining in _attackReminders.Where(other =>
                    other.IsWeapon &&
                    string.Equals(other.EquipmentIdentifier, legacyIdentifier, StringComparison.OrdinalIgnoreCase) &&
                    !string.Equals(other.Key, reminder.Key, StringComparison.OrdinalIgnoreCase)))
                {
                    if (!_s.AttackReminderWeaponIds.Contains(remaining.Key, StringComparer.OrdinalIgnoreCase))
                        _s.AttackReminderWeaponIds.Add(remaining.Key);
                }
            }
        }
        else if (!_s.HiddenDefaultAttackReminderKeys.Contains(reminder.Key, StringComparer.OrdinalIgnoreCase))
        {
            _s.HiddenDefaultAttackReminderKeys.Add(reminder.Key);
        }

        AutoSave();
        RefreshAttackReminders();
    }

    private void RefreshAttackReminders()
    {
        var attackReminderSet = BuildAttackReminderSet();
        _attackReminders = attackReminderSet.Visible;
        _availableAttackReminders = attackReminderSet.AvailableWeapons;
    }

    private SessionAttackReminderSet BuildAttackReminderSet()
    {
        if (_snap is null)
            return new SessionAttackReminderSet([], []);

        var attacks = _snap.Attacks
            .Select(attack => new SessionAttackSource(
                attack.Name,
                attack.Attack,
                attack.Damage,
                attack.Range,
                attack.EquipmentIdentifier))
            .ToList();

        var inventory = _snap.InventoryItems
            .Select(item => new SessionInventorySource(
                item.Identifier,
                item.IsEquipped,
                item.EquippedLocation,
                item.Name,
                item.IsWeaponLike,
                item.Damage,
                item.Range))
            .ToList();

        return SessionAttackReminderService.Build(
            attacks,
            inventory,
            _s.AttackReminderWeaponIds,
            _s.HiddenDefaultAttackReminderKeys,
            _s.CustomAttackReminders);
    }

    private static List<SpellLevelEntry> BuildAggregatedSpellLevels(CharacterSnapshot? snap)
    {
        if (snap is null) return [];

        return snap.SpellcastingSections
            .SelectMany(section => section.SpellLevels)
            .Where(level => level.TotalSlots > 0)
            .GroupBy(level => level.Level)
            .Select(group => new SpellLevelEntry(
                group.Key,
                [],
                group.Max(level => level.TotalSlots)))
            .OrderBy(level => level.Level)
            .ToList();
    }

    // ── Custom resources ──────────────────────────────────────────────────────

    private void ToggleResource(CustomResource r, int idx)
    {
        r.Used = r.Used == idx ? idx - 1 : idx;
        AutoSave();
    }

    private void AdjustResource(CustomResource r, int delta)
    {
        // delta is the change in Remaining: +1 = recover one, -1 = expend one.
        r.Used = Math.Clamp(r.Used - delta, 0, r.Max);
        AutoSave();
    }

