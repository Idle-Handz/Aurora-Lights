@page "/settings"
@implements IDisposable
@using Aurora.Importer
@using Builder.Presentation
@inject ContentDatabaseService ContentDb
@inject ContentService Content
@inject CharacterService Characters
@inject ContentDatabaseParityService Parity
@inject CharacterTabService Tabs
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject UserPreferencesService Prefs
@inject DebugLogService DebugLog

<MudText Typo="Typo.h5" Class="mb-4">Settings</MudText>

<MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true" PanelClass="pt-4">

    <!-- ── General ─────────────────────────────────────────────────────────── -->
    <MudTabPanel Text="General">

        <div class="pref-section">
            <div class="section-label">Appearance</div>

            <div class="pref-row">
                <div class="pref-row-text">
                    <div class="pref-row-title">Light mode</div>
                    <div class="pref-row-desc">
                        Switch to a light colour palette. Most MudBlazor controls will update immediately;
                        custom layout areas use the dark palette by design and are unaffected.
                    </div>
                </div>
                <MudSwitch Value="Prefs.LightMode"
                           ValueChanged="@((bool v) => Prefs.LightMode = v)"
                           Color="Color.Primary" />
            </div>
        </div>

        <div class="pref-section" style="margin-top: 24px;">
            <div class="section-label">Build &amp; Magic</div>

            <div class="pref-row">
                <div class="pref-row-text">
                    <div class="pref-row-title">Auto-save on selection change</div>
                    <div class="pref-row-desc">
                        When enabled, choosing a new option on the Build or Magic page immediately
                        writes the character file to disk. Disable this if you want to experiment
                        with different build choices and save only when satisfied.
                    </div>
                </div>
                <MudSwitch Value="Prefs.AutoSaveBuildChanges"
                           ValueChanged="@((bool v) => Prefs.AutoSaveBuildChanges = v)"
                           Color="Color.Primary" />
            </div>

            <div class="pref-row" style="margin-top: 16px;">
                <div class="pref-row-text">
                    <div class="pref-row-title">Default HP method for new characters</div>
                    <div class="pref-row-desc">
                        Average uses the fixed value for each die size (for example, d8 → 5 per level, max at level 1).
                        Rolled generates random dice values upfront and persists them. Either can be changed
                        per-character on the Build page after creation.
                    </div>
                </div>
                <MudRadioGroup Value="Prefs.DefaultHpMethod"
                               ValueChanged="@((HpMethod v) => Prefs.DefaultHpMethod = v)">
                    <MudRadio Value="HpMethod.Average" Color="Color.Primary">Average</MudRadio>
                    <MudRadio Value="HpMethod.Rolled"  Color="Color.Primary">Rolled</MudRadio>
                </MudRadioGroup>
            </div>

            <div class="pref-row" style="margin-top: 16px;">
                <div class="pref-row-text">
                    <div class="pref-row-title">Allow feats</div>
                    <div class="pref-row-desc">
                        When enabled, new characters can forgo an Ability Score Improvement to take a feat
                        instead. Per-character control is available on the Manage page.
                    </div>
                </div>
                <MudSwitch Value="Prefs.DefaultFeats"
                           ValueChanged="@((bool v) => Prefs.DefaultFeats = v)"
                           Color="Color.Primary" />
            </div>

            <div class="pref-row" style="margin-top: 16px;">
                <div class="pref-row-text">
                    <div class="pref-row-title">Allow multiclassing</div>
                    <div class="pref-row-desc">
                        When enabled, new characters can gain levels in more than one class.
                        Per-character control is available on the Manage page.
                    </div>
                </div>
                <MudSwitch Value="Prefs.DefaultMulticlassing"
                           ValueChanged="@((bool v) => Prefs.DefaultMulticlassing = v)"
                           Color="Color.Primary" />
            </div>

            <div class="pref-row" style="margin-top: 16px;">
                <div class="pref-row-text">
                    <div class="pref-row-title">Customized ability score increases</div>
                    <div class="pref-row-desc">
                        When enabled, new characters default to allowing racial ability score increases to be
                        moved to any ability scores of your choice — keeping the same split (+2 to one, +1 to another).
                        Per-character control is available on the Manage page.
                    </div>
                </div>
                <MudSwitch Value="Prefs.DefaultCustomOrigin"
                           ValueChanged="@((bool v) => Prefs.DefaultCustomOrigin = v)"
                           Color="Color.Primary" />
            </div>

            <div class="pref-row" style="margin-top: 16px;">
                <div class="pref-row-text">
                    <div class="pref-row-title">Customized language</div>
                    <div class="pref-row-desc">
                        When enabled, new characters default to allowing the fixed racial language to be
                        swapped for any other standard language of your choice.
                        Per-character control is available on the Manage page.
                    </div>
                </div>
                <MudSwitch Value="Prefs.DefaultCustomLanguage"
                           ValueChanged="@((bool v) => Prefs.DefaultCustomLanguage = v)"
                           Color="Color.Primary" />
            </div>

            <div class="pref-row" style="margin-top: 16px;">
                <div class="pref-row-text">
                    <div class="pref-row-title">Customized proficiencies</div>
                    <div class="pref-row-desc">
                        When enabled, new characters default to allowing fixed racial skill proficiencies to be
                        swapped for any other skill proficiency of your choice.
                        Per-character control is available on the Manage page.
                    </div>
                </div>
                <MudSwitch Value="Prefs.DefaultCustomProficiency"
                           ValueChanged="@((bool v) => Prefs.DefaultCustomProficiency = v)"
                           Color="Color.Primary" />
            </div>
        </div>

        <div class="pref-section" style="margin-top: 24px;">
            <div class="section-label">Character Storage</div>

            <div style="margin-bottom: 12px;">
                <div class="pref-row-desc">
                    Character files (.dnd5e) are saved to and loaded from this directory.
                    @if (OperatingSystem.IsAndroid())
                    {
                        <span> On Android, switching to <b>External Storage</b> makes files accessible from any file manager app without needing ADB or root.</span>
                    }
                </div>
            </div>

            <div style="margin-bottom: 12px;">
                <div class="pref-row-title" style="margin-bottom: 4px;">Current location</div>
                <div style="font-family: monospace; font-size: 12px; color: var(--mud-palette-text-secondary); word-break: break-all;">
                    @Characters.CharactersDirectory
                </div>
            </div>

            @if (Tabs.Tabs.Count > 0)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                    Close all character tabs before changing the storage location.
                </MudAlert>
            }

            <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
                @if (OperatingSystem.IsAndroid())
                {
                    string? extPath = CharacterService.GetAndroidExternalStoragePath();
                    bool alreadyExternal = extPath != null &&
                        Characters.CharactersDirectory.StartsWith(extPath, StringComparison.Ordinal);
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Disabled="@(Tabs.Tabs.Count > 0 || alreadyExternal || _dirBusy)"
                               OnClick="UseExternalStorageAsync">
                        Use External Storage
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Disabled="@(Tabs.Tabs.Count > 0 || _dirBusy)"
                               StartIcon="@Icons.Material.Filled.FolderOpen"
                               OnClick="BrowseCharactersDirAsync">
                        Browse…
                    </MudButton>
                }

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           Size="Size.Small"
                           Disabled="@(Tabs.Tabs.Count > 0 || _dirBusy || string.IsNullOrEmpty(ApplicationContext.Current.Settings.DocumentsRootDirectory))"
                           OnClick="ResetCharactersDirAsync">
                    Reset to Default
                </MudButton>
            </div>

            @if (_dirError != null)
            {
                <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true"
                          ShowCloseIcon="true" CloseIconClicked="() => _dirError = null">
                    @_dirError
                </MudAlert>
            }
        </div>

    </MudTabPanel>

    <!-- ── Character Sheet ──────────────────────────────────────────────────── -->
    <MudTabPanel Text="Character Sheet">

        <div class="pref-section">
            <div class="section-label">PDF Cards</div>
            <div class="pref-row-desc" style="margin-bottom: 16px;">
                Choose which extra card pages to append when generating a character sheet PDF.
            </div>

            <div class="pref-row">
                <div class="pref-row-text">
                    <div class="pref-row-title">Include spell cards</div>
                    <div class="pref-row-desc">
                        Adds a page of spell cards at the end of the PDF. Each spell the character knows
                        or has prepared gets its own card with casting details and description.
                    </div>
                </div>
                <MudSwitch Value="Prefs.IncludeSpellCards"
                           ValueChanged="@((bool v) => Prefs.IncludeSpellCards = v)"
                           Color="Color.Primary" />
            </div>

            <div class="pref-row" style="margin-top: 16px;">
                <div class="pref-row-text">
                    <div class="pref-row-title">Include item cards</div>
                    <div class="pref-row-desc">
                        Adds a page of item cards for equipment marked to show as a card. Each item
                        gets its own card with its category, description, and source.
                    </div>
                </div>
                <MudSwitch Value="Prefs.IncludeItemCards"
                           ValueChanged="@((bool v) => Prefs.IncludeItemCards = v)"
                           Color="Color.Primary" />
            </div>

            <div class="pref-row" style="margin-top: 16px;">
                <div class="pref-row-text">
                    <div class="pref-row-title">Include attack cards</div>
                    <div class="pref-row-desc">
                        Adds a page of attack cards for weapons and abilities configured to appear as cards,
                        showing attack bonus, damage, range, and description.
                    </div>
                </div>
                <MudSwitch Value="Prefs.IncludeAttackCards"
                           ValueChanged="@((bool v) => Prefs.IncludeAttackCards = v)"
                           Color="Color.Primary" />
            </div>

            <div class="pref-row" style="margin-top: 16px;">
                <div class="pref-row-text">
                    <div class="pref-row-title">Include feature cards</div>
                    <div class="pref-row-desc">
                        Adds a page of feature cards for class features, racial traits, feats, and other
                        abilities that are enabled to display on the character sheet.
                    </div>
                </div>
                <MudSwitch Value="Prefs.IncludeFeatureCards"
                           ValueChanged="@((bool v) => Prefs.IncludeFeatureCards = v)"
                           Color="Color.Primary" />
            </div>
        </div>

    </MudTabPanel>

    <!-- ── Content ──────────────────────────────────────────────────────────── -->
    <MudTabPanel Text="Content">

        <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true" PanelClass="pt-3">

            <!-- ── Data sub-tab ───────────────────────────────────────────────── -->
            <MudTabPanel Text="Data">

                <div class="pref-section">
                    <div class="section-label">Database</div>
                    <div class="pref-row-desc" style="margin-bottom: 16px;">
                        Manage the installed content database and keep it in sync with your content directory.
                    </div>

                    <div style="margin-bottom: 12px;">
                        <div class="pref-row-title" style="margin-bottom: 4px;">Content directory</div>
                        <div style="font-family: monospace; font-size: 12px; color: var(--mud-palette-text-secondary); word-break: break-all;">
                            @(string.IsNullOrWhiteSpace(ContentDb.ContentDirectory) ? "(not available)" : ContentDb.ContentDirectory)
                        </div>
                    </div>

                    <div style="margin-bottom: 12px;">
                        <div class="pref-row-title" style="margin-bottom: 4px;">Database path</div>
                        <div style="font-family: monospace; font-size: 12px; color: var(--mud-palette-text-secondary); word-break: break-all;">
                            @(ContentDb.DatabasePath ?? "(not available)")
                        </div>
                    </div>

                    <div style="margin-bottom: 16px;">
                        <div class="pref-row-title" style="margin-bottom: 4px;">Status</div>
                        @if (ContentDb.SyncState == ContentDatabaseSyncState.Syncing)
                        {
                            <div style="color: var(--mud-palette-primary); font-size: 13px;">
                                @(ContentDb.Progress?.PhaseLabel ?? "Syncing...")
                            </div>
                            <MudProgressLinear Indeterminate="false"
                                               Value="@SyncPercent"
                                               Min="0" Max="100"
                                               Color="Color.Primary"
                                               Class="mt-2" />
                        }
                        else if (ContentDb.LastResult != null)
                        {
                            <div style="color: @(ContentDb.LastResult.Success ? "var(--mud-palette-success)" : "var(--mud-palette-error)"); font-size: 13px;">
                                @ContentDb.LastResult.Summary
                            </div>
                        }
                        else if (ContentDb.IsStale)
                        {
                            <div style="color: var(--mud-palette-warning); font-size: 13px;">Database is out of date. Sync to update it.</div>
                        }
                        else if (_stalenessChecked)
                        {
                            <div style="color: var(--mud-palette-success); font-size: 13px;">Database is up to date.</div>
                        }
                        else
                        {
                            <div style="font-size: 13px; color: var(--mud-palette-text-disabled);">Not checked yet.</div>
                        }
                    </div>

                    <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   Disabled="@(ContentDb.SyncState == ContentDatabaseSyncState.Syncing)"
                                   OnClick="CheckStaleAsync">
                            Check for Changes
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Disabled="@(ContentDb.SyncState == ContentDatabaseSyncState.Syncing || string.IsNullOrWhiteSpace(ContentDb.ContentDirectory))"
                                   OnClick="SyncNowAsync">
                            Sync Now
                        </MudButton>
                        @if (ContentDb.SyncState == ContentDatabaseSyncState.Done && Tabs.Tabs.Count == 0)
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       Size="Size.Small"
                                       OnClick="ReloadElementsAsync">
                                Reload Elements
                            </MudButton>
                        }
                    </div>

                    @if (ContentDb.SyncState == ContentDatabaseSyncState.Done && ContentDb.LastResult?.Success == true && Tabs.Tabs.Count > 0)
                    {
                        <MudAlert Severity="Severity.Info" Class="mt-4" Dense="true">
                            Close all character tabs and click <strong>Reload Elements</strong> to use the updated database.
                        </MudAlert>
                    }
                </div>

            </MudTabPanel>

            <!-- ── Sources sub-tab ────────────────────────────────────────────── -->
            <MudTabPanel Text="Sources">

                <div class="pref-section" style="margin-bottom: 24px;">
                    <div class="section-label">Sources</div>
                    <div class="pref-row-desc" style="margin-bottom: 10px;">
                        Enable or disable individual content sources. Disabled sources are excluded
                        from element resolution. Reload elements after making changes for them to take effect.
                    </div>
                    @{
                        var packages = ContentDb.GetPackages();
                        IReadOnlyList<ContentPackageInfo> filteredPackages = string.IsNullOrWhiteSpace(_packageSearch)
                            ? packages
                            : packages.Where(p =>
                                p.PackageName.Contains(_packageSearch, StringComparison.OrdinalIgnoreCase) ||
                                p.PackageKey.Contains(_packageSearch, StringComparison.OrdinalIgnoreCase) ||
                                p.PackageKind.Contains(_packageSearch, StringComparison.OrdinalIgnoreCase)).ToList();
                    }
                    @if (packages.Count == 0)
                    {
                        <div style="font-size: 13px; color: var(--mud-palette-text-disabled);">
                            No sources found. Sync the content database first.
                        </div>
                    }
                    else
                    {
                        <MudTextField @bind-Value="_packageSearch"
                                      Placeholder="Search sources…"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Clearable="true"
                                      Immediate="true"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Class="mb-3" />
                        @if (!filteredPackages.Any())
                        {
                            <div style="font-size: 13px; color: var(--mud-palette-text-disabled);">No sources match your search.</div>
                        }
                        else
                        {
                            <div style="display: flex; flex-direction: column; gap: 4px; max-height: 320px; overflow-y: auto;">
                                @foreach (var pkg in filteredPackages)
                                {
                                    var p = pkg;
                                    <div style="display: flex; align-items: center; gap: 10px; padding: 6px 8px; border-radius: 6px; background: var(--mud-palette-background-grey);">
                                        <MudSwitch Value="p.IsEnabled"
                                                   ValueChanged="@((bool v) => TogglePackageAsync(p.Id, v))"
                                                   Color="Color.Primary"
                                                   Style="margin: 0;" />
                                        <span style="font-size: 13px; color: var(--mud-palette-text-primary); flex: 1;">@p.PackageName</span>
                                        <MudChip T="string" Size="Size.Small"
                                                 Style="@($"background: {KindColor(p.PackageKind)}22; color: {KindColor(p.PackageKind)}; font-size: 11px; height: 20px; border-radius: 4px;")">
                                            @p.PackageKind
                                        </MudChip>
                                    </div>
                                }
                            </div>
                            @if (filteredPackages.Count < packages.Count)
                            {
                                <div style="font-size: 12px; color: var(--mud-palette-text-disabled); margin-top: 6px;">
                                    Showing @filteredPackages.Count of @packages.Count sources.
                                </div>
                            }
                        }
                    }
                </div>

                <div class="pref-section">

                    <div style="margin-bottom: 16px;">
                        <div class="pref-row-title" style="margin-bottom: 4px;">Built-in custom directory</div>
                        <div style="font-family: monospace; font-size: 12px; color: var(--mud-palette-text-secondary); word-break: break-all;">
                            @Content.BuiltInCustomDirectory
                        </div>
                        <div class="pref-row-desc" style="margin-top: 4px;">
                            Place XML files or .index files here and reload elements to pick them up.
                        </div>
                    </div>

                    <div style="margin-bottom: 6px;">
                        <div class="pref-row-title">Additional content directories</div>
                        <div class="pref-row-desc" style="margin-bottom: 10px;">
                            Extra folders containing Aurora XML content, useful for homebrew or
                            third-party content stored outside the built-in custom directory.
                        </div>

                        @if (Content.AdditionalDirectories.Count == 0)
                        {
                            <div style="font-size: 13px; color: var(--mud-palette-text-disabled); margin-bottom: 8px;">No additional directories configured.</div>
                        }
                        else
                        {
                            <div style="display: flex; flex-direction: column; gap: 6px; margin-bottom: 10px;">
                                @foreach (var dir in Content.AdditionalDirectories.ToList())
                                {
                                    var d = dir;
                                    <div style="display: flex; align-items: center; gap: 8px; background: var(--mud-palette-background-grey); border-radius: 6px; padding: 6px 10px;">
                                        <span style="font-family: monospace; font-size: 12px; color: var(--mud-palette-text-primary); flex: 1; word-break: break-all;">@d</span>
                                        <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                                       Size="Size.Small"
                                                       title="Remove"
                                                       OnClick="() => RemoveDirectory(d)"
                                                       Style="padding: 2px; flex-shrink: 0;" />
                                    </div>
                                }
                            </div>
                        }

                        <div style="display: flex; gap: 8px; align-items: flex-start; margin-top: 4px;">
                            <MudTextField @bind-Value="_newDirPath"
                                          Label="Folder path"
                                          Placeholder="C:\path\to\homebrew\content"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Style="flex: 1; font-size: 13px;"
                                          Immediate="true"
                                          @onkeydown="OnDirKeyDown" />
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       Disabled="@string.IsNullOrWhiteSpace(_newDirPath)"
                                       OnClick="AddDirectory"
                                       Style="margin-top: 4px; white-space: nowrap;">
                                Add
                            </MudButton>
                        </div>
                    </div>

                    <div style="margin-top: 24px;">
                        <div class="pref-row-title">Content index files (.index)</div>
                        <div class="pref-row-desc" style="margin-bottom: 10px;">
                            Paste a URL ending in <code>.index</code> to register it, then check for updates
                            to download the content. Requires a network connection.
                        </div>

                        <div style="display: flex; gap: 8px; align-items: flex-start; margin-bottom: 10px;">
                            <MudTextField @bind-Value="_indexUrl"
                                          Label="Index URL"
                                          Placeholder="https://raw.githubusercontent.com/.../core.index"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Style="flex: 1; font-size: 13px;"
                                          Disabled="_contentWorking" />
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       Disabled="@(_contentWorking || string.IsNullOrWhiteSpace(_indexUrl))"
                                       OnClick="FetchIndexAsync"
                                       Style="margin-top: 4px; white-space: nowrap;">
                                Fetch Index
                            </MudButton>
                        </div>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.Sync"
                                   Size="Size.Small"
                                   Disabled="_contentWorking"
                                   OnClick="CheckForUpdatesAsync">
                            Check for Updates
                        </MudButton>
                    </div>

                    @if (_needsContentReload)
                    {
                        <MudAlert Severity="Severity.Info" Class="mt-4" Dense="true">
                            Content changes will not take effect until elements are reloaded.
                            @if (Content.HasOpenTabs)
                            {
                                <span> Open characters will be closed.</span>
                            }
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       Disabled="_contentWorking"
                                       OnClick="ReloadContentAsync"
                                       Style="margin-left: 12px;">
                                @(_contentWorking ? "Reloading..." : "Reload Now")
                            </MudButton>
                        </MudAlert>
                    }

                    @if (_contentStatus != null)
                    {
                        <MudAlert Severity="@_contentStatusSeverity" Class="mt-3" Dense="true"
                                  ShowCloseIcon="true" CloseIconClicked="() => _contentStatus = null">
                            @_contentStatus
                        </MudAlert>
                    }

                </div>

            </MudTabPanel>

        </MudTabs>

    </MudTabPanel>

    <!-- ── Advanced ─────────────────────────────────────────────────────────── -->
    <MudTabPanel Text="Advanced">

        <div class="pref-section">
            <div class="section-label">Developer</div>

            <div class="pref-row">
                <div class="pref-row-text">
                    <div class="pref-row-title">Developer / debug mode</div>
                    <div class="pref-row-desc">
                        Shows a Console page in the navigation menu where runtime exceptions and
                        diagnostic messages are captured. Useful for diagnosing crashes.
                    </div>
                </div>
                <MudSwitch Value="Prefs.DevMode"
                           ValueChanged="@((bool v) => Prefs.DevMode = v)"
                           Color="Color.Secondary" />
            </div>

            @if (Prefs.DevMode)
            {
                <div class="pref-row" style="margin-top: 16px;">
                    <div class="pref-row-text">
                        <div class="pref-row-title">Log entries: @DebugLog.Entries.Count</div>
                        <div class="pref-row-desc">Errors: @DebugLog.Entries.Count(e => e.Level == LogLevel.Error)</div>
                    </div>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                               Href="/console">Open Console</MudButton>
                </div>

                <div class="pref-row" style="margin-top: 16px;">
                    <div class="pref-row-text">
                        <div class="pref-row-title">Element data source: @Characters.ElementLoadSource</div>
                        <div class="pref-row-desc">@Characters.ElementLoadSummary</div>
                        @if (Characters.ElementLoadSchemaVersion.HasValue)
                        {
                            <div class="pref-row-desc">Schema version: @Characters.ElementLoadSchemaVersion.Value</div>
                        }
                        @if (Characters.ElementLoadDataVersion.HasValue)
                        {
                            <div class="pref-row-desc">Data version: @Characters.ElementLoadDataVersion.Value</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Characters.ElementLoadImporterVersion))
                        {
                            <div class="pref-row-desc">Importer version: @Characters.ElementLoadImporterVersion</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Characters.ElementLoadBuiltUtc))
                        {
                            <div class="pref-row-desc">DB built: @FormatUtc(Characters.ElementLoadBuiltUtc)</div>
                        }
                        @if (Characters.ElementLoadSourceFileCount.HasValue)
                        {
                            <div class="pref-row-desc">Indexed files: @Characters.ElementLoadSourceFileCount.Value</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Characters.ElementLoadDatabasePath))
                        {
                            <div class="pref-row-desc" style="font-family: monospace; word-break: break-all;">
                                DB path: @Characters.ElementLoadDatabasePath
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Characters.ElementLoadContentRootHash))
                        {
                            <div class="pref-row-desc" style="font-family: monospace; word-break: break-all;">
                                Content hash: @Characters.ElementLoadContentRootHash
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Characters.ElementLoadFailureReason))
                        {
                            <div class="pref-row-desc">Fallback reason: @Characters.ElementLoadFailureReason</div>
                        }
                        @if (Characters.ElementLoadSkippedElements > 0)
                        {
                            <div class="pref-row-desc">Skipped elements during DB load: @Characters.ElementLoadSkippedElements</div>
                        }
                    </div>
                </div>
            }
        </div>

        @if (Prefs.DevMode)
        {
            <div class="pref-section" style="margin-top: 24px;">
                <div class="section-label">Database Diagnostics</div>

                @{
                    var dbMeta = ContentDb.GetMetadata();
                }
                @if (dbMeta != null)
                {
                    <div style="margin-bottom: 16px;">
                        <div class="pref-row-title" style="margin-bottom: 4px;">Database metadata</div>
                        <div class="pref-row-desc">Schema v@dbMeta.SchemaVersion, data v@dbMeta.DataVersion, importer @dbMeta.ImporterVersion</div>
                        <div class="pref-row-desc">Built: @FormatUtc(dbMeta.BuiltUtc)</div>
                        <div class="pref-row-desc">Indexed files: @dbMeta.SourceFileCount, elements: @dbMeta.ElementCount</div>
                    </div>
                }

                @if (_dbHealth != null)
                {
                    <div style="margin-bottom: 16px;">
                        <div class="pref-row-title" style="margin-bottom: 6px;">Content health</div>
                        <MudAlert Severity="@HealthSeverity(_dbHealth)"
                                  Dense="true"
                                  Variant="Variant.Outlined"
                                  Class="mb-2">
                            @HealthSummary(_dbHealth)
                        </MudAlert>
                        <div class="pref-row-desc">Actionable unresolved links: @_dbHealth.ActionableUnresolvedLinks</div>
                        <div class="pref-row-desc">Classified unresolved links: @_dbHealth.ClassifiedUnresolvedLinks</div>
                        <div class="pref-row-desc">Source integrity issues: @_dbHealth.SourceIntegrityIssues</div>
                        <div class="pref-row-desc">Missing spell rows: @_dbHealth.MissingResolvedSpellRows</div>
                        <div class="pref-row-desc">Missing item rows: @_dbHealth.MissingResolvedItemRows</div>
                        <div class="pref-row-desc">Missing companion rows: @_dbHealth.MissingResolvedCompanionRows</div>
                    </div>
                }

                <div style="margin-bottom: 16px;">
                    <div class="pref-row-title" style="margin-bottom: 6px;">Database vs XML parity</div>
                    <div class="pref-row-desc" style="margin-bottom: 10px;">
                        Runs the XML parser pipeline in isolation and compares its element snapshot to the SQLite reconstruction path.
                        This is slower than the health check, so it runs only when requested.
                    </div>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               Size="Size.Small"
                               Disabled="_parityRunning"
                               OnClick="RunParityAuditAsync">
                        @(_parityRunning ? "Running parity audit..." : "Run Parity Audit")
                    </MudButton>
                </div>

                @if (_dbParity != null)
                {
                    <div style="margin-bottom: 16px;">
                        <MudAlert Severity="@ParitySeverity(_dbParity)"
                                  Dense="true"
                                  Variant="Variant.Outlined"
                                  Class="mb-2">
                            @ParitySummary(_dbParity)
                        </MudAlert>
                        @if (_dbParity.Success)
                        {
                            <div class="pref-row-desc">XML elements: @_dbParity.XmlElementCount</div>
                            <div class="pref-row-desc">Database elements: @_dbParity.DatabaseElementCount</div>
                            <div class="pref-row-desc">XML skipped during audit: @_dbParity.XmlSkippedElements</div>
                            <div class="pref-row-desc">Database skipped during audit: @_dbParity.DatabaseSkippedElements</div>
                            <div class="pref-row-desc">Missing from DB: @_dbParity.MissingInDatabaseCount</div>
                            <div class="pref-row-desc">Missing from XML: @_dbParity.MissingInXmlCount</div>
                            @if (_dbParity.MissingInDatabaseSample.Count > 0)
                            {
                                <div class="pref-row-title" style="margin-top: 10px; margin-bottom: 4px;">Present in XML but missing from DB (sample)</div>
                                @foreach (string id in _dbParity.MissingInDatabaseSample)
                                {
                                    <div class="pref-row-desc" style="font-family: monospace;">@id</div>
                                }
                            }
                            @if (_dbParity.MissingInXmlSample.Count > 0)
                            {
                                <div class="pref-row-title" style="margin-top: 10px; margin-bottom: 4px;">Present in DB but missing from XML (sample)</div>
                                @foreach (string id in _dbParity.MissingInXmlSample)
                                {
                                    <div class="pref-row-desc" style="font-family: monospace;">@id</div>
                                }
                            }
                            @if (_dbParity.TypeMismatches.Count > 0)
                            {
                                <div class="pref-row-title" style="margin-top: 10px; margin-bottom: 4px;">Type count mismatches</div>
                                @foreach (var mismatch in _dbParity.TypeMismatches)
                                {
                                    <div class="pref-row-desc">@mismatch.Key: XML @mismatch.XmlCount, DB @mismatch.DatabaseCount</div>
                                }
                            }
                            @if (_dbParity.SourceMismatches.Count > 0)
                            {
                                <div class="pref-row-title" style="margin-top: 10px; margin-bottom: 4px;">Source count mismatches</div>
                                @foreach (var mismatch in _dbParity.SourceMismatches)
                                {
                                    <div class="pref-row-desc">@mismatch.Key: XML @mismatch.XmlCount, DB @mismatch.DatabaseCount</div>
                                }
                            }
                        }
                        else if (!string.IsNullOrWhiteSpace(_dbParity.FailureReason))
                        {
                            <div class="pref-row-desc">@_dbParity.FailureReason</div>
                        }
                    </div>
                }
            </div>
        }

    </MudTabPanel>

</MudTabs>

@code {
    private CancellationTokenSource? _cts;

    private string _indexUrl = "";
    private string _newDirPath = "";
    private string _packageSearch = "";
    private string? _contentStatus;
    private Severity _contentStatusSeverity = Severity.Success;
    private bool _contentWorking;
    private bool _parityRunning;
    private bool _stalenessChecked;
    private bool _needsContentReload;
    private ContentDatabaseHealthReport? _dbHealth;
    private ContentDatabaseParityReport? _dbParity;
    private bool _dirBusy;
    private string? _dirError;

    protected override void OnInitialized()
    {
        ContentDb.StateChanged += OnStateChanged;
        Content.Changed += OnContentChanged;
        RefreshDatabaseDiagnostics();
    }

    private async Task TogglePackageAsync(long packageId, bool enabled)
    {
        await ContentDb.SetPackageEnabledAsync(packageId, enabled);
        _needsContentReload = true;
        StateHasChanged();
    }

    private static string KindColor(string kind) => kind switch
    {
        "core" => "#a6e3a1",
        "official" => "#89b4fa",
        "third-party" => "#fab387",
        "homebrew" => "#cba6f7",
        _ => "#6c7086",
    };

    private void OnStateChanged() => InvokeAsync(() =>
    {
        RefreshDatabaseDiagnostics();
        StateHasChanged();
    });
    private void OnContentChanged() => InvokeAsync(StateHasChanged);

    private int SyncPercent
    {
        get
        {
            var p = ContentDb.Progress;
            if (p == null || p.FilesTotal == 0) return 0;
            return p.Phase switch
            {
                Aurora.Importer.AuroraImportPhase.Scanning => (int)(p.FilesScanned * 50.0 / p.FilesTotal),
                Aurora.Importer.AuroraImportPhase.Importing => 50 + (int)(p.FilesScanned * 40.0 / Math.Max(1, p.FilesTotal)),
                Aurora.Importer.AuroraImportPhase.Resolving => 90,
                Aurora.Importer.AuroraImportPhase.Complete => 100,
                _ => 0
            };
        }
    }

    private async Task CheckStaleAsync()
    {
        await Task.Run(() => ContentDb.CheckIsStale());
        _stalenessChecked = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SyncNowAsync()
    {
        _stalenessChecked = false;
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        await ContentDb.SyncAsync(_cts.Token);
        RefreshDatabaseDiagnostics();
    }

    private async Task ReloadElementsAsync()
    {
        Tabs.CloseAllTabs();
        await Characters.ReloadElementsAsync();
        RefreshDatabaseDiagnostics();
    }

    private void RemoveDirectory(string path)
    {
        Content.RemoveDirectory(path);
        _needsContentReload = true;
    }

    private void OnDirKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddDirectory();
    }

    private void AddDirectory()
    {
        string path = _newDirPath.Trim();
        if (string.IsNullOrEmpty(path))
        {
            _contentStatus = "Enter a directory path first.";
            _contentStatusSeverity = Severity.Warning;
            return;
        }

        if (!Directory.Exists(path))
        {
            _contentStatus = $"Directory not found: {path}";
            _contentStatusSeverity = Severity.Error;
            return;
        }

        Content.AddDirectory(path);
        _newDirPath = "";
        _needsContentReload = true;
        _contentStatus = null;
    }

    private static string FormatUtc(string? utcText)
    {
        if (string.IsNullOrWhiteSpace(utcText)) return "Unknown";
        return DateTime.TryParse(
            utcText,
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.AssumeUniversal | System.Globalization.DateTimeStyles.AdjustToUniversal,
            out var parsed)
            ? parsed.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")
            : utcText;
    }

    private void RefreshDatabaseDiagnostics()
    {
        _dbHealth = ContentDb.GetHealthReport();
    }

    private static Severity ParitySeverity(ContentDatabaseParityReport report) => report.Status switch
    {
        ContentDatabaseParityStatus.Healthy => Severity.Success,
        ContentDatabaseParityStatus.Warning => Severity.Warning,
        ContentDatabaseParityStatus.Error => Severity.Error,
        _ => Severity.Info
    };

    private static string ParitySummary(ContentDatabaseParityReport report) => report.Status switch
    {
        ContentDatabaseParityStatus.Healthy => "SQLite and XML snapshots matched in this audit run.",
        ContentDatabaseParityStatus.Warning => "Parity audit matched structurally, but one of the loaders skipped elements during reconstruction.",
        ContentDatabaseParityStatus.Error when !report.Success => $"Parity audit failed: {report.FailureReason}",
        ContentDatabaseParityStatus.Error => $"Parity audit found {report.TotalMismatchCount} mismatch bucket(s) between XML and SQLite snapshots.",
        _ => "Parity audit status is unavailable."
    };

    private async Task RunParityAuditAsync()
    {
        _parityRunning = true;
        try
        {
            _dbParity = await Parity.RunAsync();
        }
        finally
        {
            _parityRunning = false;
        }
    }

    private static Severity HealthSeverity(ContentDatabaseHealthReport health) => health.Status switch
    {
        ContentDatabaseHealthStatus.Healthy => Severity.Success,
        ContentDatabaseHealthStatus.Warning => Severity.Warning,
        ContentDatabaseHealthStatus.Error => Severity.Error,
        _ => Severity.Info
    };

    private static string HealthSummary(ContentDatabaseHealthReport health) => health.Status switch
    {
        ContentDatabaseHealthStatus.Healthy
            => health.ClassifiedUnresolvedLinks > 0
                ? $"Content database looks healthy. {health.ClassifiedUnresolvedLinks} known unresolved link(s) were classified as non-actionable."
                : "Content database looks healthy.",
        ContentDatabaseHealthStatus.Warning
            => $"Content database has {health.ActionableUnresolvedLinks} actionable unresolved link(s) to review.",
        ContentDatabaseHealthStatus.Error
            => $"Content database has {health.TotalIssues} issue(s) affecting trust or typed projections.",
        _ => "Content health is unavailable."
    };

    private async Task FetchIndexAsync()
    {
        _contentWorking = true;
        _contentStatus = null;
        StateHasChanged();
        try
        {
            var (success, msg) = await Content.FetchIndexAsync(_indexUrl);
            _contentStatus = msg;
            _contentStatusSeverity = success ? Severity.Success : Severity.Error;
            if (success)
            {
                _indexUrl = "";
                _needsContentReload = true;
            }
        }
        finally
        {
            _contentWorking = false;
        }
    }

    private async Task CheckForUpdatesAsync()
    {
        _contentWorking = true;
        _contentStatus = null;
        StateHasChanged();
        try
        {
            var (updated, msg) = await Content.CheckForUpdatesAsync();
            _contentStatus = msg;
            _contentStatusSeverity = Severity.Info;
            if (updated) _needsContentReload = true;
        }
        finally
        {
            _contentWorking = false;
        }
    }

    private async Task ReloadContentAsync()
    {
        _contentWorking = true;
        _contentStatus = null;
        StateHasChanged();
        try
        {
            string? error = await Content.ReloadContentAsync();
            if (error != null)
            {
                _contentStatus = $"Reload failed: {error}";
                _contentStatusSeverity = Severity.Error;
            }
            else
            {
                _needsContentReload = false;
                Snackbar.Add("Content reloaded.", Severity.Success);
                Nav.NavigateTo("/");
            }
        }
        finally
        {
            _contentWorking = false;
        }
    }

    // ── Character storage directory ──────────────────────────────────────────

    private async Task BrowseCharactersDirAsync()
    {
        _dirBusy  = true;
        _dirError = null;
        StateHasChanged();
        try
        {
            string? chosen = await CharacterService.PickCharactersDirectoryAsync();
            if (chosen == null) return;
            _dirError = Characters.ApplyCustomCharactersDirectory(chosen);
            if (_dirError == null)
                Snackbar.Add($"Characters folder set to: {chosen}", Severity.Success,
                    cfg => cfg.VisibleStateDuration = 4000);
        }
        finally
        {
            _dirBusy = false;
            StateHasChanged();
        }
    }

    private Task UseExternalStorageAsync()
    {
        _dirError = null;
        string? path = CharacterService.GetAndroidExternalStoragePath();
        if (path == null)
        {
            _dirError = "External storage path is not available on this device.";
            return Task.CompletedTask;
        }
        _dirError = Characters.ApplyCustomCharactersDirectory(path);
        if (_dirError == null)
            Snackbar.Add("Switched to external storage. Files are now accessible from the Files app.",
                Severity.Success, cfg => cfg.VisibleStateDuration = 5000);
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task ResetCharactersDirAsync()
    {
        _dirError = Characters.ApplyCustomCharactersDirectory(null);
        if (_dirError == null)
            Snackbar.Add("Characters folder reset to default.", Severity.Success,
                cfg => cfg.VisibleStateDuration = 3000);
        StateHasChanged();
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        ContentDb.StateChanged -= OnStateChanged;
        Content.Changed -= OnContentChanged;
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
