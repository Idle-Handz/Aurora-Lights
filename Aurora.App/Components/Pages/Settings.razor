    private bool   _applying;
    private int    _applyProgress;
    private string? _applyError;

    private async Task ApplyUpdateAsync()
    {
        _applying = true;
        _applyProgress = 0;
        _applyError = null;
        StateHasChanged();
        try
        {
            var progress = new Progress<int>(p =>
            {
                _applyProgress = p;
                _ = InvokeAsync(StateHasChanged);
            });

            // ApplyAsync downloads and then normally exits via Velopack restart.
            // Any returned string means the process is still alive and the user needs feedback.
            string? error = await AppUpdates.ApplyAsync(
                Prefs.IncludePrereleasesInUpdateCheck, progress);

            if (error != null)
            {
                _applyError = error;
                _applying = false;
                await InvokeAsync(StateHasChanged);
            }
            // On success the process has already been replaced — we never reach here.
        }
        catch (Exception ex)
        {
            _applyError = ex.Message;
            _applying = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task PrepareUpdateOnCloseAsync()
    {
        _applying = true;
        _applyProgress = 0;
        _applyError = null;
        StateHasChanged();
        try
        {
            var progress = new Progress<int>(p =>
            {
                _applyProgress = p;
                _ = InvokeAsync(StateHasChanged);
            });

            string? error = await AppUpdates.PrepareApplyOnExitAsync(
                Prefs.IncludePrereleasesInUpdateCheck, progress);

            _applying = false;
            if (error != null)
            {
                _applyError = error;
            }
            else
            {
                Snackbar.Add(
                    "Update downloaded. Close the app normally when convenient; your next launch will use the new version.",
                    Severity.Success,
                    cfg => cfg.VisibleStateDuration = 10000);
            }
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            _applyError = ex.Message;
            _applying = false;
            await InvokeAsync(StateHasChanged);
        }
    }
