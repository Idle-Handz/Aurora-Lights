    private void OnContentChanged() => InvokeAsync(StateHasChanged);

    private int SyncPercent
    {
        get
        {
            var p = ContentDb.Progress;
            if (p == null || p.FilesTotal == 0) return 0;
            return p.Phase switch
            {
                Aurora.Importer.AuroraImportPhase.Scanning => (int)(p.FilesScanned * 50.0 / p.FilesTotal),
                Aurora.Importer.AuroraImportPhase.Importing => 50 + (int)(p.FilesScanned * 40.0 / Math.Max(1, p.FilesTotal)),
                Aurora.Importer.AuroraImportPhase.Resolving => 90,
                Aurora.Importer.AuroraImportPhase.Complete => 100,
                _ => 0
            };
        }
    }

    private async Task CheckStaleAsync()
    {
        _checkingStale = true;
        StateHasChanged();
        try
        {
            await Task.Run(() => ContentDb.CheckIsStale());
            if (_disposed) return;
            _stalenessChecked = true;
        }
        finally
        {
            _checkingStale = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshDatabaseAsync()
    {
        _contentWorking = true;
        _reloadingElements = true;
        _contentStatus = null;
        StateHasChanged();
        try
        {
            string? error = await Content.ReloadContentAsync();
            if (_disposed) return;
            if (error != null)
            {
                _contentStatus = $"Refresh failed: {error}";
                _contentStatusSeverity = Severity.Error;
            }
            else
            {
                _needsContentReload = false;
                _stalenessChecked = true;
                RefreshDatabaseDiagnostics();
                Snackbar.Add("Database refreshed.", Severity.Success);
            }
        }
        finally
        {
            _contentWorking = false;
            _reloadingElements = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void RemoveDirectory(string path)
    {
        Content.RemoveDirectory(path);
        _needsContentReload = true;
    }

    private void OnDirKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddDirectory();
    }

    private void AddDirectory()
    {
        string path = _newDirPath.Trim();
        if (string.IsNullOrEmpty(path))
        {
            _contentStatus = "Enter a directory path first.";
            _contentStatusSeverity = Severity.Warning;
            return;
        }

        if (!Directory.Exists(path))
        {
            _contentStatus = $"Directory not found: {path}";
            _contentStatusSeverity = Severity.Error;
            return;
        }

        Content.AddDirectory(path);
        _newDirPath = "";
        _needsContentReload = true;
        _contentStatus = null;
    }

    private static string FormatUtc(string? utcText)
    {
        if (string.IsNullOrWhiteSpace(utcText)) return "Unknown";
        return DateTime.TryParse(
            utcText,
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.AssumeUniversal | System.Globalization.DateTimeStyles.AdjustToUniversal,
            out var parsed)
            ? parsed.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")
            : utcText;
    }

    private void RefreshDatabaseDiagnostics()
    {
        _dbHealth = ContentDb.GetHealthReport();
    }

    private static Severity ParitySeverity(ContentDatabaseParityReport report) => report.Status switch
    {
        ContentDatabaseParityStatus.Healthy => Severity.Success,
        ContentDatabaseParityStatus.Warning => Severity.Warning,
        ContentDatabaseParityStatus.Error => Severity.Error,
        _ => Severity.Info
    };

    private static string ParitySummary(ContentDatabaseParityReport report) => report.Status switch
    {
        ContentDatabaseParityStatus.Healthy => "SQLite and XML snapshots matched in this audit run.",
        ContentDatabaseParityStatus.Warning when report.ReviewableMismatchCount > 0
            => $"Parity audit found {report.ReviewableMismatchCount} reviewable snapshot difference(s). Known XML-only internal entries are counted separately.",
        ContentDatabaseParityStatus.Warning when report.TotalMismatchCount > 0
            => $"Parity audit found only known/internal snapshot differences ({report.TotalMismatchCount} total).",
        ContentDatabaseParityStatus.Warning => "Parity audit matched structurally, but one of the loaders skipped elements during reconstruction.",
        ContentDatabaseParityStatus.Error when !report.Success => $"Parity audit failed: {report.FailureReason}",
        ContentDatabaseParityStatus.Error => $"Parity audit found {report.TotalMismatchCount} mismatch bucket(s) between XML and SQLite snapshots.",
        _ => "Parity audit status is unavailable."
    };

    private async Task RunParityAuditAsync()
    {
        _parityRunning = true;
        try
        {
            _dbParity = await Parity.RunAsync();
        }
        finally
        {
            _parityRunning = false;
        }
    }

    private static Severity HealthSeverity(ContentDatabaseHealthReport health) => health.Status switch
    {
        ContentDatabaseHealthStatus.Healthy => Severity.Success,
        ContentDatabaseHealthStatus.Warning => Severity.Warning,
        ContentDatabaseHealthStatus.Error => Severity.Error,
        _ => Severity.Info
    };

    private static string HealthSummary(ContentDatabaseHealthReport health) => health.Status switch
    {
        ContentDatabaseHealthStatus.Healthy
            => health.AutoRecoveredIssueCount > 0 || health.ExpectedIssueCount > 0
                ? $"Content trust is load-safe. {health.AutoRecoveredIssueCount} issue(s) were auto-recovered and {health.ExpectedIssueCount} expected diagnostic(s) were classified."
                : "Content trust is load-safe.",
        ContentDatabaseHealthStatus.Warning
            => $"Content trust has {health.ManualReviewIssueCount} manual-review issue(s), with no blocking loader failures.",
        ContentDatabaseHealthStatus.Error
            => $"Content trust has {health.BlockingIssueCount} blocking issue(s). Rebuild or fix content before relying on SQLite content.",
        _ => "Content health is unavailable."
    };

    private static string TrustImpactLabel(ContentDatabaseTrustImpact impact) => impact switch
    {
        ContentDatabaseTrustImpact.Blocking => "Blocking",
        ContentDatabaseTrustImpact.ManualReview => "Manual review",
        ContentDatabaseTrustImpact.AutoRecovered => "Auto-recovered",
        ContentDatabaseTrustImpact.Expected => "Expected",
        _ => impact.ToString()
    };

    private static string HealthGroupLabel(ContentDatabaseHealthIssueGroup group)
    {
        string file = string.IsNullOrWhiteSpace(group.FilePath) ? "" : $" in {group.FilePath}";
        return group.Area switch
        {
            "unresolved-link" => $"{group.Status}/{group.Reason} {group.Kind}",
            "source-integrity" => $"{group.Reason}{file}",
            _ => $"{group.Area}/{group.Reason}{file}"
        };
    }

    private static string HealthSampleLabel(ContentDatabaseHealthIssueSample sample)
    {
        bool hasFile = !string.IsNullOrWhiteSpace(sample.FilePath);
        string location = hasFile ? sample.FilePath : sample.Owner;
        string owner = hasFile && !string.IsNullOrWhiteSpace(sample.Owner) ? $" {sample.Owner}" : "";
        string key = string.IsNullOrWhiteSpace(sample.Key) ? "" : $" [{sample.Key}]";
        string text = string.IsNullOrWhiteSpace(sample.Text) ? "" : $" {sample.Text}";
        return $"{sample.Reason}: {location}{owner}{key}{text}";
    }

    private async Task CopyContentDiagnosticsAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", BuildContentDiagnosticsReport());
            Snackbar.Add("Content diagnostics copied.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Could not copy diagnostics. The report is still visible in Settings.", Severity.Error);
        }
    }

    private string BuildContentDiagnosticsReport()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Aurora content diagnostics");
        sb.AppendLine($"Generated: {DateTime.UtcNow:yyyy-MM-dd HH:mm:ss} UTC");

        if (ContentDb.GetMetadata() is { } meta)
        {
            sb.AppendLine();
            sb.AppendLine("Database metadata");
            sb.AppendLine($"Schema: {meta.SchemaVersion}");
            sb.AppendLine($"Data: {meta.DataVersion}");
            sb.AppendLine($"Importer: {meta.ImporterVersion}");
            sb.AppendLine($"Built: {FormatUtc(meta.BuiltUtc)}");
            sb.AppendLine($"Indexed files: {meta.SourceFileCount}");
            sb.AppendLine($"Elements: {meta.ElementCount}");
        }

        if (_dbHealth is { } health)
        {
            sb.AppendLine();
            sb.AppendLine("Content trust");
            sb.AppendLine($"Status: {health.Status}");
            sb.AppendLine($"Summary: {HealthSummary(health)}");
            sb.AppendLine($"Blocking: {health.BlockingIssueCount}");
            sb.AppendLine($"Manual review: {health.ManualReviewIssueCount}");
            sb.AppendLine($"Auto-recovered: {health.AutoRecoveredIssueCount}");
            sb.AppendLine($"Expected: {health.ExpectedIssueCount}");
            sb.AppendLine($"Actionable unresolved links: {health.ActionableUnresolvedLinks}");
            sb.AppendLine($"Classified unresolved links: {health.ClassifiedUnresolvedLinks}");
            sb.AppendLine($"Source integrity issues: {health.SourceIntegrityIssues}");
            sb.AppendLine($"Missing spell rows: {health.MissingResolvedSpellRows}");
            sb.AppendLine($"Missing item rows: {health.MissingResolvedItemRows}");
            sb.AppendLine($"Missing companion rows: {health.MissingResolvedCompanionRows}");

            if (health.Groups.Count > 0)
            {
                sb.AppendLine();
                sb.AppendLine("Diagnostic categories");
                foreach (var group in health.Groups)
                    sb.AppendLine($"- {TrustImpactLabel(group.Impact)} | {HealthGroupLabel(group)} | {group.Count}");
            }

            if (health.Samples.Count > 0)
            {
                sb.AppendLine();
                sb.AppendLine("Review samples");
                foreach (var sample in health.Samples)
                    sb.AppendLine($"- {TrustImpactLabel(sample.Impact)} | {HealthSampleLabel(sample)}");
            }
        }

        if (_dbParity is { } parity)
        {
            sb.AppendLine();
            sb.AppendLine("Database vs XML parity");
            sb.AppendLine($"Status: {parity.Status}");
            sb.AppendLine($"Success: {parity.Success}");
            if (!string.IsNullOrWhiteSpace(parity.FailureReason))
                sb.AppendLine($"Failure: {parity.FailureReason}");
            sb.AppendLine($"XML elements: {parity.XmlElementCount}");
            sb.AppendLine($"Database elements: {parity.DatabaseElementCount}");
            sb.AppendLine($"XML skipped: {parity.XmlSkippedElements}");
            sb.AppendLine($"Database skipped: {parity.DatabaseSkippedElements}");
            sb.AppendLine($"Missing from DB: {parity.MissingInDatabaseCount}");
            sb.AppendLine($"Reviewable missing from DB: {parity.ReviewableMissingInDatabaseCount}");
            sb.AppendLine($"Known XML-only internal missing from DB: {parity.KnownXmlOnlyInternalMissingInDatabaseCount}");
            sb.AppendLine($"Missing from XML: {parity.MissingInXmlCount}");
            AppendList(sb, "Reviewable XML entries missing from DB", parity.MissingInDatabaseSample);
            AppendList(sb, "Known XML-only internal entries missing from DB", parity.KnownXmlOnlyInternalSample);
            AppendList(sb, "DB entries missing from XML", parity.MissingInXmlSample);
        }

        return sb.ToString();
    }

    private static void AppendList(StringBuilder sb, string title, IReadOnlyList<string> values)
    {
        if (values.Count == 0)
            return;

        sb.AppendLine();
        sb.AppendLine(title);
        foreach (string value in values)
            sb.AppendLine($"- {value}");
    }

    private async Task FetchIndexAsync()
    {
        _contentWorking = true;
        _contentStatus = null;
        StateHasChanged();
        try
        {
            var (success, msg) = await Content.FetchIndexAsync(_indexUrl);
            if (_disposed) return;
            _contentStatus = msg;
            _contentStatusSeverity = success ? Severity.Success : Severity.Error;
            if (success)
            {
                _indexUrl = "";
                _needsContentReload = true;
            }
        }
        finally
        {
            _contentWorking = false;
        }

        // Newly-installed indices are empty — they're just a manifest pointing at the real
        // content URLs. Without an immediate Check-for-Updates the user is left with a
        // registered-but-empty index and has to click again to actually pull anything.
        // Chain into the existing handler so a single click of "Fetch Index" delivers the
        // payload too. CheckForUpdatesAsync manages its own _contentStatus / _checkingUpdates
        // state so the UI surfaces the progress and final tally.
        if (_contentStatusSeverity == Severity.Success && !_disposed)
            await CheckForUpdatesAsync();
    }

    private async Task CheckForUpdatesAsync()
    {
        _contentWorking = true;
        _checkingUpdates = true;
        _contentStatus = null;
        StateHasChanged();
        try
        {
            var (outcome, msg) = await Content.CheckForUpdatesAsync();
            if (_disposed) return;
            _contentStatus = msg;
            _contentStatusSeverity = outcome switch
            {
                ContentUpdateOutcome.Updated  => Severity.Success,
                ContentUpdateOutcome.UpToDate => Severity.Info,
                _                             => Severity.Error,
            };
            if (outcome == ContentUpdateOutcome.Updated) _needsContentReload = true;
        }
        finally
        {
            _contentWorking = false;
            _checkingUpdates = false;
        }
    }

    // ── Character storage directory ──────────────────────────────────────────

    private async Task BrowseCharactersDirAsync()
    {
        _dirBusy  = true;
        _dirError = null;
        StateHasChanged();
        try
        {
            string? chosen = await CharacterService.PickCharactersDirectoryAsync();
            if (chosen == null) return;
            _dirError = Characters.ApplyCustomCharactersDirectory(chosen);
            if (_dirError == null)
            {
                HandleContentRootChanged();
                Snackbar.Add($"Characters folder set to: {chosen}", Severity.Success,
                    cfg => cfg.VisibleStateDuration = 4000);
            }
        }
        finally
        {
            _dirBusy = false;
            StateHasChanged();
        }
    }

    private Task UseExternalStorageAsync()
    {
        _dirError = null;
        string? path = CharacterService.GetAndroidExternalStoragePath();
        if (path == null)
        {
            _dirError = "External storage path is not available on this device.";
            return Task.CompletedTask;
        }
        _dirError = Characters.ApplyCustomCharactersDirectory(path);
        if (_dirError == null)
        {
            HandleContentRootChanged();
            Snackbar.Add("Switched to external storage. Files are now accessible from the Files app.",
                Severity.Success, cfg => cfg.VisibleStateDuration = 5000);
        }
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task ResetCharactersDirAsync()
    {
        _dirError = Characters.ApplyCustomCharactersDirectory(null);
        if (_dirError == null)
        {
            HandleContentRootChanged();
            Snackbar.Add("Characters folder reset to default.", Severity.Success,
                cfg => cfg.VisibleStateDuration = 3000);
        }
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void HandleContentRootChanged()
    {
        ContentDb.NotifyContentDirectoryChanged();
        _stalenessChecked = false;
        _dbParity = null;
        _needsContentReload = true;
        RefreshDatabaseDiagnostics();
    }

    public void Dispose()
    {
        _disposed = true;
        ContentDb.StateChanged -= OnStateChanged;
        Content.Changed -= OnContentChanged;
        AppUpdates.Changed -= OnAppUpdatesChanged;
        ContentUpdates.Changed -= OnContentUpdatesChanged;
    }
}
