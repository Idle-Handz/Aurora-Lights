    </entry>

    <!-- 2024 (5.5) — Eberron: Forge of the Artificer. Choose A or B:
         (A) the fixed kit below plus 16 GP, or (B) take 150 GP instead of all equipment. -->
    <entry element-id="ID_EFA_CLASS_ARTIFICER">
        <starting-equipment>
            <gold-alternative amount="150" />

            <item id="ID_WOTC_PHB24_ARMOR_LIGHT_STUDDED_LEATHER" />
            <item id="ID_WOTC_PHB24_WEAPON_DAGGER" />
            <item id="ID_WOTC_PHB24_ITEM_TOOL_THIEVES_TOOLS" />
            <item id="ID_WOTC_PHB24_ITEM_TOOL_TINKERS_TOOLS" />
            <item id="ID_WOTC_PHB24_ITEM_DUNGEONEERS_PACK" />
            <gold amount="16" />
        </starting-equipment>
    </entry>
</aurora-starting-equipment>
