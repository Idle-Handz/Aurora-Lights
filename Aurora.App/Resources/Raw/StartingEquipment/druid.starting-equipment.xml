<?xml version="1.0" encoding="utf-8"?>
<aurora-starting-equipment>
    <entry element-id="ID_WOTC_PHB_CLASS_DRUID">
        <starting-equipment>
            <gold-alternative roll="2d4" multiplier="10" />

            <!-- (a) a wooden shield or (b) any simple weapon -->
            <choice>
                <option label="a">
                    <item id="ID_WOTC_GEAR_SHIELD" />
                </option>
                <option label="b">
                    <item category="Simple Weapon" />
                </option>
            </choice>

            <!-- (a) a scimitar or (b) any simple melee weapon -->
            <choice>
                <option label="a">
                    <item id="ID_WOTC_PHB_WEAPON_SCIMITAR" />
                </option>
                <option label="b">
                    <item category="Simple Weapon" />
                </option>
            </choice>

            <!-- Fixed: leather armor, an explorer's pack, and a druidic focus -->
            <item id="ID_WOTC_ARMOR_LIGHT_LEATHER" />
            <item id="ID_WOTC_ITEM_EXPLORERS_PACK" />
            <item category="Druidic Focus" />
        </starting-equipment>
    </entry>
</aurora-starting-equipment>
