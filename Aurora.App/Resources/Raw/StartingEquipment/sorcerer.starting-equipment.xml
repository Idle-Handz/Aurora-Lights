<?xml version="1.0" encoding="utf-8"?>
<aurora-starting-equipment>
    <entry element-id="ID_WOTC_PHB_CLASS_SORCERER">
        <starting-equipment>
            <gold-alternative roll="3d4" multiplier="10" />

            <!-- (a) a light crossbow and 20 bolts or (b) any simple weapon -->
            <choice>
                <option label="a">
                    <item id="ID_WOTC_PHB_WEAPON_CROSSBOW_LIGHT" />
                    <item id="ID_WOTC_PHB_ITEM_CROSSBOWBOLT" count="20" />
                </option>
                <option label="b">
                    <item category="Simple Weapon" />
                </option>
            </choice>

            <!-- (a) a component pouch or (b) an arcane focus -->
            <choice>
                <option label="a">
                    <item id="ID_WOTC_PHB_ITEM_COMPONENTPOUCH" />
                </option>
                <option label="b">
                    <item category="Arcane Focus" />
                </option>
            </choice>

            <!-- (a) a dungeoneer's pack or (b) an explorer's pack -->
            <choice>
                <option label="a">
                    <item id="ID_WOTC_ITEM_DUNGEONEERS_PACK" />
                </option>
                <option label="b">
                    <item id="ID_WOTC_ITEM_EXPLORERS_PACK" />
                </option>
            </choice>

            <!-- Fixed: two daggers -->
            <item id="ID_WOTC_PHB_WEAPON_DAGGER" count="2" />
        </starting-equipment>
    </entry>
</aurora-starting-equipment>
