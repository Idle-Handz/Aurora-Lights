@using System.Linq

<div class="character-browser-shell">
    @if (!string.IsNullOrWhiteSpace(Title) || !string.IsNullOrWhiteSpace(DirectoryCaption) || ShowCreateButton)
    {
        <div class="character-browser-header">
            <div>
                @if (!string.IsNullOrWhiteSpace(Title))
                {
                    <h2 class="character-browser-title">@Title</h2>
                }
                @if (!string.IsNullOrWhiteSpace(DirectoryCaption))
                {
                    <p class="character-browser-caption">@DirectoryCaption</p>
                }
            </div>

            <div class="character-browser-actions">
                @if (AdditionalHeaderContent != null)
                {
                    @AdditionalHeaderContent
                }
                @if (ShowCreateButton)
                {
                    <button class="character-browser-create"
                            type="button"
                            @onclick="OnCreate"
                            disabled="@DisableCreateButton">
                        @CreateButtonText
                    </button>
                }
            </div>
        </div>
    }

    @if (Characters.Count > 0)
    {
        <div class="character-browser-search-row">
            <input class="character-browser-search"
                   type="search"
                   placeholder="Search characters…"
                   value="@_searchText"
                   @oninput="OnSearchInput" />
            @if (!string.IsNullOrWhiteSpace(_searchText))
            {
                <span class="character-browser-search-count">
                    @_filtered.Count of @Characters.Count
                </span>
            }
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(BusyMessage))
    {
        <div class="character-browser-status">@BusyMessage</div>
    }

    @if (Characters.Count == 0)
    {
        <p class="character-browser-empty">@EmptyMessage</p>
        @if (!string.IsNullOrWhiteSpace(EmptySubMessage))
        {
            <p class="character-browser-empty-sub">@EmptySubMessage</p>
        }
    }
    else if (_filtered.Count == 0)
    {
        <p class="character-browser-empty">No characters match "@_searchText".</p>
    }
    else
    {
        @if (_favorites.Count > 0)
        {
            <section class="character-browser-section">
                <h3 class="character-browser-section-title">Favorites</h3>
                <div class="character-browser-grid">
                    @foreach (CharacterBrowserEntry character in _favorites)
                    {
                        <div class="character-browser-card-wrapper">
                            <button class="@GetCardClass(character)"
                                    type="button"
                                    @onclick="() => OnSelected.InvokeAsync(character)">
                                <div class="character-browser-portrait">
                                    @if (!string.IsNullOrWhiteSpace(character.PortraitDataUrl))
                                    {
                                        <img src="@character.PortraitDataUrl" alt="@character.DisplayName" />
                                    }
                                    else
                                    {
                                        <span>@GetInitials(character.DisplayName)</span>
                                    }
                                </div>

                                <div class="character-browser-card-body">
                                    <div class="character-browser-name-row">
                                        <span class="character-browser-name">@character.DisplayName</span>
                                        @if (character.IsFavorite)
                                        {
                                            <span class="character-browser-star" aria-hidden="true">★</span>
                                        }
                                    </div>

                                    <div class="character-browser-primary">@character.PrimaryText</div>

                                    @if (!string.IsNullOrWhiteSpace(character.SecondaryText))
                                    {
                                        <div class="character-browser-secondary">@character.SecondaryText</div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(character.CaptionText))
                                    {
                                        <div class="character-browser-tertiary">@character.CaptionText</div>
                                    }
                                </div>
                            </button>
                            @if (OnDelete.HasDelegate)
                            {
                                <button class="character-browser-delete-btn"
                                        type="button"
                                        title="Delete character"
                                        @onclick="() => OnDelete.InvokeAsync(character)"
                                        @onclick:stopPropagation="true">
                                    ×
                                </button>
                            }
                        </div>
                    }
                </div>
            </section>
        }

        @foreach (IGrouping<string, CharacterBrowserEntry> group in _groups)
        {
            <section class="character-browser-section">
                <h3 class="character-browser-section-title">@group.Key</h3>
                <div class="character-browser-grid">
                    @foreach (CharacterBrowserEntry character in group)
                    {
                        <div class="character-browser-card-wrapper">
                            <button class="@GetCardClass(character)"
                                    type="button"
                                    @onclick="() => OnSelected.InvokeAsync(character)">
                                <div class="character-browser-portrait">
                                    @if (!string.IsNullOrWhiteSpace(character.PortraitDataUrl))
                                    {
                                        <img src="@character.PortraitDataUrl" alt="@character.DisplayName" />
                                    }
                                    else
                                    {
                                        <span>@GetInitials(character.DisplayName)</span>
                                    }
                                </div>

                                <div class="character-browser-card-body">
                                    <div class="character-browser-name-row">
                                        <span class="character-browser-name">@character.DisplayName</span>
                                        @if (character.IsFavorite)
                                        {
                                            <span class="character-browser-star" aria-hidden="true">★</span>
                                        }
                                    </div>

                                    <div class="character-browser-primary">@character.PrimaryText</div>

                                    @if (!string.IsNullOrWhiteSpace(character.SecondaryText))
                                    {
                                        <div class="character-browser-secondary">@character.SecondaryText</div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(character.CaptionText))
                                    {
                                        <div class="character-browser-tertiary">@character.CaptionText</div>
                                    }
                                </div>
                            </button>
                            @if (OnDelete.HasDelegate)
                            {
                                <button class="character-browser-delete-btn"
                                        type="button"
                                        title="Delete character"
                                        @onclick="() => OnDelete.InvokeAsync(character)"
                                        @onclick:stopPropagation="true">
                                    ×
                                </button>
                            }
                        </div>
                    }
                </div>
            </section>
        }
    }
</div>

@code {
    private string _searchText = "";
    private IReadOnlyList<CharacterBrowserEntry> _filtered = [];
    private IReadOnlyList<CharacterBrowserEntry> _favorites = [];
    private IReadOnlyList<IGrouping<string, CharacterBrowserEntry>> _groups = [];

    [Parameter, EditorRequired]
    public IReadOnlyList<CharacterBrowserEntry> Characters { get; set; } = [];

    [Parameter]
    public string Title { get; set; } = "Characters";

    [Parameter]
    public string DirectoryCaption { get; set; } = string.Empty;

    [Parameter]
    public string EmptyMessage { get; set; } = "No characters are available yet.";

    [Parameter]
    public string? EmptySubMessage { get; set; }

    [Parameter]
    public string? BusyMessage { get; set; }

    [Parameter]
    public bool ShowCreateButton { get; set; }

    [Parameter]
    public string CreateButtonText { get; set; } = "New Character";

    [Parameter]
    public bool DisableCreateButton { get; set; }

    [Parameter]
    public string? SelectedId { get; set; }

    [Parameter]
    public EventCallback<CharacterBrowserEntry> OnSelected { get; set; }

    [Parameter]
    public EventCallback<CharacterBrowserEntry> OnDelete { get; set; }

    [Parameter]
    public EventCallback OnCreate { get; set; }

    [Parameter]
    public RenderFragment? AdditionalHeaderContent { get; set; }

    protected override void OnParametersSet() => ApplyFilter();

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString() ?? "";
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        _filtered = string.IsNullOrWhiteSpace(_searchText)
            ? Characters
            : Characters.Where(c =>
                c.DisplayName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                c.PrimaryText.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                (c.SecondaryText?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                (c.CaptionText?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                (c.GroupName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) == true))
            .ToList();

        _favorites = _filtered.Where(c => c.IsFavorite).ToList();
        _groups = _filtered
            .Where(c => !c.IsFavorite)
            .GroupBy(c => string.IsNullOrWhiteSpace(c.GroupName) ? "Characters" : c.GroupName!)
            .OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private string GetCardClass(CharacterBrowserEntry character)
    {
        bool isSelected = string.Equals(character.Id, SelectedId, StringComparison.Ordinal);
        return isSelected
            ? "character-browser-card selected"
            : "character-browser-card";
    }

    private static string GetInitials(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "?";
        }

        string[] parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 1)
        {
            return parts[0][0].ToString().ToUpperInvariant();
        }

        return string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0])));
    }
}
