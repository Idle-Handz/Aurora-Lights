@using Microsoft.AspNetCore.Components.Web

<div class="character-creation-fields">
    <div class="character-creation-field">
        <label for="@NameFieldId">@NameLabel</label>
        <input id="@NameFieldId"
               class="character-creation-input"
               placeholder="@NamePlaceholder"
               @bind="Model.Name"
               @bind:event="oninput"
               @onkeydown="OnKeyDown" />
    </div>

    <div class="character-creation-field">
        <label for="@PlayerFieldId">@PlayerNameLabel</label>
        <input id="@PlayerFieldId"
               class="character-creation-input"
               placeholder="@PlayerNamePlaceholder"
               @bind="Model.PlayerName"
               @bind:event="oninput"
               @onkeydown="OnKeyDown" />
    </div>

    <div class="character-creation-field">
        <label for="@GroupFieldId">Group</label>
        <input id="@GroupFieldId"
               class="character-creation-input"
               list="@GroupListId"
               placeholder="Characters"
               @bind="Model.Group"
               @bind:event="oninput"
               @onkeydown="OnKeyDown" />
        <datalist id="@GroupListId">
            @foreach (var g in ExistingGroups)
            {
                <option value="@g" />
            }
        </datalist>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public CharacterCreationModel Model { get; set; } = new();

    [Parameter]
    public string NameLabel { get; set; } = "Character Name";

    [Parameter]
    public string PlayerNameLabel { get; set; } = "Player Name";

    [Parameter]
    public string NamePlaceholder { get; set; } = "New Character";

    [Parameter]
    public string PlayerNamePlaceholder { get; set; } = "Optional";

    [Parameter]
    public IReadOnlyList<string> ExistingGroups { get; set; } = [];

    [Parameter]
    public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }

    private string NameFieldId { get; } = $"character-name-{Guid.NewGuid():N}";
    private string PlayerFieldId { get; } = $"player-name-{Guid.NewGuid():N}";
    private string GroupFieldId { get; } = $"character-group-{Guid.NewGuid():N}";
    private string GroupListId { get; } = $"character-group-list-{Guid.NewGuid():N}";
}
