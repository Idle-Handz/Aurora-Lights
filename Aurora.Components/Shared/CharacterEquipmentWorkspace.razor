<div class="character-equipment-workspace">
    @if (Model.Attacks.Count > 0)
    {
        <section class="equipment-section">
            <div class="equipment-section-label">Attacks</div>
            <div class="equipment-attack-table">
                <div class="equipment-attack-row equipment-attack-header">
                    <span>Name</span>
                    <span>Attack</span>
                    <span>Damage</span>
                    <span>Range</span>
                </div>
                @foreach (EquipmentAttackModel attack in Model.Attacks)
                {
                    <div class="equipment-attack-row">
                        <span>@attack.Name</span>
                        <span>@attack.Attack</span>
                        <span>@attack.Damage</span>
                        <span>@attack.Range</span>
                    </div>
                }
            </div>
        </section>
    }

    <section class="equipment-section">
        <div class="equipment-section-label">Equipped Gear</div>
        <div class="equipment-gear-slots">
            @foreach (EquipmentGearSlotModel slot in Model.GearSlots)
            {
                var hasEquippedItem = !string.IsNullOrWhiteSpace(slot.EquippedIdentifier);
                var canOpenGearRow = OnOpenGearSlot.HasDelegate || (hasEquippedItem && OnOpenItemDetails.HasDelegate);
                <div class="equipment-gear-row @(canOpenGearRow ? "equipment-gear-row--clickable" : string.Empty)"
                     @ondblclick="() => OpenGearRowAsync(slot)"
                     title="@(hasEquippedItem && OnOpenItemDetails.HasDelegate ? "Double-click for details" : OnOpenGearSlot.HasDelegate ? "Double-click to change" : null)"
                     >
                    <div class="equipment-gear-label">@slot.Label</div>
                    <div class="@(slot.EquippedName is null ? "equipment-gear-empty" : "equipment-gear-item")">
                        @(slot.EquippedName ?? "- None -")
                    </div>
                    @if (OnOpenGearSlot.HasDelegate || OnOpenItemDetails.HasDelegate || OnUnequipGearSlot.HasDelegate)
                    {
                        <div class="equipment-gear-actions">
                            @if (OnOpenGearSlot.HasDelegate)
                            {
                                <button type="button"
                                        class="equipment-action-button"
                                        disabled="@Busy"
                                        @onclick="() => OnOpenGearSlot.InvokeAsync(slot.Id)">
                                    @(slot.EquippedName is null ? "Equip" : "Change")
                                </button>
                            }
                            @if (hasEquippedItem && OnOpenItemDetails.HasDelegate)
                            {
                                <button type="button"
                                        class="equipment-action-button secondary"
                                        disabled="@Busy"
                                        @onclick="() => OnOpenItemDetails.InvokeAsync(slot.EquippedIdentifier!)">
                                    Details
                                </button>
                            }
                            @if (slot.EquippedName is not null && OnUnequipGearSlot.HasDelegate)
                            {
                                <button type="button"
                                        class="equipment-action-button secondary"
                                        disabled="@Busy"
                                        @onclick="() => OnUnequipGearSlot.InvokeAsync(slot.Id)">
                                    Unequip
                                </button>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </section>

    <section class="equipment-section">
        <div class="equipment-section-label">Currency</div>
        <div class="session-currency-strip">
            <label class="session-coin-cell">
                <input class="session-coin-input" type="number" min="0"
                       value="@Model.Copper"
                       disabled="@(!OnCoinChanged.HasDelegate || Busy)"
                       @onchange='args => _ = ChangeCoinAsync("cp", args.Value?.ToString())' />
                <span class="session-coin-label">CP</span>
            </label>
            <label class="session-coin-cell">
                <input class="session-coin-input" type="number" min="0"
                       value="@Model.Silver"
                       disabled="@(!OnCoinChanged.HasDelegate || Busy)"
                       @onchange='args => _ = ChangeCoinAsync("sp", args.Value?.ToString())' />
                <span class="session-coin-label">SP</span>
            </label>
            <label class="session-coin-cell">
                <input class="session-coin-input" type="number" min="0"
                       value="@Model.Electrum"
                       disabled="@(!OnCoinChanged.HasDelegate || Busy)"
                       @onchange='args => _ = ChangeCoinAsync("ep", args.Value?.ToString())' />
                <span class="session-coin-label">EP</span>
            </label>
            <label class="session-coin-cell">
                <input class="session-coin-input" type="number" min="0"
                       value="@Model.Gold"
                       disabled="@(!OnCoinChanged.HasDelegate || Busy)"
                       @onchange='args => _ = ChangeCoinAsync("gp", args.Value?.ToString())' />
                <span class="session-coin-label">GP</span>
            </label>
            <label class="session-coin-cell">
                <input class="session-coin-input" type="number" min="0"
                       value="@Model.Platinum"
                       disabled="@(!OnCoinChanged.HasDelegate || Busy)"
                       @onchange='args => _ = ChangeCoinAsync("pp", args.Value?.ToString())' />
                <span class="session-coin-label">PP</span>
            </label>
        </div>
    </section>

    <section class="equipment-section">
        <div class="equipment-inventory-header">
            <div class="equipment-inventory-title">
                <div class="equipment-section-label">Inventory</div>
                @if (Model.AttunedMax > 0)
                {
                    <span class="equipment-attuned-summary">Attuned: @Model.AttunedCount / @Model.AttunedMax</span>
                }
            </div>

            @if (OnAddItem.HasDelegate)
            {
                <button type="button"
                        class="equipment-action-button primary"
                        disabled="@Busy"
                        @onclick="() => OnAddItem.InvokeAsync()">
                    Add Item
                </button>
            }
        </div>

        @if (Model.InventoryItems.Count == 0)
        {
            <p class="equipment-empty">No items in inventory.</p>
        }
        else
        {
            <div class="equipment-inventory-table">
                <div class="equipment-inventory-row equipment-inventory-header-row">
                    <span>Item</span>
                    <span></span>
                    <span>Qty</span>
                    <span>Weight</span>
                    <span>Value</span>
                    <span></span>
                </div>
                @foreach (EquipmentInventoryItemModel item in Model.InventoryItems)
                {
                    <div class="equipment-inventory-row @(OnOpenItemDetails.HasDelegate ? "equipment-inventory-row--clickable" : string.Empty)"
                         title="@(OnOpenItemDetails.HasDelegate ? "Double-click for details" : null)"
                         @ondblclick="() => OpenInventoryItemAsync(item.Identifier)">
                        <span>@item.Name</span>
                        <span class="equipment-tag-strip">
                            @if (item.IsEquippable)
                            {
                                <button type="button"
                                        class="equipment-tag @(item.IsEquipped ? "active" : string.Empty)"
                                        disabled="@(!OnToggleEquipped.HasDelegate || Busy)"
                                        title="@(item.IsEquipped ? $"Equipped: {item.EquippedLocation}" : "Equip item")"
                                        @onclick="() => OnToggleEquipped.InvokeAsync(item.Identifier)">
                                    E
                                </button>
                            }
                            @if (item.HasVersatile && item.IsEquipped)
                            {
                                var wieldedTwoHanded = string.Equals(item.EquippedLocation, "Two-Handed (Versatile)", StringComparison.OrdinalIgnoreCase);
                                <button type="button"
                                        class="equipment-tag @(wieldedTwoHanded ? "active" : string.Empty)"
                                        disabled="@(!OnToggleVersatileWield.HasDelegate || Busy)"
                                        title="@(wieldedTwoHanded ? "Wield one-handed" : "Wield two-handed")"
                                        @onclick="() => OnToggleVersatileWield.InvokeAsync(item.Identifier)">
                                    @(wieldedTwoHanded ? "2H" : "1H")
                                </button>
                            }
                            @if (item.IsAttunable)
                            {
                                <button type="button"
                                        class="equipment-tag attunement @(item.IsAttuned ? "active" : string.Empty)"
                                        disabled="@(!OnToggleAttuned.HasDelegate || Busy)"
                                        title="@(item.IsAttuned ? "Attuned" : "Requires attunement")"
                                        @onclick="() => OnToggleAttuned.InvokeAsync(item.Identifier)">
                                    @(item.IsAttuned ? "A" : "◇")
                                </button>
                            }
                            @if (item.CanExtract && OnExtractItem.HasDelegate)
                            {
                                <button type="button"
                                        class="equipment-tag extract"
                                        disabled="@Busy"
                                        title="Extract pack contents"
                                        @onclick="() => OnExtractItem.InvokeAsync(item.Identifier)">
                                    Extract
                                </button>
                            }
                        </span>
                        <span>
                            @if (item.IsStackable && OnChangeAmount.HasDelegate)
                            {
                                <input class="equipment-qty-input"
                                       type="number"
                                       min="1"
                                       max="999"
                                       value="@item.Amount"
                                       disabled="@Busy"
                                       @onchange="args => ChangeAmountAsync(item.Identifier, args)" />
                            }
                            else
                            {
                                <span class="equipment-static-qty">@item.Amount</span>
                            }
                        </span>
                        <span>@item.DisplayWeight</span>
                        <span>@item.DisplayPrice</span>
                        <span>
                            <div class="equipment-item-actions">
                                @if (OnOpenItemDetails.HasDelegate)
                                {
                                    <button type="button"
                                            class="equipment-icon-button"
                                            disabled="@Busy"
                                            aria-label="View item details"
                                            title="View item details"
                                            @onclick="() => OnOpenItemDetails.InvokeAsync(item.Identifier)">
                                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                            <path d="M11 17h2v-6h-2v6Zm1-8c.69 0 1.25-.56 1.25-1.25S12.69 6.5 12 6.5s-1.25.56-1.25 1.25S11.31 9 12 9Zm0 13A10 10 0 1 1 12 2a10 10 0 0 1 0 20Zm0-2A8 8 0 1 0 12 4a8 8 0 0 0 0 16Z" />
                                        </svg>
                                    </button>
                                }
                                @if (OnEditItem.HasDelegate)
                                {
                                    <button type="button"
                                            class="equipment-edit-button"
                                            disabled="@Busy"
                                            title="Rename or add notes"
                                            @onclick="() => OnEditItem.InvokeAsync(item.Identifier)">
                                        ✏
                                    </button>
                                }
                                @if (OnRemoveItem.HasDelegate)
                                {
                                    <button type="button"
                                            class="equipment-remove-button"
                                            disabled="@Busy"
                                            @onclick="() => OnRemoveItem.InvokeAsync(item.Identifier)">
                                        ×
                                    </button>
                                }
                            </div>
                        </span>
                    </div>
                }
            </div>
        }
    </section>

    <section class="equipment-section">
        <div class="equipment-section-label">Equipment Notes</div>
        <textarea class="equipment-notes-area"
                  rows="3"
                  value="@Model.EquipmentNotes"
                  disabled="@(!OnNoteChanged.HasDelegate || Busy)"
                  @oninput='args => ChangeNoteAsync("equipment", args)'></textarea>
    </section>

    <section class="equipment-section">
        <div class="equipment-section-label">Treasure</div>
        <textarea class="equipment-notes-area"
                  rows="3"
                  value="@Model.TreasureNotes"
                  disabled="@(!OnNoteChanged.HasDelegate || Busy)"
                  @oninput='args => ChangeNoteAsync("treasure", args)'></textarea>
    </section>

    <section class="equipment-section">
        <div class="equipment-section-label">Quest Items</div>
        <textarea class="equipment-notes-area"
                  rows="3"
                  value="@Model.QuestNotes"
                  disabled="@(!OnNoteChanged.HasDelegate || Busy)"
                  @oninput='args => ChangeNoteAsync("quest", args)'></textarea>
    </section>
</div>

@code {
    [Parameter, EditorRequired]
    public EquipmentOverviewModel Model { get; set; } = new();

    [Parameter]
    public bool Busy { get; set; }

    [Parameter]
    public EventCallback OnAddItem { get; set; }

    [Parameter]
    public EventCallback<string> OnOpenGearSlot { get; set; }

    [Parameter]
    public EventCallback<string> OnUnequipGearSlot { get; set; }

    [Parameter]
    public EventCallback<string> OnOpenItemDetails { get; set; }

    [Parameter]
    public EventCallback<string> OnRemoveItem { get; set; }

    [Parameter]
    public EventCallback<string> OnToggleEquipped { get; set; }

    [Parameter]
    public EventCallback<string> OnToggleVersatileWield { get; set; }

    [Parameter]
    public EventCallback<string> OnToggleAttuned { get; set; }

    [Parameter]
    public EventCallback<EquipmentAmountChangeModel> OnChangeAmount { get; set; }

    [Parameter]
    public EventCallback<EquipmentCoinChangeModel> OnCoinChanged { get; set; }

    [Parameter]
    public EventCallback<EquipmentNoteChangeModel> OnNoteChanged { get; set; }

    [Parameter]
    public EventCallback<string> OnEditItem { get; set; }

    [Parameter]
    public EventCallback<string> OnExtractItem { get; set; }

    private Task ChangeAmountAsync(string identifier, ChangeEventArgs args)
    {
        if (!OnChangeAmount.HasDelegate)
        {
            return Task.CompletedTask;
        }

        int amount = 1;
        if (args.Value is not null && int.TryParse(args.Value.ToString(), out int parsed))
        {
            amount = Math.Max(1, parsed);
        }

        return OnChangeAmount.InvokeAsync(new EquipmentAmountChangeModel(identifier, amount));
    }

    private Task OpenGearRowAsync(EquipmentGearSlotModel slot)
    {
        if (!string.IsNullOrWhiteSpace(slot.EquippedIdentifier) && OnOpenItemDetails.HasDelegate)
            return OnOpenItemDetails.InvokeAsync(slot.EquippedIdentifier);

        return OnOpenGearSlot.HasDelegate
            ? OnOpenGearSlot.InvokeAsync(slot.Id)
            : Task.CompletedTask;
    }

    private Task OpenInventoryItemAsync(string identifier) =>
        OnOpenItemDetails.HasDelegate
            ? OnOpenItemDetails.InvokeAsync(identifier)
            : Task.CompletedTask;

    private Task ChangeCoinAsync(string coinId, string? rawValue)
    {
        if (!OnCoinChanged.HasDelegate)
        {
            return Task.CompletedTask;
        }

        long value = 0;
        if (!string.IsNullOrWhiteSpace(rawValue) && long.TryParse(rawValue, out long parsed))
        {
            value = Math.Max(0, parsed);
        }

        return OnCoinChanged.InvokeAsync(new EquipmentCoinChangeModel(coinId, value));
    }

    private Task ChangeNoteAsync(string noteId, ChangeEventArgs args)
    {
        if (!OnNoteChanged.HasDelegate)
        {
            return Task.CompletedTask;
        }

        return OnNoteChanged.InvokeAsync(new EquipmentNoteChangeModel(noteId, args.Value?.ToString() ?? string.Empty));
    }
}
