<UserControl x:Class="Builder.Presentation.UserControls.RefactoredAbilitiesContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:userControls="clr-namespace:Builder.Presentation.UserControls"
             xmlns:converters="clr-namespace:Builder.Presentation.Converters"
             mc:Ignorable="d"
             d:DesignHeight="420"
             d:DesignWidth="1100">
  <Grid Margin="10,10,10,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid.Resources>
      <converters:AvailablePointsValueConverter x:Key="AvailablePointsBrushConverter" />

      <Style x:Key="AbilityHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource GrayBrush2}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,4" />
      </Style>

      <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource LightMetroWindowButtonStyle}">
        <Setter Property="Margin" Value="0,0,10,0" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="MinWidth" Value="110" />
      </Style>

      <Style x:Key="InlineAbilityButtonStyle" TargetType="Button" BasedOn="{StaticResource MetroFlatButton}">
        <Setter Property="Width" Value="22" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
      </Style>
    </Grid.Resources>

    <Grid Grid.Row="0" Margin="0,0,0,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <StackPanel Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Visibility="{Binding IsPointsGeneration, Converter={StaticResource BooleanToVisibilityConverter}}">
        <TextBlock Text="ABILITY POINTS:"
                   Style="{StaticResource AbilityHeaderTextStyle}"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0" />
        <TextBlock Text="{Binding Abilities.AvailablePoints}"
                   VerticalAlignment="Center"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="{Binding Abilities.AvailablePoints, Converter={StaticResource AvailablePointsBrushConverter}}" />
        <TextBlock Text=" / 27"
                   VerticalAlignment="Center"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="{DynamicResource GrayBrush6}" />
      </StackPanel>

      <StackPanel Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Visibility="{Binding IsRandomizeGeneration, Converter={StaticResource BooleanToVisibilityConverter}}">
        <TextBlock Text="{Binding GenerationDisplayName}"
                   Style="{StaticResource AbilityHeaderTextStyle}"
                   VerticalAlignment="Center"
                   Margin="0,0,12,0" />
        <Button Style="{StaticResource ActionButtonStyle}"
                Command="{Binding RandomizeCommand}"
                ToolTip="Randomize all abilities">
          <StackPanel Orientation="Horizontal">
            <iconPacks:PackIconEntypo Kind="Cycle" Width="14" Height="14" Margin="0,0,6,0" />
            <TextBlock Text="Randomize All" />
          </StackPanel>
        </Button>
      </StackPanel>

      <StackPanel Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Visibility="{Binding IsArrayGeneration, Converter={StaticResource BooleanToVisibilityConverter}}">
        <TextBlock Text="{Binding GenerationDisplayName}"
                   Style="{StaticResource AbilityHeaderTextStyle}"
                   VerticalAlignment="Center" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right">
        <Button Style="{StaticResource LightMetroWindowButtonStyle}"
                Command="{Binding Abilities.ResetScoresCommand}"
                ToolTip="Reset ability scores"
                MinWidth="0"
                Padding="6,4">
          <StackPanel Orientation="Horizontal">
            <iconPacks:PackIconMaterial Kind="Restore" Width="16" Height="16" Margin="0,0,6,0" />
            <TextBlock Text="Reset" />
          </StackPanel>
        </Button>
        <Button Style="{StaticResource ActionButtonStyle}"
                Click="SwitchGenerateionButtonBase_OnClick"
                ToolTip="Switch to point buy in preferences"
                Visibility="{Binding IsPointsGeneration, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
          <StackPanel Orientation="Horizontal">
            <iconPacks:PackIconMaterial Kind="Tune" Width="14" Height="14" Margin="0,0,6,0" />
            <TextBlock Text="Point Buy" />
          </StackPanel>
        </Button>
      </StackPanel>
    </Grid>

    <TextBlock Grid.Row="1"
               Margin="0,0,0,10"
               Foreground="{DynamicResource GrayBrush2}"
               Text="Drag ability cards to reorder the standard array, use plus/minus for point buy, or randomize scores when rolling."
               TextWrapping="Wrap"
               Visibility="{Binding IsPointsGeneration, Converter={StaticResource InvertedBooleanToVisibilityConverter}}" />

    <UniformGrid Grid.Row="2" Columns="6" Margin="0,0,0,10">
      <Grid Margin="0,0,12,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <userControls:AbilitiesSpinner DataContext="{Binding Abilities.Strength}"
                                       AllowDrop="True"
                                       PreviewMouseMove="UIElement_OnMouseMove"
                                       Drop="UIElement_OnDrop" />
        <StackPanel Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsPointsGeneration, Converter={StaticResource BooleanToVisibilityConverter}}">
          <Button Style="{StaticResource InlineAbilityButtonStyle}"
                  Command="{Binding Abilities.IncreaseAbilityCommand}"
                  CommandParameter="{Binding Abilities.Strength}">
            <iconPacks:PackIconMaterial Kind="ChevronUp" Width="18" Height="18" Foreground="{DynamicResource GrayBrush6}" />
          </Button>
          <TextBlock Text="{Binding Abilities.Strength.BaseScore}" Foreground="{DynamicResource GrayBrush6}" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,5" />
          <Button Style="{StaticResource InlineAbilityButtonStyle}"
                  Command="{Binding Abilities.DecreaseAbilityCommand}"
                  CommandParameter="{Binding Abilities.Strength}">
            <iconPacks:PackIconMaterial Kind="ChevronDown" Width="18" Height="18" Foreground="{DynamicResource GrayBrush6}" />
          </Button>
        </StackPanel>
      </Grid>
      <Grid Margin="0,0,12,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <userControls:AbilitiesSpinner DataContext="{Binding Abilities.Dexterity}"
                                       AllowDrop="True"
                                       PreviewMouseMove="UIElement_OnMouseMove"
                                       Drop="UIElement_OnDrop" />
        <StackPanel Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsPointsGeneration, Converter={StaticResource BooleanToVisibilityConverter}}">
          <Button Style="{StaticResource InlineAbilityButtonStyle}"
                  Command="{Binding Abilities.IncreaseAbilityCommand}"
                  CommandParameter="{Binding Abilities.Dexterity}">
            <iconPacks:PackIconMaterial Kind="ChevronUp" Width="18" Height="18" Foreground="{DynamicResource GrayBrush6}" />
          </Button>
          <TextBlock Text="{Binding Abilities.Dexterity.BaseScore}" Foreground="{DynamicResource GrayBrush6}" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,5" />
          <Button Style="{StaticResource InlineAbilityButtonStyle}"
                  Command="{Binding Abilities.DecreaseAbilityCommand}"
                  CommandParameter="{Binding Abilities.Dexterity}">
            <iconPacks:PackIconMaterial Kind="ChevronDown" Width="18" Height="18" Foreground="{DynamicResource GrayBrush6}" />
          </Button>
        </StackPanel>
      </Grid>
      <Grid Margin="0,0,12,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <userControls:AbilitiesSpinner DataContext="{Binding Abilities.Constitution}"
                                       AllowDrop="True"
                                       PreviewMouseMove="UIElement_OnMouseMove"
                                       Drop="UIElement_OnDrop" />
        <StackPanel Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsPointsGeneration, Converter={StaticResource BooleanToVisibilityConverter}}">
          <Button Style="{StaticResource InlineAbilityButtonStyle}"
                  Command="{Binding Abilities.IncreaseAbilityCommand}"
                  CommandParameter="{Binding Abilities.Constitution}">
            <iconPacks:PackIconMaterial Kind="ChevronUp" Width="18" Height="18" Foreground="{DynamicResource GrayBrush6}" />
          </Button>
          <TextBlock Text="{Binding Abilities.Constitution.BaseScore}" Foreground="{DynamicResource GrayBrush6}" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,5" />
          <Button Style="{StaticResource InlineAbilityButtonStyle}"
                  Command="{Binding Abilities.DecreaseAbilityCommand}"
                  CommandParameter="{Binding Abilities.Constitution}">
            <iconPacks:PackIconMaterial Kind="ChevronDown" Width="18" Height="18" Foreground="{DynamicResource GrayBrush6}" />
          </Button>
        </StackPanel>
      </Grid>
      <Grid Margin="0,0,12,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <userControls:AbilitiesSpinner DataContext="{Binding Abilities.Intelligence}"
                                       AllowDrop="True"
                                       PreviewMouseMove="UIElement_OnMouseMove"
                                       Drop="UIElement_OnDrop" />
        <StackPanel Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsPointsGeneration, Converter={StaticResource BooleanToVisibilityConverter}}">
          <Button Style="{StaticResource InlineAbilityButtonStyle}"
                  Command="{Binding Abilities.IncreaseAbilityCommand}"
                  CommandParameter="{Binding Abilities.Intelligence}">
            <iconPacks:PackIconMaterial Kind="ChevronUp" Width="18" Height="18" Foreground="{DynamicResource GrayBrush6}" />
          </Button>
          <TextBlock Text="{Binding Abilities.Intelligence.BaseScore}" Foreground="{DynamicResource GrayBrush6}" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,5" />
          <Button Style="{StaticResource InlineAbilityButtonStyle}"
                  Command="{Binding Abilities.DecreaseAbilityCommand}"
                  CommandParameter="{Binding Abilities.Intelligence}">
            <iconPacks:PackIconMaterial Kind="ChevronDown" Width="18" Height="18" Foreground="{DynamicResource GrayBrush6}" />
          </Button>
        </StackPanel>
      </Grid>
      <Grid Margin="0,0,12,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <userControls:AbilitiesSpinner DataContext="{Binding Abilities.Wisdom}"
                                       AllowDrop="True"
                                       PreviewMouseMove="UIElement_OnMouseMove"
                                       Drop="UIElement_OnDrop" />
        <StackPanel Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsPointsGeneration, Converter={StaticResource BooleanToVisibilityConverter}}">
          <Button Style="{StaticResource InlineAbilityButtonStyle}"
                  Command="{Binding Abilities.IncreaseAbilityCommand}"
                  CommandParameter="{Binding Abilities.Wisdom}">
            <iconPacks:PackIconMaterial Kind="ChevronUp" Width="18" Height="18" Foreground="{DynamicResource GrayBrush6}" />
          </Button>
          <TextBlock Text="{Binding Abilities.Wisdom.BaseScore}" Foreground="{DynamicResource GrayBrush6}" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,5" />
          <Button Style="{StaticResource InlineAbilityButtonStyle}"
                  Command="{Binding Abilities.DecreaseAbilityCommand}"
                  CommandParameter="{Binding Abilities.Wisdom}">
            <iconPacks:PackIconMaterial Kind="ChevronDown" Width="18" Height="18" Foreground="{DynamicResource GrayBrush6}" />
          </Button>
        </StackPanel>
      </Grid>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <userControls:AbilitiesSpinner DataContext="{Binding Abilities.Charisma}"
                                       AllowDrop="True"
                                       PreviewMouseMove="UIElement_OnMouseMove"
                                       Drop="UIElement_OnDrop" />
        <StackPanel Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsPointsGeneration, Converter={StaticResource BooleanToVisibilityConverter}}">
          <Button Style="{StaticResource InlineAbilityButtonStyle}"
                  Command="{Binding Abilities.IncreaseAbilityCommand}"
                  CommandParameter="{Binding Abilities.Charisma}">
            <iconPacks:PackIconMaterial Kind="ChevronUp" Width="18" Height="18" Foreground="{DynamicResource GrayBrush6}" />
          </Button>
          <TextBlock Text="{Binding Abilities.Charisma.BaseScore}" Foreground="{DynamicResource GrayBrush6}" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,5" />
          <Button Style="{StaticResource InlineAbilityButtonStyle}"
                  Command="{Binding Abilities.DecreaseAbilityCommand}"
                  CommandParameter="{Binding Abilities.Charisma}">
            <iconPacks:PackIconMaterial Kind="ChevronDown" Width="18" Height="18" Foreground="{DynamicResource GrayBrush6}" />
          </Button>
        </StackPanel>
      </Grid>
    </UniformGrid>
  </Grid>
</UserControl>
