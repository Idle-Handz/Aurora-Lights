<UserControl x:Class="Builder.Presentation.UserControls.SavingThrowsPanelContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:content="clr-namespace:Builder.Presentation.ViewModels.Content;assembly=Aurora.Logic"
             mc:Ignorable="d">
  <Grid Margin="0,0,0,0">
    <FrameworkElement.DataContext>
      <content:SavingThrowsContentViewModel/>
    </FrameworkElement.DataContext>
    <ItemsControl ItemsSource="{Binding SavingThrowItems}">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Grid Margin="0,1,0,1" Background="{DynamicResource AccentColorBrush4}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="14"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Ellipse Width="8" Height="8" Margin="4,0,2,0" VerticalAlignment="Center"
                     Fill="{DynamicResource HighlightBrush}"
                     Visibility="{Binding IsProficient, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <TextBlock Grid.Column="1" Text="{Binding FinalBonusModifierString}" Foreground="{DynamicResource HighlightBrush}"
                       FontSize="12" FontWeight="SemiBold" Margin="0,1,6,1"/>
            <TextBlock Grid.Column="2" Text="{Binding Name}" Foreground="{DynamicResource GrayBrush6}" FontSize="12" Margin="0,1,6,1"/>
            <TextBlock Grid.Column="3" Text="{Binding KeyAbility.Abbreviation}" Foreground="{DynamicResource GrayBrush2}" FontSize="11" Margin="0,1,6,1"/>
          </Grid>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </Grid>
</UserControl>
