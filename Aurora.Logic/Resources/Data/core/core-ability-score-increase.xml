  <!-- TCE Customized Ability Score Increase options (Customizing Your Origin)                    -->
  <!-- +2 pool: one element per ability; each requires the option is on and the +1 for that       -->
  <!--          ability is NOT already selected (mutual exclusion prevents +2 and +1 to same).    -->
  <!-- +1 pool: one element per ability; likewise mutual-excludes its matching +2.                -->

  <element name="Strength" type="Ability Score Improvement" source="Internal" id="ID_WOTC_TCOE_OPTION_CUSTOMIZED_ASI_STRENGTH_INCREASE_2">
    <compendium display="false" />
    <supports>Custom Ability Score Increase 2</supports>
    <requirements>ID_WOTC_TCOE_OPTION_CUSTOMIZED_ASI,!ID_WOTC_TCOE_OPTION_CUSTOMIZED_ASI_STRENGTH_INCREASE_1</requirements>
    <description><p>Your Strength score increases by 2.</p></description>
    <sheet display="false" />
    <setters><set name="allow duplicate">false</set></setters>
    <rules><stat name="strength" value="2" alt="Racial Ability Score Increase" /></rules>
  </element>
