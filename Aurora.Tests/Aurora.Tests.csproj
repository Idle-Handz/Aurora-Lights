<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="bunit" Version="2.7.2" />
    <PackageReference Include="coverlet.collector" Version="6.0.4" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.4" />
    <PackageReference Include="FluentAssertions" Version="6.12.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Aurora.Logic\Aurora.Logic.csproj" />
    <ProjectReference Include="..\Aurora.Components\Aurora.Components.csproj" />
    <ProjectReference Include="..\Aurora.Importer\Aurora.Importer.csproj" />
    <Reference Include="Builder.Core">
      <HintPath>..\lib\Builder.Core.dll</HintPath>
    </Reference>
    <Reference Include="Builder.Data">
      <HintPath>..\lib\Builder.Data.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
    <Using Include="FluentAssertions" />
  </ItemGroup>

  <!-- Embed minimal test character XML as a resource -->
  <ItemGroup>
    <EmbeddedResource Include="Fixtures\*.dnd5e" />
    <Content Include="Fixtures\Characters\*.dnd5e" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Fixtures\ParityScenarios\*.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- Update-service source files live in Aurora.App (MAUI target). Link the pure-.NET ones here
       so we can test parsing, channel filtering, and comparison logic without pulling in MAUI.
       DebugLogService, GithubReleasesClient, UpdateAvailability, and GithubReleaseChannelService
       have no MAUI dependencies; AppUpdateService does (Velopack/AppInfo) so it is not linked.
       Test helpers in GithubUpdateChannelTests cover the logic via concrete subclasses. -->
  <ItemGroup>
    <Compile Include="..\Aurora.App\Services\Updates\SemVer.cs" Link="Linked\SemVer.cs" />
    <Compile Include="..\Aurora.App\Services\DebugLogService.cs" Link="Linked\DebugLogService.cs" />
    <Compile Include="..\Aurora.App\Services\Updates\GithubReleasesClient.cs" Link="Linked\GithubReleasesClient.cs" />
    <Compile Include="..\Aurora.App\Services\Updates\UpdateAvailability.cs" Link="Linked\UpdateAvailability.cs" />
    <Compile Include="..\Aurora.App\Services\Updates\GithubReleaseChannelService.cs" Link="Linked\GithubReleaseChannelService.cs" />
    <Compile Include="..\Aurora.App\Services\EquipmentService.cs" Link="Linked\EquipmentService.cs" />
    <Compile Include="..\Aurora.App\Services\SessionAttackReminderService.cs" Link="Linked\SessionAttackReminderService.cs" />
    <Compile Include="..\Aurora.App\Services\SessionState.cs" Link="Linked\SessionState.cs" />
    <Compile Include="..\Aurora.App\Services\SessionStore.cs" Link="Linked\SessionStore.cs" />
  </ItemGroup>

</Project>
